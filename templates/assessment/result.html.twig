{% extends 'layout/app_shell.html.twig' %}

{% block title %}Assessment Result{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .circular-chart {
            display: block;
            margin: 3rem auto;
            max-width: 80%;
            max-height: 250px;
        }

        .circle-bg {
            fill: none;
            stroke: #f1f5f9;
            stroke-width: 3.8;
        }

        .circle {
            fill: none;
            stroke-width: 2.8;
            stroke-linecap: round;
            animation: progress 1.5s ease-out forwards;
        }


            0% {
                stroke-dasharray: 0 100;
            }
        }

        .percentage {
            fill: #1e293b;
            font-family: inherit;
            font-weight: 700;
            font-size: 0.5em;
            text-anchor: middle;
        }

        .result-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .detail-box {
            background: #f8fafc;
            padding: 1.5rem;
            border-radius: 12px;
            text-align: center;
        }
    </style>
{% endblock %}

{% block app_content %}
    {% set percentage = result.result %}
    {% set strokeColor = percentage > 75 ? '#10b981' : (percentage > 40 ? '#f59e0b' : '#ef4444') %}

    <div style="max-width: 600px; margin: 3rem auto; background: white; border-radius: 24px; padding: 3rem 2.5rem; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.01); text-align: center;">
        
        <p style="color: #64748b; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin: 0 0 0.5rem;">Assessment Complete</p>
        <h1 style="margin: 0 0 0.5rem; font-size: 2rem; color: #0f172a; letter-spacing: -0.02em;">{{ quiz.title }} Results</h1>

        <svg viewBox="0 0 36 36" class="circular-chart">
            <path class="circle-bg"
                d="M18 2.0845
                a 15.9155 15.9155 0 0 1 0 31.831
                a 15.9155 15.9155 0 0 1 0 -31.831"
            />
            <path class="circle"
                stroke="{{ strokeColor }}"
                stroke-dasharray="{{ percentage }}, 100"
                d="M18 2.0845
                a 15.9155 15.9155 0 0 1 0 31.831
                a 15.9155 15.9155 0 0 1 0 -31.831"
            />
            <text x="18" y="20.35" class="percentage">{{ percentage }}%</text>
        </svg>

        <p style="color: #475569; font-size: 1.1rem; max-width: 400px; margin: 0 auto; line-height: 1.6;">
            {% if percentage > 75 %}
                Fantastic work! You have a very strong tendency towards the factors identified in this assessment.
            {% elseif percentage > 40 %}
                You received a balanced score, indicating moderate alignment with the key identifiers of this assessment.
            {% else %}
                Your score indicates lower alignment with the evaluated criteria.
            {% endif %}
        </p>

        <div class="result-details">
            <div class="detail-box">
                <span style="display: block; color: #64748b; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 0.5rem;">Raw Score</span>
                <strong style="color: #0f172a; font-size: 1.5rem;">{{ result.score }} <span style="font-size: 1rem; color: #94a3b8;">/ {{ quiz.questions|length * 5 }}</span></strong>
            </div>
            <div class="detail-box">
                <span style="display: block; color: #64748b; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; margin-bottom: 0.5rem;">Completed On</span>
                <strong style="color: #0f172a; font-size: 1.15rem;">{{ result.takenAt|date('M j, Y') }}</strong>
            </div>
        </div>

        <div style="margin-top: 3rem;">
            <a href="{{ path('app_assessment_index') }}" style="display: inline-block; background: #3b82f6; color: white; text-decoration: none; padding: 0.85rem 2.5rem; border-radius: 8px; font-weight: 600; font-size: 1rem; transition: background 0.2s;" onmouseover="this.style.background='#2563eb'" onmouseout="this.style.background='#3b82f6'">
                Back to Dashboard
            </a>
        </div>
    </div>
{% endblock %}
