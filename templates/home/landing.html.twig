{% extends 'base.html.twig' %}

{% block title %}Welcome to Slimenify - Your Well-being Companion
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		/* Modern reset & base */
		body {
			margin: 0;
			font-family: 'Inter', system-ui, -apple-system, sans-serif;
			background-color: #f6f5ed;
			overflow-x: hidden;
			color: #5D4A3E;
			-webkit-font-smoothing: antialiased;
		}

		/* Fine Background Dynamic Shapes */
		.bg-shapes {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100vh;
			z-index: -1;
			overflow: hidden;
			pointer-events: none;
		}
		.shape {
			position: absolute; filter: blur(100px);
			opacity: 0.35;
			animation: float 30s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
			border-radius: 50%;
		}
		.shape-1 {
			background: rgba(128, 140, 117, 0.5);
			width: 700px;
			height: 700px;
			top: -200px;
			left: -200px;
			animation-delay: 0s;
		}
		.shape-2 {
			background: rgba(168, 134, 110, 0.4);
			width: 600px;
			height: 600px;
			bottom: -150px;
			right: -100px;
			animation-delay: -5s;
		}

		/* Elegant fine grid overlay */
		.grid-overlay {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100vh;
			z-index: -1;
			opacity: 0.25;
			pointer-events: none;
			background-image: linear-gradient(rgba(122, 91, 73, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(122, 91, 73, 0.1) 1px, transparent 1px);
			background-size: 60px 60px;
		}

		@keyframes float {
			0% {
				transform: translate(0, 0) scale(1);
			}
			50% {
				transform: translate(40px, 60px) scale(1.05);
			}
			100% {
				transform: translate(-20px, 40px) scale(0.95);
			}
		}

		/* Nav Layout */
		.landing-nav {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 1.25rem 6%;
			position: fixed;
			width: 100%;
			top: 0;
			box-sizing: border-box;
			z-index: 100;
			background: rgba(246, 245, 237, 0.7); backdrop-filter: blur(40px);
			border-bottom: 1px solid rgba(122, 91, 73, 0.1);
			animation: fadeDown 1s forwards;
		}
		.brand {
			display: flex;
			align-items: center;
			gap: 1.2rem;
			text-decoration: none;
		}
		.brand img {
			height: 72px;
			width: 72px;
			border-radius: 18px;
			object-fit: cover;
			box-shadow: 0 10px 25px rgba(98, 114, 85, 0.15);
			border: 2px solid rgba(255, 255, 255, 0.7);
			transition: transform 0.4s ease;
		}
		.brand:hover img {
			transform: scale(1.05);
		}
		.brand-text {
			font-size: 2.2rem;
			font-weight: 800;
			background: linear-gradient(135deg, #5D4A3E, #748764);
			-webkit-background-clip: text;
			-webkit-text-fill-color: transparent;
			letter-spacing: -0.04em;
			margin: 0;
		}

		.nav-actions {
			display: flex;
			gap: 1.5rem;
			align-items: center;
		}
		.nav-link {
			color: #808c75;
			text-decoration: none;
			font-weight: 600;
			font-size: 1rem;
			transition: all 0.3s ease;
			position: relative;
			letter-spacing: 0.02em;
		}
		.nav-link::after {
			content: '';
			position: absolute;
			width: 0;
			height: 1px;
			bottom: -4px;
			left: 0;
			background-color: #627255;
			transition: width 0.3s ease;
		}
		.nav-link:hover {
			color: #5D4A3E;
		}
		.nav-link:hover::after {
			width: 100%;
		}

		/* Buttons */
		.btn {
			padding: 0.9rem 2.2rem;
			border-radius: 40px;
			font-weight: 600;
			font-size: 1rem;
			text-decoration: none;
			transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
			display: inline-flex;
			align-items: center;
			gap: 0.6rem;
			letter-spacing: 0.02em;
		}
		.btn-outline {
			color: #5D4A3E;
			background: rgba(255, 255, 255, 0.5);
			border: 1px solid rgba(122, 91, 73, 0.2);
		}
		.btn-outline:hover {
			background: #ffffff;
			border-color: #A8866E;
			transform: translateY(-3px);
			box-shadow: 0 15px 30px rgba(122, 91, 73, 0.08);
		}
		.btn-primary {
			background: linear-gradient(135deg, #748764, #A8866E);
			color: white;
			box-shadow: 0 10px 25px rgba(98, 114, 85, 0.2);
		}
		.btn-primary:hover {
			color: white;
			transform: translateY(-4px);
			box-shadow: 0 15px 35px rgba(98, 114, 85, 0.3);
		}

		/* Hero */
		.hero {
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
			padding: 12rem 5% 6rem;
			position: relative;
			z-index: 10;
			max-width: 1000px;
			margin: 0 auto;
			min-height: 80vh;
			justify-content: center;
		}

		.hero-badge {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			padding: 0.6rem 1.8rem;
			background: rgba(255, 255, 255, 0.6);
			color: #808c75;
			border-radius: 40px;
			font-weight: 600;
			font-size: 0.85rem;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			margin-bottom: 2.5rem;
			border: 1px solid rgba(255, 255, 255, 0.9);
			box-shadow: 0 8px 20px rgba(98, 114, 85, 0.05);
			animation: fadeUp 1.2s forwards;
			opacity: 0; backdrop-filter: blur(10px);
		}
		.hero-badge span {
			display: block;
			width: 6px;
			height: 6px;
			background: #b2936a;
			border-radius: 50%;
		}

		.hero h1 {
			font-size: 5.5rem;
			font-weight: 800;
			line-height: 1.05;
			margin: 0 0 1.5rem;
			letter-spacing: -0.05em;
			color: #5D4A3E;
			animation: fadeUp 1.2s 0.2s forwards;
			opacity: 0;
		}
		.hero h1 span {
			color: #A8866E;
			font-weight: 400;
			font-style: italic;
		}

		.hero p {
			font-size: 1.3rem;
			color: #808c75;
			max-width: 600px;
			margin: 0 auto 3.5rem;
			line-height: 1.7;
			font-weight: 400;
			animation: fadeUp 1.2s 0.4s forwards;
			opacity: 0;
			letter-spacing: 0.01em;
		}

		.hero-actions {
			display: flex;
			gap: 1.5rem;
			justify-content: center;
			animation: fadeUp 1.2s 0.6s forwards;
			opacity: 0;
		}

		/* Elegant Line Separator */
		.separator {
			width: 1px;
			height: 80px;
			background: linear-gradient(to bottom, rgba(122, 91, 73, 0.1), transparent);
			margin: 0 auto 4rem;
			animation: fadeUp 1.2s 0.8s forwards;
			opacity: 0;
		}

		/* Features */
		.features {
			padding: 4rem 5% 8rem;
			max-width: 1200px;
			margin: 0 auto;
			position: relative;
			z-index: 10;
			animation: fadeUp 1.2s 1s forwards;
			opacity: 0;
		}
		.section-title {
			text-align: center;
			font-size: 3.2rem;
			font-weight: 800;
			color: #5D4A3E;
			margin-bottom: 5rem;
			letter-spacing: -0.04em;
		}
		.section-title span {
			color: #A8866E;
			font-weight: 400;
			font-style: italic;
		}

		.features-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
			gap: 3rem;
		}

		/* Fine Glass Cards */
		.feature-card {
			background: rgba(255, 255, 255, 0.6); backdrop-filter: blur(30px);
			border-radius: 30px;
			padding: 4rem 3rem;
			border: 1px solid rgba(255, 255, 255, 1);
			box-shadow: 0 20px 40px rgba(98, 114, 85, 0.04);
			transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.feature-card:hover {
			transform: translateY(-15px);
			box-shadow: 0 40px 80px rgba(122, 91, 73, 0.08);
			background: rgba(255, 255, 255, 0.85);
		}

		.feature-icon {
			width: 80px;
			height: 80px;
			border-radius: 50%;
			background: linear-gradient(135deg, rgba(255,255,255,0.8), rgba(255,255,255,0.1));
			display: flex;
			align-items: center;
			justify-content: center;
			margin-bottom: 2.5rem;
			color: #808c75;
			transition: all 0.4s;
			box-shadow: 0 10px 20px rgba(98, 114, 85, 0.05), inset 0 0 0 1px rgba(255, 255, 255, 1);
		}
		.feature-card:hover .feature-icon {
			background: #A8866E;
			color: white;
			transform: translateY(-5px);
			box-shadow: 0 15px 30px rgba(168, 134, 110, 0.2);
		}

		.feature-title {
			font-size: 1.6rem;
			font-weight: 700;
			color: #5D4A3E;
			margin-bottom: 1.2rem;
			letter-spacing: -0.02em;
		}
		.feature-desc {
			color: #808c75;
			line-height: 1.8;
			font-size: 1rem;
			font-weight: 400;
			opacity: 0.9;
		}

		@keyframes fadeUp {
			from {
				opacity: 0;
				transform: translateY(40px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
		@keyframes fadeDown {
			from {
				opacity: 0;
				transform: translateY(-20px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.landing-footer {
			text-align: center;
			padding: 4rem 2rem 3rem;
			color: #808c75;
			font-size: 0.9rem;
			font-weight: 500;
			position: relative;
			z-index: 10;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.5rem;
		}
		.footer-line {
			width: 40px;
			height: 1px;
			background: rgba(122, 91, 73, 0.3);
		}

		@media(max-width: 768px) {
			.hero {
				padding-top: 10rem;
			}
			.hero h1 {
				font-size: 4rem;
			}
			.hero p {
				font-size: 1.15rem;
			}
			.nav-actions .nav-link {
				display: none;
			}
			.hero-actions {
				flex-direction: column;
				width: 100%;
				max-width: 300px;
			}
			.hero-actions .btn {
				width: 100%;
				justify-content: center;
			}
			.brand img {
				height: 50px;
				width: 50px;
			}
			.brand-text {
				font-size: 1.8rem;
			}
		}
	</style>
{% endblock %}

{% block body %}
	<div class="grid-overlay"></div>
	<div class="bg-shapes">
		<div class="shape shape-1"></div>
		<div class="shape shape-2"></div>
	</div>

	<!-- Fine Navigation -->
	<nav class="landing-nav">
		<a href="/" class="brand">
			<img src="{{ asset('logo.jpg') }}" alt="Slimenify Logo" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'72\' height=\'72\'><rect width=\'72\' height=\'72\' fill=\'#f3f2ea\' stroke=\'#808c75\' stroke-width=\'2\' rx=\'18\'/><text x=\'50%\' y=\'50%\' fill=\'#5D4A3E\' font-family=\'sans-serif\' font-size=\'28\' font-weight=\'bold\' text-anchor=\'middle\' dominant-baseline=\'central\'>S</text></svg>'">
			<h1 class="brand-text">Slimenify</h1>
		</a>
		<div class="nav-actions">
			{% if app.user %}
				<a href="{{ path('app_home') }}" class="btn btn-primary">Go to Dashboard</a>
			{% else %}
				<a href="{{ path('app_login') }}" class="nav-link">Sign In</a>
				<a href="{{ path('app_register') }}" class="btn btn-primary">Get Started</a>
			{% endif %}
		</div>
	</nav>

	<!-- Fine Hero -->
	<header class="hero">
		<div class="hero-badge">
			<span></span>
			A Journey to Wellness</div>
		<h1>Your Path to Inner
			<br><span>Peace & Recovery</span>
		</h1>
		<p>Connecting patients with leading therapists. Take comprehensive assessments, track your progress, and acquire well-being products—seamlessly.</p>

		<div class="hero-actions">
			{% if app.user %}
				<a href="{{ path('app_home') }}" class="btn btn-primary">
					Access Your Dashboard
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="5" y1="12" x2="19" y2="12"></line>
						<polyline points="12 5 19 12 12 19"></polyline>
					</svg>
				</a>
			{% else %}
				<a href="{{ path('app_register') }}" class="btn btn-primary">
					Start Your Journey
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="5" y1="12" x2="19" y2="12"></line>
						<polyline points="12 5 19 12 12 19"></polyline>
					</svg>
				</a>
				<a href="{{ path('app_login') }}" class="btn btn-outline">Member Log In</a>
			{% endif %}
		</div>
	</header>

	<div class="separator"></div>

	<!-- Fine Features -->
	<section class="features">
		<h2 class="section-title">Discover the
			<span>Platform</span>
		</h2>

		<div class="features-grid">
			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
						<circle cx="9" cy="7" r="4"></circle>
						<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
						<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
					</svg>
				</div>
				<h3 class="feature-title">Top Therapists</h3>
				<p class="feature-desc">Connect directly with specialized therapists handpicked for your unique mental health requirements and easily manage your bookings instantly.</p>
			</div>

			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
						<polyline points="14 2 14 8 20 8"></polyline>
						<line x1="16" y1="13" x2="8" y2="13"></line>
						<line x1="16" y1="17" x2="8" y2="17"></line>
						<polyline points="10 9 9 9 8 9"></polyline>
					</svg>
				</div>
				<h3 class="feature-title">Smart Assessments</h3>
				<p class="feature-desc">Engage with clinically structured quizzes crafted by professionals. Review precise analytics of your progress tailored to your personal journey over time.</p>
			</div>

			<div class="feature-card">
				<div class="feature-icon">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="9" cy="21" r="1"></circle>
						<circle cx="20" cy="21" r="1"></circle>
						<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
					</svg>
				</div>
				<h3 class="feature-title">Wellness Products</h3>
				<p class="feature-desc">Discover our comprehensive collection of therapeutic products, natural supplements, and tools hand-selected to aid and accelerate your well-being.</p>
			</div>
		</div>
	</section>

	<footer class="landing-footer">
		<div class="footer-line"></div>
		<div style="display: flex; align-items: center; gap: 0.5rem; justify-content: center; margin-bottom: 0.5rem;">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
				<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
			</svg>
			Secure & Confidential
		</div>
		<div>&copy;
			{{ "now"|date("Y") }}
			Slimenify. All rights reserved.</div>
	</footer>
{% endblock %}
