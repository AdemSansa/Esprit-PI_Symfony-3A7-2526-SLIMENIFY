{% extends 'base.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<style>:root
	{
		--app-sidebar-bg: #0f172a;
		--app-sidebar-text: #e2e8f0;
		--app-sidebar-muted: #94a3b8;
		--app-accent: #22d3ee;
		--app-accent-hover: #06b6d4;
		--app-main-bg: transparent;
	}
	@keyframes fadeInSlideUp {
		0% {
			opacity: 0;
			transform: translateY(15px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes pulseGlow {
		0% {
			box-shadow: 0 0 0 0 rgba(128, 140, 117, 0.4);
		}
		70% {
			box-shadow: 0 0 0 10px rgba(128, 140, 117, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(128, 140, 117, 0);
		}
	}
	@keyframes appFlashIn {
		from {
			opacity: 0;
			transform: translateY(-14px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}
	@keyframes appFlashErrorGlow {
		0%, 100% {
			box-shadow: 0 4px 14px rgba(197, 48, 48, 0.12);
		}
		40% {
			box-shadow: 0 6px 22px rgba(197, 48, 48, 0.28);
		}
		70% {
			box-shadow: 0 4px 16px rgba(197, 48, 48, 0.18);
		}
	}
	.app-layout {
		display: flex;
		min-height: 100vh;
		margin: 0;
		font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
		position: relative;
	}
	.app-layout::before {
		content: "";
		position: fixed;
		top: -10px;
		left: -10px;
		right: -10px;
		bottom: -10px;
		background: #f9f8f4 url('{{ asset('psy.png') }}') repeat;
		filter: blur(6px);
		z-index: -1;
		pointer-events: none;
		opacity: 0.8;
	}
	.app-sidebar {
		width: 240px;
		flex-shrink: 0;
		background:
			radial-gradient(120% 80% at 0% 0%, rgba(34, 211, 238, 0.2) 0%, rgba(34, 211, 238, 0) 60%),
			radial-gradient(100% 65% at 100% 100%, rgba(129, 140, 248, 0.18) 0%, rgba(129, 140, 248, 0) 65%),
			linear-gradient(165deg, var(--app-sidebar-bg) 0%, #111827 45%, #0b1120 100%);
		color: var(--app-sidebar-text);
		padding: 1rem 0 0.85rem;
		display: flex;
		flex-direction: column;
		border-right: 1px solid rgba(148, 163, 184, 0.2);
		box-shadow: 10px 0 28px rgba(2, 6, 23, 0.45);
	}
	.app-sidebar__brand {
		padding: 0 1.1rem 1.05rem;
		font-weight: 800;
		font-size: 1.18rem;
		letter-spacing: -0.02em;
		border-bottom: 1px solid rgba(148, 163, 184, 0.18);
		margin-bottom: 0.4rem;
		background: linear-gradient(90deg, #e2e8f0, #67e8f9);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.app-sidebar__nav {
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
		padding: 0 0.7rem;
		overflow-y: auto;
	}
	.app-sidebar__section-title {
		margin: 1.1rem 0 0.2rem;
		padding: 0 0.85rem;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgba(148, 163, 184, 0.9);
	}
	.app-sidebar__nav a {
		position: relative;
		display: flex;
		align-items: center;
		padding: 0.58rem 0.82rem 0.58rem 1.45rem;
		border-radius: 10px;
		color: rgba(226, 232, 240, 0.92);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		transition: background 0.18s, color 0.18s, transform 0.18s;
	}
	.app-sidebar__nav a::before {
		content: '';
		position: absolute;
		left: 0.78rem;
		width: 6px;
		height: 6px;
		border-radius: 999px;
		background: rgba(148, 163, 184, 0.7);
		transition: background 0.18s, transform 0.18s;
	}
	.app-sidebar__nav a:hover {
		color: var(--app-sidebar-text);
		background: rgba(148, 163, 184, 0.16);
		transform: translateX(2px);
	}
	.app-sidebar__nav a:hover::before {
		background: #67e8f9;
		transform: scale(1.2);
	}
	.app-sidebar__nav a.is-active {
		color: #e0f2fe;
		background: linear-gradient(90deg, rgba(34, 211, 238, 0.3), rgba(129, 140, 248, 0.22));
		box-shadow: 0 10px 18px rgba(2, 6, 23, 0.38), inset 0 0 0 1px rgba(125, 211, 252, 0.28);
	}
	.app-sidebar__nav a.is-active::before {
		background: #67e8f9;
		transform: scale(1.35);
	}
	.app-sidebar__footer {
		margin-top: auto;
		padding: 1rem 1.1rem 1.2rem;
		border-top: 1px solid rgba(148, 163, 184, 0.18);
		font-size: 0.8rem;
		color: var(--app-sidebar-muted);
	}
	.app-sidebar__user {
		font-weight: 700;
		color: #f8fafc;
		margin-bottom: 0.5rem;
		background: rgba(30, 41, 59, 0.7);
		border: 1px solid rgba(103, 232, 249, 0.2);
		padding: 0.45rem 0.65rem;
		border-radius: 8px;
	}
	.btn-logout {
		display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
		margin-top: 12px;
		padding: 8px 15px;
		background: rgba(15, 23, 42, 0.55);
		border: 1px solid rgba(148, 163, 184, 0.35);
		color: #e2e8f0 !important;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s;
	}
	.btn-logout:hover {
		background: linear-gradient(90deg, #ef4444, #dc2626);
        border-color: rgba(254, 202, 202, 0.35);
		text-decoration: none;
	}
	.app-main {
		flex: 1;
		background: rgba(249, 248, 244, 0.4);
		padding: 1.75rem 2rem;
		overflow: auto;
		backdrop-filter: blur(2px);
	}
	.app-main__inner {
		width: 100%;
		max-width: 1400px;
		margin: 0 auto;
		animation: fadeInSlideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.app-flash-stack {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
		scroll-margin-top: 1rem;
	}
	.app-flash-stack:not(:has(.alert)) {
		margin-bottom: 0;
		min-height: 0;
	}
	.app-main .alert {
		display: flex;
		align-items: flex-start;
		gap: 0.65rem;
		padding: 0.85rem 1rem;
		border-radius: 10px;
		font-size: 0.95rem;
		line-height: 1.45;
		border: 1px solid transparent;
		opacity: 0;
		animation: appFlashIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
		box-shadow: 0 4px 14px rgba(45, 42, 38, 0.06);
	}
	.app-main .alert svg {
		flex-shrink: 0;
		margin-top: 2px;
	}
	.app-main .alert-success {
		background: #e8f0e4;
		border-color: rgba(98, 114, 85, 0.35);
		color: #3d4a32;
		animation-delay: 0.05s;
	}
	.app-main .alert-success svg {
		color: #627255;
	}
	.app-main .alert-error {
		background: #fdecea;
		border-color: rgba(185, 74, 72, 0.45);
		color: #6b1d1a;
		animation: appFlashIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards, appFlashErrorGlow 1.1s ease-in-out 0.4s 2;
	}
	.app-main .alert-error svg {
		color: #c53030;
	}
	@media (prefers-reduced-motion: reduce) {
		.app-main .alert {
			opacity: 1;
			animation: none;
			transform: none;
		}
		.app-main .alert-error {
			box-shadow: 0 4px 14px rgba(45, 42, 38, 0.06);
		}
	}
	.app-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.45rem 1rem 1rem;
		margin-bottom: 2rem;
		border: 1px solid rgba(148, 163, 184, 0.22);
		background: rgba(255, 255, 255, 0.62);
		backdrop-filter: blur(10px);
		border-radius: 16px;
		box-shadow: 0 10px 28px rgba(30, 41, 59, 0.08);
	}
	.app-header-left {
		display: flex;
		flex-direction: column;
	}
	.app-header-role {
		font-weight: 700;
		color: #0f172a;
		font-size: 0.95rem;
		text-transform: capitalize;
	}
	.app-header-sub {
		color: #475569;
		font-size: 0.8rem;
	}
	.app-header-right {
		display: flex;
		align-items: center;
		gap: 15px;
	}
	.app-header-greeting {
		display: flex;
		flex-direction: column;
		text-align: right;
	}
	.app-header-welcome {
		font-weight: 600;
		color: #0f172a;
		font-size: 0.95rem;
	}
	.app-header-glad {
		color: #6366f1;
		font-size: 0.8rem;
	}
	.app-header-avatar {
		width: 45px;
		height: 45px;
		border-radius: 50%;
		background: linear-gradient(135deg, #0ea5e9, #6366f1);
		color: #f8fafc;
        box-shadow: 0 8px 20px rgba(14, 165, 233, 0.25);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 1.3rem;
	}
	.cart-icon-btn {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		background: rgba(255, 255, 255, 0.92);
		border-radius: 12px;
		border: 1px solid rgba(125, 211, 252, 0.35);
		text-decoration: none;
		transition: all 0.2s;
		box-shadow: 0 8px 16px rgba(15, 23, 42, 0.1);
	}
	.cart-icon-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 20px rgba(99, 102, 241, 0.26) !important;
	}
	.locale-switcher {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.3rem;
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(148, 163, 184, 0.35);
		border-radius: 999px;
	}
	.locale-switcher__link {
		text-decoration: none;
		font-size: 0.76rem;
		font-weight: 700;
		padding: 0.28rem 0.52rem;
		border-radius: 999px;
		color: #475569;
		transition: all 0.2s;
	}
	.locale-switcher__link:hover {
		background: rgba(99, 102, 241, 0.12);
		color: #1e293b;
	}
	.locale-switcher__link.is-active {
		background: linear-gradient(135deg, #0ea5e9, #6366f1);
		color: #fff;
	}
	
	/* KnpPaginator Global Styles to make them look like buttons */
	.pagination {
		display: flex;
		gap: 8px;
		list-style: none;
		padding: 0;
		margin: 20px 0;
		justify-content: center;
		align-items: center;
	}
	.pagination span, .pagination a {
		display: inline-block;
		padding: 8px 16px;
		border-radius: 8px;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
		background: rgba(255, 255, 255, 0.85);
		color: #334155;
		border: 1px solid rgba(148, 163, 184, 0.35);
		box-shadow: 0 8px 16px rgba(15, 23, 42, 0.08);
	}
	.pagination a:hover {
		background: linear-gradient(135deg, #0ea5e9, #6366f1);
		color: #ffffff;
		border-color: rgba(224, 231, 255, 0.35);
		transform: translateY(-1px);
		box-shadow: 0 10px 18px rgba(99, 102, 241, 0.3);
	}
	.pagination .current {
		background: linear-gradient(135deg, #0ea5e9, #6366f1);
		color: #ffffff;
		border-color: rgba(224, 231, 255, 0.35);
		box-shadow: inset 0 2px 4px rgba(15, 23, 42, 0.18);
	}
	
	/* --- PATIENT TOP NAV STYLES --- */
	.is-patient-layout {
		flex-direction: column;
		background: transparent;
	}
	.is-patient-layout .app-main {
		background: transparent;
		padding: 0;
	}
	.is-patient-layout .app-main__inner {
		padding: 2rem 1.5rem;
		max-width: 1200px;
		margin: 0 auto;
	}
	.patient-top-nav {
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(16px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.4);
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
		position: sticky;
		top: 0;
		z-index: 100;
		padding: 0.6rem 0;
	}
	.patient-top-nav__container {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.patient-top-nav__brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 800;
		font-size: 1.4rem;
		background: linear-gradient(90deg, #3d4a32, #748764);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.patient-top-nav__brand-icon {
		width: 38px;
		height: 38px;
		background: linear-gradient(135deg, #748764, #b2936a);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 12px rgba(98,114,85,0.25);
	}
	.patient-top-nav__links {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		background: rgba(255, 255, 255, 0.5);
		padding: 0.35rem;
		border-radius: 100px;
		border: 1px solid rgba(255,255,255,0.6);
		box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
	}
	.patient-top-nav__link {
		color: #576550;
		font-weight: 600;
		font-size: 0.88rem;
		text-decoration: none;
		padding: 0.45rem 1rem;
		border-radius: 100px;
		transition: all 0.3s ease;
		position: relative;
	}
	.patient-top-nav__link:hover {
		color: #3d4a32;
		background: rgba(255, 255, 255, 0.8);
	}
	.patient-top-nav__link.is-active,
	.patient-nav-group:hover > .patient-top-nav__link,
	.patient-nav-group > .patient-top-nav__link.is-active {
		color: #fff;
		background: #748764;
		box-shadow: 0 4px 12px rgba(116, 135, 100, 0.3);
	}
	
	/* Dropdowns for Patient Nav */
	.patient-nav-group {
		position: relative;
		display: flex;
		align-items: center;
	}
	.patient-nav-group > .patient-top-nav__link::after {
		content: '';
		display: inline-block;
		width: 0.35em;
		height: 0.35em;
		border-right: 0.15em solid currentColor;
		border-bottom: 0.15em solid currentColor;
		transform: rotate(45deg) translateY(-2px);
		transition: transform 0.3s;
		margin-left: 6px;
	}
	.patient-nav-group:hover > .patient-top-nav__link::after {
		transform: rotate(-135deg) translate(-2px, -2px);
	}
	.patient-nav-dropdown {
		position: absolute;
		top: 100%;
		left: 50%;
		transform: translateX(-50%) translateY(10px);
		background: rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.5);
		border-radius: 12px;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
		padding: 0.5rem;
		min-width: 190px;
		opacity: 0;
		visibility: hidden;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		z-index: 200;
	}
	.patient-nav-group:hover .patient-nav-dropdown {
		opacity: 1;
		visibility: visible;
		transform: translateX(-50%) translateY(5px);
	}
	.patient-nav-dropdown a {
		text-decoration: none;
		color: #475569;
		font-size: 0.88rem;
		font-weight: 600;
		padding: 0.5rem 0.8rem;
		border-radius: 8px;
		transition: all 0.2s;
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.patient-nav-dropdown a:hover {
		background: #f1f5f9;
		color: #3d4a32;
	}
	.patient-nav-dropdown a.is-active {
		background: rgba(116, 135, 100, 0.08);
		color: #748764;
	}

	.patient-top-nav__actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.patient-top-nav__user {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding-left: 1rem;
		border-left: 1px solid rgba(148, 163, 184, 0.3);
	}
	.patient-avatar {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: linear-gradient(135deg, #748764, #b2936a);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 1.1rem;
		box-shadow: 0 4px 10px rgba(116, 135, 100, 0.3);
		text-decoration: none;
		transition: transform 0.2s;
	}
	.patient-avatar:hover {
		transform: scale(1.05);
	}
	.patient-logout {
		color: #ef4444;
		background: rgba(239, 68, 68, 0.1);
		width: 36px;
		height: 36px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
		text-decoration: none;
	}
	.patient-logout:hover {
		background: #ef4444;
		color: #fff;
		box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
	}

	/* Floating Action Button (FAB) */
	.app-fab {
		position: fixed;
		bottom: 30px;
		right: 30px;
		width: 85px;
		height: 85px;
		background: linear-gradient(135deg, #627255 0%, #808c75 100%);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
		z-index: 9999;
		animation: app-fab-pulse 2s infinite;
		border: 3px solid white;
		padding: 2px;
	}
	@keyframes app-fab-pulse {
		0% { box-shadow: 0 0 0 0 rgba(98, 114, 85, 0.7); transform: scale(1); }
		70% { box-shadow: 0 0 0 15px rgba(98, 114, 85, 0); transform: scale(1.05); }
		100% { box-shadow: 0 0 0 0 rgba(98, 114, 85, 0); transform: scale(1); }
	}
	.app-fab:hover {
		transform: scale(1.1) rotate(5deg);
		box-shadow: 0 15px 30px rgba(98, 114, 85, 0.5);
		color: white;
	}
	.app-fab svg {
		width: 28px;
		height: 28px;
	}
	.app-fab::after {
		content: 'Assistant AI';
		position: absolute;
		right: 70px;
		background: #3d4a32;
		color: white;
		padding: 6px 12px;
		border-radius: 8px;
		font-size: 0.85rem;
		font-weight: 600;
		white-space: nowrap;
		opacity: 0;
		transform: translateX(10px);
		transition: all 0.3s ease;
		pointer-events: none;
	}
	.app-fab:hover::after {
		opacity: 1;
		transform: translateX(0);
	}
	.btn-premium {
		display: inline-block;
		background: linear-gradient(135deg, #748764 0%, #546549 100%);
		color: white !important;
		padding: 12px 24px;
		border-radius: 12px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
		border: none;
		box-shadow: 0 4px 15px rgba(98, 114, 85, 0.2);
		cursor: pointer;
		text-align: center;
	}
	.btn-premium:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 25px rgba(98, 114, 85, 0.35);
		background: linear-gradient(135deg, #829672 0%, #617455 100%);
	}
	.btn-premium:active {
		transform: translateY(0);
	}
	</style>
{% endblock %}

{% block body %}
{% set route = app.request.attributes.get('_route') %}
{% set is_patient_only = app.user and app.user.role|lower == 'patient' %}
{% set currentLocale = app.request.locale|default('en') %}
{% set languageOptions = {'en': 'EN', 'fr': 'FR', 'ar': 'AR'} %}
<div class="app-layout {% if is_patient_only %}is-patient-layout{% endif %}">
	{% if not is_patient_only %}
	<aside class="app-sidebar" aria-label="Main navigation">
		<div class="app-sidebar__brand">{{ 'brand.name'|trans }}</div>
		<nav class="app-sidebar__nav">
