{% extends 'base.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<style>:root
	{
		--app-sidebar-bg: #808c75;
		--app-sidebar-text: #ffffff;
		--app-sidebar-muted: #d5d9d1;
		--app-accent: #627255;
		--app-accent-hover: #4f5d44;
		--app-main-bg: #f6f5ed;
	}
	@keyframes fadeInSlideUp {
		0% { opacity: 0; transform: translateY(15px); }
		100% { opacity: 1; transform: translateY(0); }
	}
	@keyframes pulseGlow {
		0% { box-shadow: 0 0 0 0 rgba(128, 140, 117, 0.4); }
		70% { box-shadow: 0 0 0 10px rgba(128, 140, 117, 0); }
		100% { box-shadow: 0 0 0 0 rgba(128, 140, 117, 0); }
	}
	.app-layout {
		display: flex;
		min-height: 100vh;
		margin: 0;
		font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
	}
	.app-sidebar {
		width: 240px;
		flex-shrink: 0;
		background: linear-gradient(180deg, var(--app-sidebar-bg) 0%, #687560 100%);
		color: var(--app-sidebar-text);
		padding: 1.25rem 0;
		display: flex;
		flex-direction: column;
	}
	.app-sidebar__brand {
		padding: 0 1.25rem 1.25rem;
		font-weight: 800;
		font-size: 1.3rem;
		letter-spacing: -0.02em;
		border-bottom: 1px solid rgba(255, 255, 255, .15);
		margin-bottom: 0.75rem;
		background: linear-gradient(90deg, #ffffff, #d5d9d1);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.app-sidebar__nav {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0 0.75rem;
	}
	.app-sidebar__nav a {
		display: block;
		padding: 0.65rem 0.85rem;
		border-radius: 8px;
		color: var(--app-sidebar-muted);
		text-decoration: none;
		font-size: 0.95rem;
		transition: background 0.15s, color 0.15s;
	}
	.app-sidebar__nav a:hover {
		color: var(--app-sidebar-text);
		background: rgba(255, 255, 255, .1);
	}
	.app-sidebar__nav a.is-active {
		color: #fff;
		background: rgba(255, 255, 255, 0.2);
	}
	.app-sidebar__footer {
		margin-top: auto;
		padding: 1rem 1.25rem 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, .08);
		font-size: 0.8rem;
		color: var(--app-sidebar-muted);
	}
	.btn-logout {
		display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
		margin-top: 12px;
		padding: 8px 15px;
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.3);
		color: #ffffff !important;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s;
	}
	.btn-logout:hover {
		background: #D9534F;
        border-color: #D9534F;
		text-decoration: none;
	}
	.app-main {
		flex: 1;
		background: var(--app-main-bg);
		padding: 1.75rem 2rem;
		overflow: auto;
	}
	.app-main__inner {
		max-width: 960px;
		animation: fadeInSlideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.app-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 0 1.25rem 0;
		margin-bottom: 2rem;
		border-bottom: 1px solid rgba(122, 91, 73, 0.1);
	}
	.app-header-left {
		display: flex;
		flex-direction: column;
	}
	.app-header-role {
		font-weight: 700;
		color: #5D4A3E;
		font-size: 0.95rem;
		text-transform: capitalize;
	}
	.app-header-sub {
		color: #A8866E;
		font-size: 0.8rem;
	}
	.app-header-right {
		display: flex;
		align-items: center;
		gap: 15px;
	}
	.app-header-greeting {
		display: flex;
		flex-direction: column;
		text-align: right;
	}
	.app-header-welcome {
		font-weight: 600;
		color: #5D4A3E;
		font-size: 0.95rem;
	}
	.app-header-glad {
		color: #A8866E;
		font-size: 0.8rem;
	}
	.app-header-avatar {
		width: 45px;
		height: 45px;
		border-radius: 50%;
		background: #ffffff;
		color: #5D4A3E;
        box-shadow: 0 4px 12px rgba(122, 91, 73, 0.1);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 1.3rem;
	}
</style>{% endblock %}{% block body %}
{% set route = app.request.attributes.get('_route') %}
<div class="app-layout">
	<aside class="app-sidebar" aria-label="Main navigation">
		<div class="app-sidebar__brand">Slimenify</div>
		<nav class="app-sidebar__nav">
			<a href="{{ path('app_home') }}" class="{{ route == 'app_home' ? 'is-active' : '' }}">Home</a>

			{% if is_granted('ROLE_PATIENT') or is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_assessment_index') }}" class="{{ route starts with 'app_assessment' ? 'is-active' : '' }}">Assessments</a>
			{% endif %}

			{% if is_granted('ROLE_THERAPIST') or is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_quiz_index') }}" class="{{ route starts with 'app_quiz' ? 'is-active' : '' }}">Quizzes</a>
				<a href="{{ path('app_question_index') }}" class="{{ route starts with 'app_question' ? 'is-active' : '' }}">Questions</a>
			{% endif %}

			{% if is_granted('ROLE_PATIENT') or is_granted('ROLE_THERAPIST') or is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_product_index') }}" class="{{ route starts with 'app_product' ? 'is-active' : '' }}">Products</a>
			{% endif %}

			{% if is_granted('ROLE_PATIENT') %}
				<a href="{{ path('app_patient_dashboard') }}" class="{{ route == 'app_patient_dashboard' ? 'is-active' : '' }}" style="margin-top: 1.5rem;">Therapists</a>
			{% endif %}

			{% if is_granted('ROLE_ADMIN') %}
				<div style="margin-top: 1.5rem; margin-bottom: 0.25rem; padding: 0 0.85rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--app-sidebar-muted);">Admin Area</div>
				<a href="{{ path('app_admin_user_index') }}" class="{{ route starts with 'app_admin_user' ? 'is-active' : '' }}">Users</a>
				<a href="{{ path('app_admin_therapist_index') }}" class="{{ route starts with 'app_admin_therapist' ? 'is-active' : '' }}">Therapists</a>
				<a href="{{ path('app_supplier_index') }}" class="{{ route starts with 'app_supplier' ? 'is-active' : '' }}">Suppliers</a>
			{% endif %}

			{% if is_granted('ROLE_THERAPIST') and not is_granted('ROLE_ADMIN') %}
				<div style="margin-top: 1.5rem; margin-bottom: 0.25rem; padding: 0 0.85rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--app-sidebar-muted);">Therapist Space</div>
				<a href="{{ path('app_therapist_dashboard') }}" class="{{ route == 'app_therapist_dashboard' ? 'is-active' : '' }}">My Dashboard</a>
				<a href="{{ path('app_therapist_directory') }}" class="{{ route == 'app_therapist_directory' ? 'is-active' : '' }}">Therapists</a>
			{% endif %}
		</nav>
		<div class="app-sidebar__footer">
			{% if app.user %}
				<div style="font-weight: 600; color: #fff; margin-bottom: 5px;">{{ app.user.userIdentifier }}</div>
			{% endif %}
            <a href="{{ path('app_profile_index') }}" class="btn-logout" style="margin-top: 5px; background: rgba(255,255,255,0.05); border-color: transparent;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                My Profile
            </a>
			<a href="{{ path('app_logout') }}" class="btn-logout">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Log out
            </a>
		</div>
	</aside>
	<main class="app-main">
		<header class="app-header">
			<div class="app-header-left">
				<div class="app-header-role">
					{{ app.user ? app.user.role|default('User') : 'Guest' }}
				</div>
				<div class="app-header-sub">Your access level</div>
			</div>
			<div class="app-header-right">
				<div class="app-header-greeting">
					<div class="app-header-welcome">Bienvenue, {{ app.user ? app.user.firstName|capitalize : 'User' }}</div>
					<div class="app-header-glad">Glad to see you again 👋</div>
				</div>
				{% if app.user %}
					<div class="app-header-avatar">{{ app.user.firstName|first|upper }}</div>
				{% else %}
					<div class="app-header-avatar">?</div>
				{% endif %}
			</div>
		</header>

		<div class="app-main__inner">
			{% block app_content %}{% endblock %}
		</div>
	</main>
</div>{% endblock %}
