        <script>
            function bindSweetAlertDelete() {
                const forms = document.querySelectorAll('.swal-delete-form:not(.swal-bound)');
                forms.forEach(form => {
                    form.classList.add('swal-bound');
                    form.addEventListener('submit', function(e) {
                        e.preventDefault();
                        const itemName = form.getAttribute('data-name') || 'item';
                        Swal.fire({
                            title: 'Are you sure?',
                            text: "You won't be able to revert this " + itemName + " deletion!",
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            cancelButtonColor: '#3085d6',
                            confirmButtonText: 'Yes, delete it!'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                form.submit();
                            }
                        });
                    });
                });
            }
            document.addEventListener('DOMContentLoaded', bindSweetAlertDelete);
            document.addEventListener('turbo:load', bindSweetAlertDelete);
        </script>

