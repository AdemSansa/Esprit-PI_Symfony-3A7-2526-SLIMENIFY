{% extends 'base.html.twig' %}

{% block stylesheets %}
	{{ parent() }}
	<style>:root
	{
		--app-sidebar-bg: #808c75;
		--app-sidebar-text: #ffffff;
		--app-sidebar-muted: #d5d9d1;
		--app-accent: #627255;
		--app-accent-hover: #4f5d44;
		--app-main-bg: #f6f5ed;
	}
	@keyframes fadeInSlideUp {
		0% {
			opacity: 0;
			transform: translateY(15px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes pulseGlow {
		0% {
			box-shadow: 0 0 0 0 rgba(128, 140, 117, 0.4);
		}
		70% {
			box-shadow: 0 0 0 10px rgba(128, 140, 117, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(128, 140, 117, 0);
		}
	}
	.app-layout {
		display: flex;
		min-height: 100vh;
		margin: 0;
		font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
	}
	.app-sidebar {
		width: 240px;
		flex-shrink: 0;
		background: linear-gradient(180deg, var(--app-sidebar-bg) 0%, #687560 100%);
		color: var(--app-sidebar-text);
		padding: 1.25rem 0;
		display: flex;
		flex-direction: column;
	}
	.app-sidebar__brand {
		padding: 0 1.25rem 1.25rem;
		font-weight: 800;
		font-size: 1.3rem;
		letter-spacing: -0.02em;
		border-bottom: 1px solid rgba(255, 255, 255, 0.15);
		margin-bottom: 0.75rem;
		background: linear-gradient(90deg, #ffffff, #d5d9d1);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.app-sidebar__nav {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0 0.75rem;
	}
	.app-sidebar__nav a {
		display: block;
		padding: 0.65rem 0.85rem;
		border-radius: 8px;
		color: var(--app-sidebar-muted);
		text-decoration: none;
		font-size: 0.95rem;
		transition: background 0.15s, color 0.15s;
	}
	.app-sidebar__nav a:hover {
		color: var(--app-sidebar-text);
		background: rgba(255, 255, 255, 0.1);
	}
	.app-sidebar__nav a.is-active {
		color: #fff;
		background: rgba(255, 255, 255, 0.2);
	}
	.app-sidebar__footer {
		margin-top: auto;
		padding: 1rem 1.25rem 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, .08);
		font-size: 0.8rem;
		color: var(--app-sidebar-muted);
	}
	.btn-logout {
		display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
		margin-top: 12px;
		padding: 8px 15px;
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.3);
		color: #ffffff !important;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s;
	}
	.btn-logout:hover {
		background: #D9534F;
        border-color: #D9534F;
		text-decoration: none;
	}
	.app-main {
		flex: 1;
		background: var(--app-main-bg);
		padding: 1.75rem 2rem;
		overflow: auto;
	}
	.app-main__inner {
		max-width: 960px;
		animation: fadeInSlideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.app-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 0 1.25rem 0;
		margin-bottom: 2rem;
		border-bottom: 1px solid rgba(122, 91, 73, 0.1);
	}
	.app-header-left {
		display: flex;
		flex-direction: column;
	}
	.app-header-role {
		font-weight: 700;
		color: #5D4A3E;
		font-size: 0.95rem;
		text-transform: capitalize;
	}
	.app-header-sub {
		color: #A8866E;
		font-size: 0.8rem;
	}
	.app-header-right {
		display: flex;
		align-items: center;
		gap: 15px;
	}
	.app-header-greeting {
		display: flex;
		flex-direction: column;
		text-align: right;
	}
	.app-header-welcome {
		font-weight: 600;
		color: #5D4A3E;
		font-size: 0.95rem;
	}
	.app-header-glad {
		color: #A8866E;
		font-size: 0.8rem;
	}
	.app-header-avatar {
		width: 45px;
		height: 45px;
		border-radius: 50%;
		background: #ffffff;
		color: #5D4A3E;
        box-shadow: 0 4px 12px rgba(122, 91, 73, 0.1);
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 800;
		font-size: 1.3rem;
	}
	.cart-icon-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(98,114,85,0.25) !important;
	}
	</style>
{% endblock %}

{% block body %}
{% set route = app.request.attributes.get('_route') %}
<div class="app-layout">
	<aside class="app-sidebar" aria-label="Main navigation">
		<div class="app-sidebar__brand">Slimenify</div>
		<nav class="app-sidebar__nav">
			<a href="{{ path('app_home') }}" class="{{ route == 'app_home' ? 'is-active' : '' }}">Home</a>

			{% if is_granted('ROLE_PATIENT') or is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_assessment_index') }}" class="{{ route starts with 'app_assessment' ? 'is-active' : '' }}">Assessments</a>
			{% endif %}

			{% if is_granted('ROLE_THERAPIST') or is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_quiz_index') }}" class="{{ route starts with 'app_quiz' ? 'is-active' : '' }}">Quizzes</a>
				<a href="{{ path('app_question_index') }}" class="{{ route starts with 'app_question' ? 'is-active' : '' }}">Questions</a>
				<a href="{{ path('app_availability_manage') }}" class="{{ route starts with 'app_availability' ? 'is-active' : '' }}">Availability</a>
			{% endif %}

			{% if is_granted('ROLE_PATIENT') or is_granted('ROLE_THERAPIST') or is_granted('ROLE_ADMIN') %}
				<a href="{{ path('app_product_index') }}" class="{{ route starts with 'app_product' ? 'is-active' : '' }}">Products</a>
				<a href="{{ path('app_appointments_calendar') }}" class="{{ route starts with 'app_appointments' ? 'is-active' : '' }}">Appointments</a>
			{% endif %}

			{% if is_granted('ROLE_PATIENT') %}
				<a href="{{ path('app_patient_dashboard') }}" class="{{ route == 'app_patient_dashboard' ? 'is-active' : '' }}" style="margin-top: 1.5rem;">Therapists</a>
			{% endif %}

			{% if is_granted('ROLE_ADMIN') %}
				<div style="margin-top: 1.5rem; margin-bottom: 0.25rem; padding: 0 0.85rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--app-sidebar-muted);">Admin Area</div>
				<a href="{{ path('app_admin_user_index') }}" class="{{ route starts with 'app_admin_user' ? 'is-active' : '' }}">Users</a>
				<a href="{{ path('app_admin_therapist_index') }}" class="{{ route starts with 'app_admin_therapist' ? 'is-active' : '' }}">Therapists</a>
				<a href="{{ path('app_supplier_index') }}" class="{{ route starts with 'app_supplier' ? 'is-active' : '' }}">Suppliers</a>
			{% endif %}

			{% if is_granted('ROLE_THERAPIST') and not is_granted('ROLE_ADMIN') %}
				<div style="margin-top: 1.5rem; margin-bottom: 0.25rem; padding: 0 0.85rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--app-sidebar-muted);">Therapist Space</div>
				<a href="{{ path('app_therapist_dashboard') }}" class="{{ route == 'app_therapist_dashboard' ? 'is-active' : '' }}">My Dashboard</a>
				<a href="{{ path('app_therapist_directory') }}" class="{{ route == 'app_therapist_directory' ? 'is-active' : '' }}">Therapists</a>
			{% endif %}
		</nav>
		<div class="app-sidebar__footer">
			{% if app.user %}
				<div style="font-weight: 600; color: #fff; margin-bottom: 5px;">{{ app.user.userIdentifier }}</div>
			{% endif %}
            <a href="{{ path('app_profile_index') }}" class="btn-logout" style="margin-top: 5px; background: rgba(255,255,255,0.05); border-color: transparent;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                My Profile
            </a>
			<a href="{{ path('app_logout') }}" class="btn-logout">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Log out
            </a>
		</div>
	</aside>
	<main class="app-main">
		<header class="app-header">
			<div class="app-header-left">
				<div class="app-header-role">
					{{ app.user ? app.user.role|default('User') : 'Guest' }}
				</div>
				<div class="app-header-sub">Your access level</div>
			</div>
			<div class="app-header-right">
				{# Cart icon — only for patients #}
				{% if is_granted('ROLE_PATIENT') %}
					{% set cartCount = app.session.get('cart', [])|length %}
					<a href="{{ path('app_cart_index') }}" class="cart-icon-btn" title="My Cart" style="
						position: relative;
						display: flex; align-items: center; justify-content: center;
						width: 42px; height: 42px;
						background: #fff;
						border-radius: 12px;
						box-shadow: 0 2px 10px rgba(98,114,85,0.15);
						border: 1px solid #e8f0e4;
						text-decoration: none;
						transition: all 0.2s;
					">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#627255" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="9" cy="21" r="1"></circle>
							<circle cx="20" cy="21" r="1"></circle>
							<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
						</svg>
						{% if cartCount > 0 %}
							<span style="
								position: absolute; top: -6px; right: -6px;
								background: #b2936a;
								color: white;
								border-radius: 50%;
								width: 18px; height: 18px;
								font-size: 0.65rem; font-weight: 800;
								display: flex; align-items: center; justify-content: center;
								border: 2px solid #f6f5ed;
							">{{ cartCount }}</span>
						{% endif %}
					</a>
				{% endif %}
				<div class="app-header-greeting">
					<div class="app-header-welcome">Bienvenue, {{ app.user ? app.user.firstName|capitalize : 'User' }}</div>
					<div class="app-header-glad">Glad to see you again 👋</div>
				</div>
				{% if app.user %}
					<div class="app-header-avatar">{{ app.user.firstName|first|upper }}</div>
				{% else %}
					<div class="app-header-avatar">?</div>
				{% endif %}
			</div>
		</header>

		<div class="app-main__inner">
			{% for label, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ label }}">
						{% if label == 'success' %}
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
								<polyline points="22 4 12 14.01 9 11.01"></polyline>
							</svg>
						{% else %}
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"></circle>
								<line x1="12" y1="8" x2="12" y2="12"></line>
								<line x1="12" y1="16" x2="12.01" y2="16"></line>
							</svg>
						{% endif %}
						{{ message }}
					</div>
				{% endfor %}
			{% endfor %}

			{% block app_content %}{% endblock %}
		</div>

		{# Footer Logo #}
		<footer style="margin-top: 3rem; padding: 2rem 2rem 1.5rem; border-top: 1px solid rgba(98,114,85,0.12); display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.5rem;">
			<div style="display: flex; align-items: center; gap: 0.6rem;">
				<div style="width: 36px; height: 36px; background: linear-gradient(135deg, #748764, #b2936a); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(98,114,85,0.25);">
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
					</svg>
				</div>
				<span style="font-size: 1.2rem; font-weight: 800; background: linear-gradient(90deg, #3d4a32, #748764); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: -0.02em;">Slimenify</span>
			</div>
			<p style="font-size: 0.75rem; color: #94a3b8; margin: 0; letter-spacing: 0.02em;">
				Well-being &amp; Recovery Platform &copy; {{ "now"|date("Y") }}
			</p>
		</footer>

	</main>
</div>
{% endblock %}
