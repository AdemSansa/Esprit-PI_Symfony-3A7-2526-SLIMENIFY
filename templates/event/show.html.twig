{% extends 'layout/app_shell.html.twig' %}

{% block title %}{{ event.title }} | Psychology Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #748764;
            --primary-dark: #2d1e16;
            --accent: #f43f5e;
            --card-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            --glass: rgba(255, 255, 255, 0.85);
        }

        .details-page {
            font-family: 'Inter', sans-serif;
            color: #1e293b;
            padding-bottom: 8rem;
            background: #f8fafc;
            overflow-x: hidden;
        }

        /* ✨ PARALLAX HERO */
        .hero-viewport {
            height: 550px;
            position: relative;
            overflow: hidden;
            border-radius: 0 0 60px 60px;
            margin-bottom: -120px;
        }
        .hero-parallax {
            position: absolute; top: 0; left: 0; width: 100%; height: 120%;
            background-size: cover; background-position: center;
            transform: translateY(0); transition: transform 0.1s ease-out;
            filter: brightness(0.6);
        }
        .hero-content-wrap {
            position: absolute; inset: 0;
            display: flex; flex-direction: column; justify-content: flex-end;
            padding: 6rem 4rem;
            background: linear-gradient(to top, rgba(15, 23, 42, 0.9) 0%, transparent 60%);
        }
        
        .animate-component { opacity: 0; transform: translateY(30px); transition: all 1s cubic-bezier(0.2, 0.8, 0.2, 1); }
        .animate-component.visible { opacity: 1; transform: translateY(0); }

        .hero-title {
            font-family: 'Outfit', sans-serif; font-size: 4rem; font-weight: 800; color: white;
            line-height: 1.1; letter-spacing: -0.04em; margin-bottom: 2rem;
        }

        /* ⏳ COUNTDOWN TIMER */
        .countdown-container {
            display: flex; gap: 1.5rem; margin-top: 1rem;
        }
        .time-block {
            background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 1rem; border-radius: 20px; min-width: 80px; text-align: center;
        }
        .time-val { display: block; font-size: 1.75rem; font-weight: 800; color: white; font-family: 'Outfit'; }
        .time-label { font-size: 0.65rem; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.1em; }

        /* 📦 CONTENT GRID */
        .main-layout {
            max-width: 1300px; margin: 0 auto; padding: 0 2rem;
            display: grid; grid-template-columns: 1fr 420px; gap: 4rem;
            position: relative; z-index: 10;
        }

        .details-card {
            background: var(--glass); backdrop-filter: blur(20px);
            border-radius: 32px; padding: 4rem;
            box-shadow: var(--card-shadow); border: 1px solid white;
        }

        .section-title {
            font-family: 'Outfit', sans-serif; font-size: 2.25rem; font-weight: 800;
            margin-bottom: 2rem; display: flex; align-items: center; gap: 1rem;
        }

        /* 🔗 SOCIAL SHARE */
        .share-bar {
            display: flex; gap: 1rem; margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e2e8f0;
        }
        .share-btn {
            width: 45px; height: 45px; border-radius: 12px; display: flex; align-items: center; justify-content: center;
            background: white; border: 1px solid #e2e8f0; color: #475569; transition: all 0.3s; cursor: pointer;
        }
        .share-btn:hover { background: var(--primary); color: white; border-color: var(--primary); transform: translateY(-3px); }

        /* 📋 SIDEBAR */
        .premium-sidebar {
            background: white; border-radius: 32px; padding: 2.5rem;
            box-shadow: var(--card-shadow); position: sticky; top: 2rem;
            border: 1px solid #e2e8f0;
        }

        .status-tag {
            display: inline-block; padding: 0.6rem 1.2rem; border-radius: 14px;
            font-weight: 800; font-size: 0.8rem; text-transform: uppercase;
            margin-bottom: 2.5rem; background: #dcfce7; color: #16a34a;
        }

        .meta-list { list-style: none; padding: 0; margin: 0; }
        .meta-row {
            display: flex; align-items: flex-start; gap: 1.25rem; margin-bottom: 2rem;
        }
        .meta-icon-box {
            width: 54px; height: 54px; border-radius: 18px; background: #f1f5f9;
            display: flex; align-items: center; justify-content: center; font-size: 1.25rem;
        }
        .meta-info h4 { font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; margin: 0 0 0.25rem; letter-spacing: 0.05em; }
        .meta-info p { font-size: 1.05rem; font-weight: 700; color: #1e293b; margin: 0; }

        /* 📊 CAPACITY */
        .sidebar-capacity { margin-top: 3rem; background: #f8fafc; padding: 1.5rem; border-radius: 20px; }
        .capacity-bar-wrap { height: 12px; background: #e2e8f0; border-radius: 99px; overflow: hidden; margin-bottom: 1rem; }
        .capacity-bar-fill { height: 100%; background: linear-gradient(90deg, #748764, #c026d3); }

        /* 🌊 RELATED EVENTS SECTION */
        .related-section { max-width: 1300px; margin: 6rem auto 0; padding: 0 2rem; }
        .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem; margin-top: 2rem; }
        .mini-card {
            background: white; border-radius: 24px; padding: 1.5rem; border: 1px solid #e2e8f0;
            transition: all 0.4s; text-decoration: none; color: inherit;
        }
        .mini-card:hover { transform: translateY(-10px); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); border-color: var(--primary); }
        .mini-image { height: 150px; border-radius: 16px; overflow: hidden; margin-bottom: 1rem; }
        .mini-image img { width: 100%; height: 100%; object-fit: cover; }
        .mini-title { font-size: 1.1rem; font-weight: 800; margin-bottom: 0.5rem; }

        /* BUTTONS */
        .btn-premium-wide {
            display: block; width: 100%; padding: 1.25rem; border-radius: 20px;
            font-weight: 800; font-size: 1.1rem; text-align: center; text-decoration: none;
            transition: all 0.4s; margin-top: 2.5rem; border: none; font-family: inherit;
        }
        .btn-gradient { background: linear-gradient(135deg, #748764 0%, #2d1e16 100%); color: white; box-shadow: 0 10px 25px rgba(116, 135, 100, 0.4); }
        .btn-gradient:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 15px 35px rgba(99, 102, 241, 0.5); }
    </style>
{% endblock %}

{% block app_content %}
{% set booked = event.registrations|length %}
{% set capacity = event.maxParticipants ?: 100 %}
{% set percent = (booked / capacity * 100)|round %}

<div class="details-page">

    {# 🚀 ULTRA-PREMIUM PARALLAX HERO #}
    <div class="hero-viewport">
        <div class="hero-parallax" id="hero-img" style="background-image: url('{{ asset(event.imageUrl ?: 'placeholder.jpg') }}');"></div>
        <div class="hero-content-wrap">
            <div class="animate-component" id="hero-meta">
                <h1 class="hero-title">{{ event.title }}</h1>
                
                {# Countdown Section #}
                <div class="countdown-container" id="countdown" data-date="{{ event.dateStart|date('Y-m-d H:i:s') }}">
                    <div class="time-block">
                        <span class="time-val" id="days">00</span>
                        <span class="time-label">Days</span>
                    </div>
                    <div class="time-block">
                        <span class="time-val" id="hours">00</span>
                        <span class="time-label">Hours</span>
                    </div>
                    <div class="time-block">
                        <span class="time-val" id="minutes">00</span>
                        <span class="time-label">Min</span>
                    </div>
                    <div class="time-block">
                        <span class="time-val" id="seconds">00</span>
                        <span class="time-label">Sec</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# 📦 MAIN LAYOUT #}
    <div class="main-layout">
        
        {# Content Column #}
        <div class="details-card animate-component" id="main-content">
            <a href="{{ path('app_event_index') }}" style="color: var(--primary); font-weight: 800; text-decoration: none; font-size: 0.9rem; margin-bottom: 2rem; display: inline-flex; align-items: center; gap: 0.5rem;">
                <span style="font-size: 1.2rem;">←</span> BROWSE MORE EVENTS
            </a>

            <div class="section-title">
                <span>📝</span> Event Information
            </div>
            
            <div style="font-size: 1.2rem; line-height: 1.8; color: #475569; margin-bottom: 4rem;">
                {{ event.description|nl2br }}
            </div>

            <div class="section-title"  style="margin-top: 5rem;">
                <span>🗺️</span> Interactive Map
            </div>
            <div style="background: white; padding: 1.5rem; border-radius: 32px; border: 1px solid #e2e8f0; height: 500px; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);">
                <iframe width="100%" height="100%" style="border-radius: 20px; border: none;" loading="lazy"
                    src="https://maps.google.com/maps?q={{ (event.latitude and event.longitude) ? event.latitude ~ ',' ~ event.longitude : event.location|url_encode }}&t=&z=16&ie=UTF8&iwloc=&output=embed">
                </iframe>
            </div>

            {# Social Sharing Bar #}
            <div class="share-bar">
                <span style="font-weight: 800; font-size: 0.85rem; color: #94a3b8; display: flex; align-items: center; margin-right: 1rem;">SHARE EVENT</span>
                <button class="share-btn" onclick="copyLink()" title="Copy Link">🔗</button>
                <a href="#" class="share-btn">🐦</a>
                <a href="#" class="share-btn">📘</a>
                <a href="#" class="share-btn">💼</a>
            </div>
        </div>

        {# Sidebar Column #}
        <aside>
            <div class="premium-sidebar animate-component" id="sidebar">
                <div class="status-tag">● Upcoming Event</div>

                <div class="meta-list">
                    <div class="meta-row">
                        <div class="meta-icon-box">📅</div>
                        <div class="meta-info">
                            <h4>Date & Time</h4>
                            <p>{{ event.dateStart|date('D, M d, Y') }} at {{ event.dateStart|date('H:i') }}</p>
                        </div>
                    </div>

                    <div class="meta-row">
                        <div class="meta-icon-box">📍</div>
                        <div class="meta-info">
                            <h4>Location</h4>
                            <p>{{ event.location ?: 'Virtual Session' }}</p>
                        </div>
                    </div>

                    <div class="meta-row">
                        <div class="meta-icon-box">🏷️</div>
                        <div class="meta-info">
                            <h4>Experience Format</h4>
                            <p>{{ event.type|replace({'physique': 'In-Person', 'hybride': 'Hybrid'})|upper }}</p>
                        </div>
                    </div>

                    <div class="meta-row">
                        <div class="meta-icon-box">🏆</div>
                        <div class="meta-info">
                            <h4>Organizer</h4>
                            <p>Premium Psychology Specialist</p>
                        </div>
                    </div>
                </div>

                <div class="sidebar-capacity">
                    <div class="capacity-bar-wrap">
                        <div class="capacity-bar-fill" style="width: {{ percent > 100 ? 100 : percent }}%"></div>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
                        <span style="font-weight: 800; color: #1e293b;">{{ booked }} Booked</span>
                        <span style="color: #64748b;">{{ capacity }} Max</span>
                    </div>
                </div>

                {# 🎫 Actions #}
                {% if userRegistration %}
                    <a href="{{ path('app_event_registration_ticket', {id: userRegistration.id}) }}" class="btn-premium-wide btn-gradient">
                        VIBRANT ENTRY TICKET 🎫
                    </a>
                {% else %}
                    {# Allow ROLE_USER, ROLE_PATIENT, and anyone NOT a therapist to register #}
                    {% if is_granted('ROLE_PATIENT') or is_granted('ROLE_USER') or (not is_granted('ROLE_THERAPIST') and not is_granted('IS_AUTHENTICATED_FULLY')) %}
                        {% if percent < 100 %}
                            <a href="{{ path('app_event_register', {id: event.id}) }}" class="btn-premium-wide btn-gradient">RESERVE MY SEAT</a>
                        {% else %}
                            <div class="btn-premium-wide" style="background: #f1f5f9; color: #94a3b8; cursor: not-allowed;">SESSION FULL</div>
                        {% endif %}
                    {% endif %}
                {% endif %}

                {% if is_granted('ROLE_ADMIN') or (is_granted('ROLE_THERAPIST') and event.organizerId == app.user.id) %}
                    <a href="{{ path('app_event_edit', {id: event.id}) }}" class="btn-premium-wide" style="background: white; border: 2px solid #e2e8f0;">MANAGEMENT SETTINGS</a>
                {% endif %}
            </div>
        </aside>
    </div>

    {# 🌊 RELATED EVENTS #}
    {% if relatedEvents|length > 0 %}
        <section class="related-section animate-component">
            <div class="section-title">
                <span>🔥</span> More Events For You
            </div>
            <div class="related-grid">
                {% for re in relatedEvents %}
                    <a href="{{ path('app_event_show', {id: re.id}) }}" class="mini-card">
                        <div class="mini-image">
                            {% if re.imageUrl %}
                                <img src="{{ asset(re.imageUrl) }}" alt="{{ re.title }}">
                            {% else %}
                                <div style="height:100%; background: #f1f5f9; display:flex; align-items:center; justify-content:center; font-size:2rem;">📅</div>
                            {% endif %}
                        </div>
                        <h4 class="mini-title">{{ re.title }}</h4>
                        <div style="font-size:0.8rem; color: #64748b;">📅 {{ re.dateStart|date('M d, Y') }}</div>
                    </a>
                {% endfor %}
            </div>
        </section>
    {% endif %}

</div>

<script>
    // ⏳ COUNTDOWN LOGIC
    const countdownEl = document.getElementById('countdown');
    const targetDate = new Date(countdownEl.dataset.date).getTime();

    function updateCountdown() {
        const now = new Date().getTime();
        const gap = targetDate - now;

        if (gap < 0) {
            countdownEl.innerHTML = "<div class='time-block' style='min-width: 200px'><span class='time-val'>Live Now</span></div>";
            return;
        }

        const second = 1000;
        const minute = second * 60;
        const hour = minute * 60;
        const day = hour * 24;

        const d = Math.floor(gap / day);
        const h = Math.floor((gap % day) / hour);
        const m = Math.floor((gap % hour) / minute);
        const s = Math.floor((gap % minute) / second);

        document.getElementById('days').innerText = d < 10 ? '0' + d : d;
        document.getElementById('hours').innerText = h < 10 ? '0' + h : h;
        document.getElementById('minutes').innerText = m < 10 ? '0' + m : m;
        document.getElementById('seconds').innerText = s < 10 ? '0' + s : s;
    }
    setInterval(updateCountdown, 1000);
    updateCountdown();

    // 🖼️ PARALLAX LOGIC
    window.addEventListener('scroll', () => {
        const scrolled = window.pageYOffset;
        const heroImg = document.getElementById('hero-img');
        if (heroImg) {
            heroImg.style.transform = `translateY(${scrolled * 0.3}px)`;
        }
    });

    // ✨ ENTRANCE ANIMATIONS
    const observerOptions = { threshold: 0.1 };
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, observerOptions);

    document.querySelectorAll('.animate-component').forEach(el => observer.observe(el));

    // 🔗 COPY LINK
    function copyLink() {
        navigator.clipboard.writeText(window.location.href);
        alert("Event link copied to clipboard!");
    }
</script>
{% endblock %}

