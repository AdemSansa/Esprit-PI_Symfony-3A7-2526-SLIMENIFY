<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    #map { height: 400px; width: 100%; border-radius: 12px; border: 1px solid #e2e8f0; margin-top: 0.75rem; box-shadow: inset 0 2px 4px 0 rgba(0, 0, 0, 0.05); }
    .btn-ai { background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); color: white; border: none; padding: 0.6rem 1.25rem; border-radius: 10px; cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
    .btn-ai:hover { transform: translateY(-1px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05); filter: brightness(1.05); }
    .btn-ai:active { transform: translateY(0); }
    .ai-generate-wrapper { margin-top: 1rem; display: flex; align-items: center; gap: 1rem; }
    .ai-loader { display: none; font-size: 0.9rem; color: #6366f1; font-weight: 500; align-items: center; gap: 0.5rem; animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .5; } }
    
    /* Validation Errors */
    .form-group ul { list-style: none; padding: 0; margin: 0.25rem 0 0; color: #ef4444; font-size: 0.85rem; font-weight: 500; }
    .form-control.is-invalid { border-color: #ef4444; background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12' width='12' height='12' fill='none' stroke='%23ef4444'%3e%3ccircle cx='6' cy='6' r='4.5'/%3e%3cpath stroke-linejoin='round' d='M5.8 3.6h.4L6 6.5z'/%3e%3ccircle cx='6' cy='8.2' r='.6' fill='%23ef4444' stroke='none'/%3e%3c/svg%3e"); background-repeat: no-repeat; background-position: right calc(0.375em + 0.1875rem) center; background-size: calc(0.75em + 0.375rem) calc(0.75em + 0.375rem); }
</style>

{{ form_start(form, {'attr': {'id': 'event-form'}}) }}
    <div class="form-group">
        {{ form_label(form.title, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="form-group">
        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.description) }}
        
        <div class="ai-generate-wrapper">
            <button type="button" class="btn btn-ai" id="generate-ai-btn">✨ Generate AI Description</button>
            <span class="ai-loader" id="ai-loader">Generating wow-effect description...</span>
        </div>
    </div>

    <div class="row">
        <div class="col form-group">
            {{ form_label(form.type, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.type, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.type) }}
        </div>
        <div class="col form-group">
            {{ form_label(form.status, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.status) }}
        </div>
    </div>

    <div class="row">
        <div class="col form-group">
            {{ form_label(form.dateStart, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.dateStart, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateStart) }}
        </div>
        <div class="col form-group">
            {{ form_label(form.dateEnd, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.dateEnd, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.dateEnd) }}
        </div>
    </div>

    <div class="row" style="align-items: flex-start;">
        <div class="col form-group" style="flex: 2;">
            {{ form_label(form.location, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.location, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.location) }}
            <p class="location-hint">Click on the map to set the exact address automatically.</p>
            <div id="map"></div>
        </div>
        <div class="col form-group" style="flex: 1;">
            {{ form_label(form.maxParticipants, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.maxParticipants, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.maxParticipants) }}
            
            <div style="margin-top: 1.5rem;">
                {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.imageFile) }}
                
                {% if event.imageUrl %}
                    <div style="margin-top: 1rem;">
                        <img src="{{ asset(event.imageUrl) }}" style="width: 100%; border-radius: 8px;" alt="Current Image">
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="actions">
        <button class="btn btn-primary">{{ button_label|default('Save Event') }}</button>
    </div>
{{ form_end(form) }}

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- AI Description Logic ---
        const generateBtn = document.getElementById('generate-ai-btn');
        const aiLoader = document.getElementById('ai-loader');
        const titleInput = document.getElementById('{{ form.title.vars.id }}');
        const descInput = document.getElementById('{{ form.description.vars.id }}');
        
        if(generateBtn) {
            generateBtn.addEventListener('click', async () => {
                const title = titleInput.value.trim();
                if(!title) {
                    alert('Please enter a title first to generate an AI description.');
                    return;
                }
                
                generateBtn.disabled = true;
                generateBtn.style.opacity = '0.7';
                aiLoader.style.display = 'flex';
                
                console.log('Generating for title:', title);
                try {
                    const response = await fetch('{{ path('app_event_generate_ai') }}', {
                        method: 'POST',
                        headers:{ 'Content-Type': 'application/json' },
                        body: JSON.stringify({title: title})
                    });
                    
                    console.log('Response status:', response.status);
                    if (!response.ok) {
                        const errorData = await response.json().catch(() => ({}));
                        throw new Error(errorData.error || `Server returned ${response.status}`);
                    }
                    
                    const data = await response.json();
                    console.log('Data received:', data);
                    if(data.description) {
                        descInput.value = data.description;
                        descInput.dispatchEvent(new Event('change'));
                    } else if(data.error) {
                        alert('AI Error: ' + data.error);
                    }
                } catch(e) {
                    console.error('Fetch error:', e);
                    alert('Error: ' + e.message);
                } finally {
                    generateBtn.disabled = false;
                    generateBtn.style.opacity = '1';
                    aiLoader.style.display = 'none';
                }
            });
        }
        
        // --- Map Logic ---
        const mapEl = document.getElementById('map');
        const locInput = document.getElementById('{{ form.location.vars.id }}');
        if(mapEl && locInput) {
            let map;
            try {
                map = L.map('map').setView([36.8, 10.2], 6);
                L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 19,
                }).addTo(map);
                
                // CRITICAL: Ensure Leaflet detects container size correctly after page load
                setTimeout(() => { if(map) map.invalidateSize(); }, 200);
            } catch (e) {
                console.error("Leaflet Error:", e);
                mapEl.innerHTML = "<p style='padding: 20px; color: #ef4444;'>Leaflet map failed to load.</p>";
            }
            
            let marker = null;
            
            // Function to update marker and view
            function setLocation(lat, lon, addr) {
                if(marker) map.removeLayer(marker);
                marker = L.marker([lat, lon]).addTo(map);
                marker.bindPopup(`<b>${addr}</b>`).openPopup();
                locInput.value = addr;
            }
            
            // If already has location
            if(locInput.value.length > 3) {
                fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(locInput.value), {
                    headers: { 'User-Agent': 'PsychologySymfonyApp/1.0' }
                })
                .then(r => r.json())
                .then(data => {
                    if(data && data.length > 0) {
                        map.setView([data[0].lat, data[0].lon], 13);
                        setLocation(data[0].lat, data[0].lon, locInput.value);
                    }
                });
            }
            
            // Map click
            map.on('click', function(e) {
                const lat = e.latlng.lat;
                const lon = e.latlng.lng;
                
                if(marker) map.removeLayer(marker);
                marker = L.marker([lat, lon]).addTo(map);
                marker.bindPopup('Fetching address...').openPopup();
                
                fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`, {
                    headers: { 'User-Agent': 'PsychologySymfonyApp/1.0' }
                })
                .then(r => r.json())
                .then(data => {
                    const addr = data.display_name || (lat.toFixed(5) + ', ' + lon.toFixed(5));
                    setLocation(lat, lon, addr);
                }).catch(() => {
                    setLocation(lat, lon, lat.toFixed(5) + ', ' + lon.toFixed(5));
                });
            });
        }
    });
</script>
