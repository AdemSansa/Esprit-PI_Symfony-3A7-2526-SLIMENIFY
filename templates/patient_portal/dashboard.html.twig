{% extends 'layout/app_shell.html.twig' %}

{% block title %}Patient Portal - Find a Therapist
{% endblock %}

{% block app_content %}
	<style>
		.directory-header {
			background: rgba(255, 255, 255, 0.82);
			backdrop-filter: blur(12px);
			border-radius: 16px;
			padding: 20px 30px;
			box-shadow: 0 8px 32px rgba(122, 91, 73, 0.06);
			border: 1px solid rgba(255, 255, 255, 0.4);
			margin-bottom: 25px;
			display: flex;
			justify-content: space-between;
			align-items: center;
			flex-wrap: wrap;
			gap: 15px;
		}
		.directory-title-section h1 {
			color: #5D4A3E;
			font-size: 1.6rem;
			font-weight: 800;
			margin: 0 0 5px;
		}
		.directory-title-section p {
			color: #A8866E;
			font-size: 0.9rem;
			margin: 0;
		}
		.filter-wrapper {
			display: flex;
			align-items: center;
			gap: 10px;
		}
		.filter-wrapper label {
			font-weight: 700;
			color: #7A5B49;
			font-size: 0.9rem;
		}
		.form-control {
			padding: 10px 14px;
			border: 1px solid #EBE6DF;
			border-radius: 8px;
			background-color: #FDFDFD;
			font-size: 0.95rem;
			color: #2D2D2D;
			min-width: 200px;
		}

		.therapist-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
			gap: 20px;
		}

		.therapist-card {
			background: rgba(255, 255, 255, 0.85);
			backdrop-filter: blur(10px);
			border-radius: 16px;
			padding: 25px;
			box-shadow: 0 8px 32px rgba(122, 91, 73, 0.08);
			border: 1px solid rgba(255, 255, 255, 0.4);
			display: flex;
			flex-direction: column;
			transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s;
		}

		.therapist-card:hover {
			transform: translateY(-3px);
			box-shadow: 0 8px 25px rgba(122, 91, 73, 0.1);
		}

		.card-header-top {
			display: flex;
			gap: 15px;
		}
		.card-avatar {
			width: 60px;
			height: 60px;
			border-radius: 50%;
			object-fit: cover;
			border: 2px solid #F0EEEA;
		}
		.card-title {
			flex: 1;
			display: flex;
			flex-direction: column;
			justify-content: center;
		}
		.card-name {
			font-size: 1.15rem;
			font-weight: 800;
			color: #2D2D2D;
			margin: 0 0 5px;
		}

		.status-badge {
			display: inline-block;
			padding: 4px 10px;
			border-radius: 12px;
			font-size: 0.7rem;
			font-weight: 700;
			text-transform: uppercase;
			background: #EAF0E4;
			color: #4F5D44;
			align-self: flex-start;
		}

		.card-body-content {
			margin-top: 20px;
			display: flex;
			flex-direction: column;
			gap: 10px;
			flex-grow: 1;
		}
		.info-row {
			display: flex;
			align-items: flex-start;
			gap: 8px;
		}
		.info-icon {
			color: #A8866E;
			margin-top: 2px;
			flex-shrink: 0;
		}
		.info-text {
			font-size: 0.85rem;
			color: #555;
			line-height: 1.4;
		}
		.info-text strong {
			color: #5D4A3E;
		}

		.schedule-header {
			font-size: 0.85rem;
			font-weight: 700;
			color: #7A5B49;
			margin-top: 15px;
			margin-bottom: 8px;
			display: flex;
			align-items: center;
			gap: 5px;
			border-top: 1px solid #EBE6DF;
			padding-top: 15px;
		}
		.availability-list {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
		}
		.av-pill {
			background: #F9F8F5;
			border: 1px solid #EBE6DF;
			border-radius: 6px;
			padding: 4px 8px;
			font-size: 0.75rem;
			color: #687560;
			font-weight: 600;
		}
	</style>

	<div class="directory-header">
		<div class="directory-title-section">
			<h1>Find a Therapist</h1>
			<p>Browse our directory and find the perfect professional for your needs.</p>
		</div>

		<form id="searchForm" class="filter-wrapper" method="GET" action="{{ path('app_patient_dashboard') }}">
			<label for="searchName">Search:</label>
			<input type="text" name="q" id="searchName" class="form-control" placeholder="By name..." value="{{ searchQuery }}" autocomplete="off">

			<label for="filterSpecialty" style="margin-left: 10px;">Specialty:</label>
			<select name="specialty" id="filterSpecialty" class="form-control">
				<option value="all" {% if specialty == 'all' %} selected {% endif %}>All Specialties</option>
				<option value="Psychologie" {% if specialty == 'Psychologie' %} selected {% endif %}>Psychologie</option>
				<option value="Sexologie" {% if specialty == 'Sexologie' %} selected {% endif %}>Sexologie</option>
				<option value="Thérapie de couple" {% if specialty == 'Thérapie de couple' %} selected {% endif %}>Thérapie de couple</option>
				<option value="Psychiatrie" {% if specialty == 'Psychiatrie' %} selected {% endif %}>Psychiatrie</option>
			</select>

			<button type="submit" style="display:none;">Apply</button>
		</form>
	</div>

	{# Sticky AI Therapist Floating Tab #}
	<style>
		.ai-sticky-tab {
			position: fixed;
			right: 0;
			top: 50%;
			transform: translateY(-50%);
			z-index: 9998;
			background: linear-gradient(135deg, #627255 0%, #8C9C7C 100%);
			color: white;
			padding: 20px 12px;
			border-top-left-radius: 20px;
			border-bottom-left-radius: 20px;
			box-shadow: -10px 0 30px rgba(98, 114, 85, 0.25);
			text-decoration: none;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 10px;
			transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
			border: 1px solid rgba(255, 255, 255, 0.2);
			border-right: none;
			animation: tabPulse 3s infinite;
		}
		@keyframes tabPulse {
			0% { box-shadow: -5px 0 15px rgba(98, 114, 85, 0.2); }
			50% { box-shadow: -12px 0 30px rgba(98, 114, 85, 0.5); }
			100% { box-shadow: -5px 0 15px rgba(98, 114, 85, 0.2); }
		}
		.ai-sticky-tab:hover {
			padding-right: 25px;
			background: linear-gradient(135deg, #748764 0%, #a2b292 100%);
			transform: translateY(-50%) translateX(-5px);
		}
		.ai-sticky-tab span {
			writing-mode: vertical-rl;
			text-orientation: mixed;
			font-weight: 800;
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
		}
		.ai-sticky-tab .tab-icon {
			width: 24px;
			height: 24px;
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba(255,255,255,0.2);
			border-radius: 8px;
		}
	</style>

	<a href="{{ path('therapy_chat_page') }}" class="ai-sticky-tab" title="Talk to Sama AI">
		<div class="tab-icon">
			<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
				<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
			</svg>
		</div>
		<span>AI Therapist</span>
	</a>

	<div id="therapistContainer">
		<div class="therapist-grid" id="therapistGrid">
			{% for colleague in therapists %}
				<div class="therapist-card" data-specialty="{{ colleague.specialization|lower }}">
					<div class="card-header-top">
						{% if colleague.photoUrl and colleague.photoUrl != 'default.png' %}
							<img src="{{ colleague.photoUrl }}" alt="Dr. {{ colleague.lastName }}" class="card-avatar">
						{% else %}
							<img src="https://ui-avatars.com/api/?name={{ colleague.firstName }}+{{ colleague.lastName }}&background=EAF0E4&color=4F5D44" alt="Avatar" class="card-avatar">
						{% endif %}

						<div class="card-title">
							<h3 class="card-name">{{ colleague.firstName }}
								{{ colleague.lastName }}</h3>
							<div class="status-badge">{{ colleague.specialization ?: 'General Provider' }}</div>
						</div>
					</div>

					<div class="card-body-content">
						<div class="info-row">
							<svg class="info-icon" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
								<polyline points="22,6 12,13 2,6"></polyline>
							</svg>
							<span class="info-text">
								<strong>Email:</strong>
								<a href="mailto:{{ colleague.email }}" style="color: #687560; text-decoration: none;">{{ colleague.email }}</a>
							</span>
						</div>

						<div class="info-row">
							<svg class="info-icon" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
							</svg>
							<span class="info-text">
								<strong>Contact:</strong>
								{{ colleague.phoneNumber ?: 'No number provided' }}</span>
						</div>

						<div class="info-row">
							<svg class="info-icon" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
							</svg>
							<span class="info-text">
								<strong>Consultation:</strong>
								{% if colleague.consultationType == 'ONLINE' %}
									Video
								{% elseif colleague.consultationType == 'IN_PERSON' %}
									In-person
								{% else %}
									Video & In-person
								{% endif %}
							</span>
						</div>

						<div class="info-row" style="align-items: flex-start;">
							<svg class="info-icon" width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
								<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
							</svg>
							<span class="info-text">
								<strong>Bio:</strong>
								{{ colleague.description ?: 'No bio provided for this professional.' }}
							</span>
						</div>
					</div>

					<div style="margin-top:auto; padding-top:20px; display: flex; gap: 10px;">
						<a href="{{ path('app_appointments_calendar', {therapist_id: colleague.id}) }}" style="flex: 1; text-align:center; text-decoration:none; background:#627255; color:#fff; border-radius:12px; padding:12px; font-weight:700; transition:background 0.2s;" onmouseover="this.style.background='#4F5D44'" onmouseout="this.style.background='#627255'">
							Book Appointment
						</a>
						<a href="{{ path('app_chat_start', {therapistId: colleague.id}) }}" style="flex: 1; text-align:center; text-decoration:none; background:#F9F8F5; color:#5D4A3E; border: 1px solid #EBE6DF; border-radius:12px; padding:12px; font-weight:700; transition:background 0.2s;" onmouseover="this.style.background='#F0EEEA'" onmouseout="this.style.background='#F9F8F5'">
							Message
						</a>
					</div>
				</div>
			{% else %}
				<div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #7A5B49; background: #fff; border-radius: 12px; border: 1px solid #EBE6DF;">
					<h3>Welcome to Slimenify</h3>
					<p>No therapists are currently registered on the platform. Please check back later!</p>
				</div>
			{% endfor %}
		</div>

		<div style="margin-top: 30px; display: flex; justify-content: center;">
			{{ knp_pagination_render(therapists) }}
		</div>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
const form = document.getElementById('searchForm');
const container = document.getElementById('therapistContainer');
let timeout = null;

if (form && container) {
form.addEventListener('input', () => {
clearTimeout(timeout);
timeout = setTimeout(() => {
const url = new URL(form.action || window.location.href);
const formData = new FormData(form);
const searchParams = new URLSearchParams(formData);
// Remove page param when searching to start from 1
searchParams.delete('page');
url.search = searchParams.toString();

fetch(url, {
headers: {
'X-Requested-With': 'XMLHttpRequest'
}
}).then(response => response.text()).then(html => {
const parser = new DOMParser();
const doc = parser.parseFromString(html, 'text/html');
const newContainer = doc.getElementById('therapistContainer');

if (newContainer) {
container.innerHTML = newContainer.innerHTML;
}
window.history.pushState({}, '', url);
});
}, 300);
});
}
});
	</script>
{% endblock %}
