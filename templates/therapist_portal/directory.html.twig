{% extends 'layout/app_shell.html.twig' %}

{% block title %}Colleagues Directory{% endblock %}

{% block app_content %}
<style>
    /* ... Copying the minimal card styling from admin view to keep visual consistency but stripping edit/delete actions ... */
    .directory-header {
        background: #ffffff;
        border-radius: 12px;
        padding: 20px 30px;
        box-shadow: 0 4px 15px rgba(122, 91, 73, 0.05);
        border: 1px solid rgba(122, 91, 73, 0.1);
        margin-bottom: 25px;
    }
    .directory-title-section h1 {
        color: #5D4A3E;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 5px 0;
    }
    .directory-title-section p {
        color: #A8866E;
        font-size: 0.9rem;
        margin: 0;
    }

    .therapist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    .therapist-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(122, 91, 73, 0.06);
        border: 1px solid rgba(122, 91, 73, 0.05);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .therapist-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(122, 91, 73, 0.1);
    }

    .card-header-top {
        display: flex;
        gap: 15px;
    }

    .card-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #F0EEEA;
    }

    .card-title {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .card-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: #2D2D2D;
        margin: 0 0 5px 0;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        background: #EAF0E4;
        color: #4F5D44;
        align-self: flex-start;
    }

    .card-body-content {
        margin-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex-grow: 1;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }

    .info-icon {
        color: #A8866E;
        margin-top: 2px;
        flex-shrink: 0;
    }

    .info-text {
        font-size: 0.85rem;
        color: #555;
        line-height: 1.4;
    }

    .info-text strong {
        color: #5D4A3E;
    }
</style>

<div class="directory-header">
    <div class="directory-title-section">
        <h1>Therapists</h1>
        <p>Connect and interact with {{ therapists|length }} peers across the platform.</p>
    </div>
</div>

<div class="therapist-grid">
    {% for colleague in therapists %}
        <div class="therapist-card">
            <div class="card-header-top">
                {% if colleague.photoUrl and colleague.photoUrl != 'default.png' %}
                    <img src="{{ colleague.photoUrl }}" alt="Dr. {{ colleague.lastName }}" class="card-avatar">
                {% else %}
                    <img src="https://ui-avatars.com/api/?name={{ colleague.firstName }}+{{ colleague.lastName }}&background=EAF0E4&color=4F5D44" alt="Avatar" class="card-avatar">
                {% endif %}
                
                <div class="card-title">
                    <h3 class="card-name">{{ colleague.firstName }} {{ colleague.lastName }}</h3>
                    <div class="status-badge">{{ colleague.specialization ?: 'General Provider' }}</div>
                </div>
            </div>

            <div class="card-body-content">
                <div class="info-row">
                    <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    <span class="info-text"><strong>Email:</strong> {{ colleague.email }}</span>
                </div>
                
                <div class="info-row">
                    <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                    <span class="info-text"><strong>Contact:</strong> {{ colleague.phoneNumber ?: 'No number provided' }}</span>
                </div>

                <div class="info-row" style="align-items: flex-start;">
                    <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                    <span class="info-text">
                        <strong>Bio:</strong> 
                        {% if colleague.description|length > 100 %}
                            {{ colleague.description|slice(0, 100) }}...
                        {% else %}
                            {{ colleague.description ?: 'No bio provided for this colleague.' }}
                        {% endif %}
                    </span>
                </div>
            </div>
            <!-- Purposefully omitted all Edit and Delete buttons for read-only access -->
        </div>
    {% else %}
        <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #7A5B49; background: #fff; border-radius: 12px;">
            <h3>Network is Empty</h3>
            <p>No other therapists are currently registered on the platform.</p>
        </div>
    {% endfor %}
</div>
{% endblock %}
