{% extends 'layout/app_shell.html.twig' %}

{% block title %}My Dashboard{% endblock %}

{% block app_content %}
<div style="max-width: 800px; margin: 0 auto; text-align: center; padding-top: 50px;">
    
    <div style="background: #ffffff; border-radius: 16px; padding: 40px; box-shadow: 0 10px 30px rgba(122, 91, 73, 0.08); border: 1px solid rgba(122, 91, 73, 0.05);">
        
        <div style="background: #EAF0E4; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px auto; color: #687560;">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
        </div>

        <h1 style="color: #5D4A3E; font-size: 2rem; margin-top: 0; margin-bottom: 10px;">Welcome to your Portal!</h1>
        <p style="color: #A8866E; font-size: 1.1rem; line-height: 1.6; margin-bottom: 30px;">
            {{ therapist ? therapist.lastName : (app.user ? app.user.lastName : 'Therapist') }}, we are glad to have you on Slimenify. <br>
            Use the <strong>Therapists</strong> link in the sidebar to browse the directory of your colleagues.
        </p>

        <a href="{{ path('app_therapist_directory') }}" style="background: #687560; color: white; border: none; border-radius: 30px; padding: 12px 30px; font-size: 1rem; font-weight: 700; text-decoration: none; display: inline-block; transition: all 0.2s;">
            Access Therapists directory
        </a>
    </div>

</div>
{% endblock %}
