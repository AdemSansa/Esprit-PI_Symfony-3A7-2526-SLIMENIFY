<form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" style="display:inline-block; margin:0;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
    <button style="background: white; color: #ef4444; border: 1px solid #fecaca; text-decoration: none; font-size: 0.85rem; padding: 0.4rem 0.75rem; border-radius: 6px; font-weight: 500; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='white'">Delete</button>
</form>
