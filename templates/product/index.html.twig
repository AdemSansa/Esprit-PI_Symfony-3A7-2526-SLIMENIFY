								<td>
									<div class="action-btns">
										{% if is_granted('ROLE_ADMIN') %}
											<a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn-icon">
												<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
													<path d="M12 20h9"></path>
													<path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
												</svg>
											</a>
											<form method="post" action="{{ path('app_product_delete', {'id': product.id}) }}" class="swal-delete-form" data-name="product" style="margin: 0;">
												<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
												<button class="btn-icon delete">
													<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
														<polyline points="3 6 5 6 21 6"></polyline>
														<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
													</svg>
												</button>
											</form>
										{% elseif is_granted('ROLE_PATIENT') %}
											<a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.8rem;">
												Take
											</a>
