						{% for product in products %}
							<tr class="list-row {% if product.stockQuantity <= 0 %}is-out-of-stock{% endif %}" data-name="{{ product.name|lower }}" data-category="{{ product.category }}" data-price="{{ product.price }}" data-date="{{ product.createdAt|date('Y-m-d H:i:s') }}">
								<td>
									<div class="list-prod-info">
