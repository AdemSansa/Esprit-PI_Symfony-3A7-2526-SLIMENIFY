	<div class="navigation" id="pagination-container" style="display: flex; justify-content: center; margin-top: 2rem; margin-bottom: 2rem;">
		{{ knp_pagination_render(products) }}
	</div>

	<script>
        let currentFetchController = null;

		const initInventoryFeatures = () => {
            const btnGrid = document.getElementById('btn-grid-view');
            const btnList = document.getElementById('btn-list-view');
            const viewGrid = document.getElementById('view-grid');
            const viewList = document.getElementById('view-list');

            const filterForm = document.getElementById('filter-form');
            const searchInput = document.getElementById('search-input');
            const categoryFilter = document.getElementById('category-filter');
            const sortSelect = document.getElementById('sort-select');
            const sliderMin = document.getElementById('price-min');
            const sliderMax = document.getElementById('price-max');

            // --- AI SCANNER LOGIC ---
            const btnOpenScanner = document.getElementById('btn-open-scanner');
            const btnCloseScanner = document.getElementById('btn-close-scanner');
            const scannerModal = document.getElementById('scanner-modal');
            const scannerVideo = document.getElementById('scanner-video');
            const btnCapture = document.getElementById('btn-capture');
            const aiLoader = document.getElementById('ai-loader');
            
            let stream = null;

            async function startAIScanner() {
                scannerModal.style.display = 'flex';
                try {
                    stream = await navigator.mediaDevices.getUserMedia({ 
                        video: { facingMode: "environment" } 
                    });
                    scannerVideo.srcObject = stream;
                    scannerVideo.play();
                } catch (err) {
                    console.error("Camera access error:", err);
                    Swal.fire('Error', 'Unable to access camera. Please check permissions.', 'error');
                    scannerModal.style.display = 'none';
                }
            }

            async function stopAIScanner() {
                if (stream) {
                    stream.getTracks().forEach(track => track.stop());
                    stream = null;
                }
                scannerModal.style.display = 'none';
                aiLoader.style.display = 'none';
                btnCapture.disabled = false;
            }

            async function captureAndRecognize() {
                const canvas = document.createElement('canvas');
                canvas.width = scannerVideo.videoWidth;
                canvas.height = scannerVideo.videoHeight;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(scannerVideo, 0, 0);

                const base64Image = canvas.toDataURL('image/jpeg', 0.8);
                
                // Show loader
                aiLoader.style.display = 'flex';
                btnCapture.disabled = true;

                try {
                    const response = await fetch('/api/ai/recognize-product', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ image: base64Image })
                    });

                    const data = await response.json();

                    if (data.found && data.recognizedName) {
                        searchInput.value = data.recognizedName;
                        autoSubmit();
                        stopAIScanner();
                        
                        Swal.fire({
                            icon: 'success',
                            title: 'Product Identified!',
                            text: `Found: ${data.recognizedName}`,
                            timer: 2000,
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false
                        });
                    } else {
                        throw new Error(data.error || 'Identity unknown');
                    }
                } catch (err) {
                    console.error("AI recognition error:", err);
                    aiLoader.style.display = 'none';
                    btnCapture.disabled = false;
                    Swal.fire({
                        icon: 'question',
                        title: 'Not Recognized',
                        text: "Sorry, the AI couldn't identify this specific product. Try again with a clearer view.",
                        confirmButtonColor: '#627255'
                    });
                }
            }

            btnOpenScanner ?. addEventListener('click', startAIScanner);
            btnCloseScanner ?. addEventListener('click', stopAIScanner);
            btnCapture ?. addEventListener('click', captureAndRecognize);
            
            scannerModal ?. addEventListener('click', (e) => {
                if (e.target === scannerModal) stopAIScanner();
            });
            // ---------------------

            function executeAjaxFilter() {
                if (!filterForm) return;

                // Abort previous fetch if it's still running
                if (currentFetchController) {
                    currentFetchController.abort();
                }
                currentFetchController = new AbortController();

                // Show loading state
                if (viewGrid) viewGrid.style.opacity = '0.4';
                if (viewList) viewList.style.opacity = '0.4';

                const actionPath = filterForm.getAttribute('action');
                const formData = new FormData(filterForm);
                const params = new URLSearchParams(formData);
                
                // Always reset to page 1 on new filter/search
                params.set('page', '1'); 
                
                const fullUrl = actionPath + '?' + params.toString();

                window.history.replaceState({}, '', fullUrl);

                fetch(fullUrl, {
                    signal: currentFetchController.signal,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.text();
                })
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, "text/html");

                    // Update Grid
                    const newGrid = doc.getElementById('view-grid');
                    if (newGrid && viewGrid) {
                        viewGrid.innerHTML = newGrid.innerHTML;
                    }

                    // Update List
                    const newList = doc.querySelector('.data-table tbody');
                    const currentListBody = document.querySelector('.data-table tbody');
                    if (newList && currentListBody) {
                        currentListBody.innerHTML = newList.innerHTML;
                    }

                    // Update Other Elements
                    ['product-count', 'pagination-container'].forEach(id => {
                        const newVal = doc.getElementById(id);
                        const currentVal = document.getElementById(id);
                        if (newVal && currentVal) {
                            currentVal.innerHTML = newVal.innerHTML;
                        }
                    });

                    // Restore opacity
                    if (viewGrid) viewGrid.style.opacity = '1';
                    if (viewList) viewList.style.opacity = '1';
                })
                .catch(error => {
                    if (error.name === 'AbortError') return;
                    console.error('AJAX Error:', error);
                    if (viewGrid) viewGrid.style.opacity = '1';
                    if (viewList) viewList.style.opacity = '1';
                });
            }

            let debounceTimer;
            function autoSubmit() {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(executeAjaxFilter, 300);
            }

            // View Toggling
            btnGrid ?. addEventListener('click', (e) => {
                e.preventDefault();
                btnGrid.classList.add('active');
                if (btnList) btnList.classList.remove('active');
                viewGrid.style.display = 'grid';
                if (viewList) viewList.style.display = 'none';
            });

            btnList ?. addEventListener('click', (e) => {
                e.preventDefault();
                btnList.classList.add('active');
                if (btnGrid) btnGrid.classList.remove('active');
                if (viewGrid) viewGrid.style.display = 'none';
                if (viewList) viewList.style.display = 'block';
            });

            // Bind triggers
            if (filterForm) {
                categoryFilter ?. addEventListener('change', autoSubmit);
                sortSelect ?. addEventListener('change', autoSubmit);
                searchInput ?. addEventListener('input', autoSubmit);
                filterForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    executeAjaxFilter();
                });
            }

            // Dual Range Slider Logic
            function updateSliderVisuals() {
                const thumbMin = document.getElementById('thumb-min');
                const thumbMax = document.getElementById('thumb-max');
                const fill = document.getElementById('price-range-fill');
                const display = document.getElementById('price-display');
                if (! sliderMin || ! sliderMax) return;

                let minVal = parseInt(sliderMin.value);
                let maxVal = parseInt(sliderMax.value);

                if (minVal >= maxVal) {
                    if (this === sliderMin) minVal = maxVal - 5;
                    else maxVal = minVal + 5;
                    sliderMin.value = minVal;
                    sliderMax.value = maxVal;
                }

                const range = parseInt(sliderMin.max) - parseInt(sliderMin.min);
                const leftPct = ((minVal - parseInt(sliderMin.min)) / range) * 100;
                const rightPct = 100 - ((maxVal - parseInt(sliderMin.min)) / range) * 100;

                if (thumbMin) thumbMin.style.left = leftPct + '%';
                if (thumbMax) thumbMax.style.left = (100 - rightPct) + '%';
                if (fill) {
                    fill.style.left = leftPct + '%';
                    fill.style.right = rightPct + '%';
                }
                if (display) {
                    const maxLabel = maxVal >= 2000 ? '∞' : maxVal;
                    display.textContent = `${minVal} — ${maxLabel} TND`;
                }
            }

            sliderMin ?. addEventListener('input', updateSliderVisuals);
            sliderMax ?. addEventListener('input', updateSliderVisuals);
            sliderMin ?. addEventListener('change', autoSubmit);
            sliderMax ?. addEventListener('change', autoSubmit);
            updateSliderVisuals();
        };

// Listen for both event types to handle initial load and Turbo navigation
document.addEventListener("DOMContentLoaded", initInventoryFeatures);
document.addEventListener("turbo:load", initInventoryFeatures);

window.toggleFavorite = function(button, productId, productName) {
    fetch(`/favorites/toggle/${productId}`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(r => r.json())
    .then(data => {
        if (data.isFavorite) {
            button.classList.add('active');
            Swal.fire({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: '#fff',
                customClass: {
                    popup: 'favorite-toast-popup'
                },
                html: `
                    <div style="display: flex; align-items: center; gap: 12px; padding: 4px;">
                        <div style="background: #ffe4e6; border-radius: 50%; min-width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; animation: heartbeatPulse 1.2s infinite;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="#fb7185" stroke="#fb7185"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                        </div>
                        <div style="text-align: left;">
                            <h4 style="margin: 0; font-size: 0.95rem; color: #1a201a; font-weight: 700;">Added to Favorites!</h4>
                            <p style="margin: 0; font-size: 0.8rem; color: #5d665d;">${productName} saved to your list.</p>
                            <a href="/favorites" style="font-size: 0.8rem; font-weight: 600; color: #fb7185; text-decoration: underline;">View Favorites</a>
                        </div>
                    </div>
                `
            });
        } else {
            button.classList.remove('active');
            Swal.fire({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2000,
                background: '#fdfaf8',
                html: `
                    <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#948b83" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                            <span style="font-size: 0.85rem; color: #5d665d;">Removed from favorites</span>
                        </div>
                        <a href="/favorites" style="font-size: 0.75rem; color: #948b83; text-decoration: underline;">View list</a>
                    </div>
                `
            });
        }
    });
};
	</script>
	<div id="scanner-modal">
		<div class="scanner-content">
			<div class="scanner-header">
				<h3 class="scanner-title">AI Vision Scanner</h3>
				<button type="button" class="btn-close-scanner" id="btn-close-scanner">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
				</button>
			</div>
			<div style="position: relative;">
                <video id="scanner-video" playsinline></video>
                <div id="ai-loader">
                    <div class="ai-pulse"></div>
                    <p style="font-weight: 800; color: #627255; font-size: 1rem; margin: 0;">AI is identifying product...</p>
                </div>
			</div>
			<div class="scanner-footer">
				<p style="margin: 0; color: #64748b; font-size: 0.85rem; font-weight: 500; text-align: center;">Point your camera at a product and click analyze</p>
                <button type="button" class="btn-ai-capture" id="btn-capture">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path><circle cx="12" cy="13" r="3"></circle></svg>
                    Identify Product
                </button>
			</div>
		</div>
	</div>
{% endblock %}
