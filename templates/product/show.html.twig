{% extends 'layout/app_shell.html.twig' %}

{% block title %}{{ product.name }} | Slimenify Wellness{% endblock %}

{% block app_content %}
<style>
    :root {
        --primary-green: #627255;
        --soft-sage: #f8faf7;
        --accent-gold: #b2936a;
        --text-dark: #1e293b;
        --text-grey: #64748b;
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    .creative-page {
        padding: 1.5rem;
        max-width: 1100px; /* More compact overall */
        margin: 0 auto;
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
    }

    /* Artistic Background Elements */
    .bg-blob {
        position: absolute;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(98,114,85,0.08) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
        z-index: -1;
        top: -50px;
        left: -50px;
        filter: blur(40px);
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .back-btn-top {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-grey);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        transition: all 0.3s;
    }
    .back-btn-top:hover { color: var(--primary-green); transform: translateX(-5px); }

    /* Hero Section - Refined Split */
    .hero-container {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        background: #fff;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.03);
        margin-bottom: 3rem;
        border: 1px solid #f1f5f9;
        min-height: 500px;
    }

    .hero-image-side {
        background: var(--soft-sage);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5rem;
        position: relative;
    }
    .main-prod-img {
        width: 100%;
        max-width: 320px; /* Reduced from 450px */
        filter: drop-shadow(0 15px 30px rgba(0,0,0,0.1));
        transition: transform 0.6s cubic-bezier(0.2, 1, 0.2, 1);
    }
    .main-prod-img:hover { transform: scale(1.08); }

    .hero-info-side {
        padding: 3rem; /* Reduced from 4rem */
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .category-label {
        color: var(--accent-gold);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        font-size: 0.75rem;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .prod-title {
        font-size: 2.2rem; /* Significantly reduced from 3.5rem */
        font-weight: 800;
        color: var(--text-dark);
        line-height: 1.2;
        margin-bottom: 1.25rem;
        letter-spacing: -0.01em;
    }

    .price-wrap {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }
    .curr-price {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--text-dark);
    }
    .old-price {
        color: var(--text-grey);
        text-decoration: line-through;
        font-size: 1.1rem;
        opacity: 0.6;
    }

    /* Compact Interaction Island */
    .interaction-island {
        background: #f8fafc;
        padding: 1.5rem;
        border-radius: 20px;
        margin-bottom: 1.5rem;
        border: 1px solid #f1f5f9;
        max-width: 400px;
    }

    .qty-control {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .qty-btn {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        background: #fff;
        border: 1px solid #e2e8f0;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        transition: all 0.2s;
    }
    .qty-btn:hover { border-color: var(--primary-green); color: var(--primary-green); }

    .action-row-main {
        display: flex;
        gap: 0.75rem;
    }
    .btn-buy {
        flex: 1;
        background: var(--primary-green);
        color: #fff;
        border: none;
        padding: 0.8rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-buy:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(98,114,85,0.2); }

    .btn-heart {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s;
        color: var(--text-grey);
    }
    .btn-heart:hover { border-color: #ff7e5f; color: #ff7e5f; transform: scale(1.05); }

    .btn-secondary {
        width: 100%;
        margin-top: 0.75rem;
        background: transparent;
        border: 1px solid #e2e8f0;
        color: var(--text-grey);
        padding: 0.6rem;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-secondary:hover { background: #fff; color: var(--text-dark); border-color: var(--text-dark); }

    /* Highlights Section */
    .highlights-mini {
        display: flex;
        gap: 1.5rem;
        margin-top: 1.5rem;
    }
    .h-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--text-grey);
        text-transform: uppercase;
    }
    .h-icon {
        width: 36px;
        height: 36px;
        background: #f1f5f9;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    /* Refined Info Block */
    .product-meta {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid #f1f5f9;
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--text-grey);
    }

    /* Smaller Scroller for Related */
    .related-section {
        margin-top: 4rem;
        padding-top: 3rem;
    }
    .rel-title { font-size: 1.3rem; font-weight: 800; color: var(--text-dark); margin-bottom: 2rem; text-align: center;}
    
    .sugg-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
    }
    .sugg-card {
        background: #fff;
        border-radius: 20px;
        padding: 1.25rem;
        text-decoration: none;
        transition: all 0.3s;
        border: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .sugg-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.05); }
    .sugg-img-w {
        width: 100%;
        height: 140px;
        background: var(--soft-sage);
        border-radius: 12px;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .sugg-img-w img { width: 80%; height: 80%; object-fit: contain; }

    @media (max-width: 850px) {
        .hero-container { grid-template-columns: 1fr; }
        .hero-info-side { padding: 2rem; }
    }
</style>

<div class="creative-page">
    <div class="bg-blob"></div>
    
    <a href="{{ path('app_product_index') }}" class="back-btn-top">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Back to Shop
    </a>

    <div class="hero-container">
        <div class="hero-image-side">
            <img src="{{ product.photoUrl ?: 'https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=800&q=80' }}" class="main-prod-img" alt="{{ product.name }}">
        </div>

        <div class="hero-info-side">
            <span class="category-label">
                {{ product.category ?: 'Care' }}
            </span>
            <h1 class="prod-title">{{ product.name }}</h1>

            <div class="price-wrap">
                <span class="curr-price">{{ product.price }} TND</span>
                <span class="old-price">{{ (product.price * 1.12)|number_format(2) }} TND</span>
            </div>

            <div class="interaction-island">
                <form action="{{ path('app_cart_add', {'id': product.id}) }}" method="POST" id="cart-form">
                    <div class="qty-control">
                        <button type="button" class="qty-btn" id="q-min">-</button>
                        <input type="number" name="quantity" id="q-input" value="1" min="1" style="font-weight: 700; width: 45px; text-align: center; border: none; background: transparent; pointer-events: none;">
                        <button type="button" class="qty-btn" id="q-plus">+</button>
                    </div>

                    <div class="action-row-main">
                        <button type="submit" class="btn-buy" id="btn-add">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
                            Add to Cart
                        </button>
                        <button type="button" class="btn-heart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                        </button>
                    </div>
                    
                    <button type="button" class="btn-secondary" onclick="alert('This feature will be available soon!')">
                        Take for treatment
                    </button>
                </form>
            </div>

            <div class="highlights-mini">
                <div class="h-item">
                    <div class="h-icon" title="Organic Cert">O</div>
                    <span>Organic</span>
                </div>
                <div class="h-item">
                    <div class="h-icon" title="Pure Quality">P</div>
                    <span>Pure</span>
                </div>
                <div class="h-item">
                    <div class="h-icon" title="Express Delivery">E</div>
                    <span>Express</span>
                </div>
            </div>
        </div>
    </div>

    <div class="product-meta">
        <h3 style="font-size: 1.1rem; color: var(--text-dark); margin-bottom: 1rem;">About Product</h3>
        <p>
            {{ product.description ?: 'A carefully selected choice for your mental well-being. This product meets Slimenify quality standards, designed to support you in your healing journey.' }}
        </p>
        
        {% if not is_granted('ROLE_PATIENT') %}
            <div style="margin-top: 1.5rem; font-size: 0.8rem; color: #94a3b8;">
                Ref: PH-{{ product.id }} | Stock: {{ product.stockQuantity }} units
            </div>
        {% endif %}
    </div>

    {% if relatedProducts|length > 0 %}
    <div class="related-section">
        <h3 class="rel-title">Related Suggestions</h3>
        <div class="sugg-grid">
            {% for rel in relatedProducts %}
                <a href="{{ path('app_product_show', {id: rel.id}) }}" class="sugg-card">
                    <div class="sugg-img-w">
                        <img src="{{ rel.photoUrl ?: 'https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=200&q=80' }}" alt="">
                    </div>
                    <span style="font-size: 0.8rem; font-weight: 700; color: var(--text-dark);">
                        {{ rel.name }}
                    </span>
                    <span style="font-size: 0.85rem; color: var(--primary-green); font-weight: 700; margin-top: 0.3rem;">
                        {{ rel.price }} TND
                    </span>
                </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const qInput = document.getElementById('q-input');
        let count = 1;

        document.getElementById('q-plus')?.addEventListener('click', () => {
            count++;
            qInput.value = count;
        });

        document.getElementById('q-min')?.addEventListener('click', () => {
            if (count > 1) {
                count--;
                qInput.value = count;
            }
        });
    });
</script>
{% endblock %}
