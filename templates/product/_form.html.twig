<style>
    .form-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    .form-group {
        margin-bottom: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .form-group.full-width {
        grid-column: span 2;
    }
    .form-label {
        font-weight: 600;
        font-size: 0.9rem;
        color: #334155;
    }
    .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        background: #f8fafc;
        font-size: 0.95rem;
        transition: all 0.2s;
        box-sizing: border-box;
    }
    .form-input:focus {
        background: #fff;
        border-color: #627255;
        box-shadow: 0 0 0 4px rgba(98, 114, 85, 0.1);
        outline: none;
    }
    .form-input.is-invalid {
        border-color: #ef4444;
        background: #fffcfc;
    }
    .form-error {
        color: #ef4444;
        font-size: 0.8rem;
        font-weight: 500;
        margin-top: 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }
    .form-error svg {
        width: 14px;
        height: 14px;
    }
    .form-submit-row {
        margin-top: 2rem;
        display: flex;
        justify-content: flex-end;
    }
    .btn-save {
        background: linear-gradient(135deg, #748764, #546549);
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(98, 114, 85, 0.2);
    }
    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 15px rgba(98, 114, 85, 0.3);
    }

    @media (max-width: 640px) {
        .form-container { grid-template-columns: 1fr; }
        .form-group.full-width { grid-column: span 1; }
    }
</style>

{{ form_start(form, {'attr': {
    'novalidate': 'novalidate',
    'onsubmit': "return confirm('Are you sure you want to save these product details?');"
}}) }}
    <div class="form-container">
        <div class="form-group full-width">
            {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'form-input' ~ (form.name.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
            {% for error in form.name.vars.errors %}
                <div class="form-error">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>

        <div class="form-group full-width">
            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'form-input' ~ (form.description.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="form-group">
            {{ form_label(form.price, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.price, {'attr': {'class': 'form-input' ~ (form.price.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
            {% for error in form.price.vars.errors %}
                <div class="form-error">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>

        <div class="form-group">
            {{ form_label(form.stockQuantity, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.stockQuantity, {'attr': {'class': 'form-input' ~ (form.stockQuantity.vars.errors|length > 0 ? ' is-invalid' : '')}}) }}
            {% for error in form.stockQuantity.vars.errors %}
                <div class="form-error">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>

        <div class="form-group">
            {{ form_label(form.category, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.category, {'attr': {'class': 'form-input'}}) }}
        </div>

        <div class="form-group">
            {{ form_label(form.status, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'form-input'}}) }}
        </div>

        <div class="form-group">
            {{ form_label(form.expirationDate, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.expirationDate, {'attr': {'class': 'form-input'}}) }}
        </div>

        <div class="form-group">
            {{ form_label(form.supplier, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.supplier, {'attr': {'class': 'form-input'}}) }}
        </div>

        <div class="form-group full-width">
            {{ form_label(form.photoUrl, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.photoUrl, {'attr': {'class': 'form-input'}}) }}
        </div>
    </div>

    <div class="form-submit-row">
        <button type="submit" class="btn-save">{{ button_label|default('Save Product') }}</button>
    </div>

    <script>
        const initFormLogic = () => {
            const qtyInput = document.getElementById('{{ form.stockQuantity.vars.id }}');
            const statusSelect = document.getElementById('{{ form.status.vars.id }}');
            
            if (qtyInput && statusSelect) {
                // Remove previous event listener to avoid duplicates from turbo
                const newQtyInput = qtyInput.cloneNode(true);
                qtyInput.parentNode.replaceChild(newQtyInput, qtyInput);

                newQtyInput.addEventListener('input', function() {
                    const qty = parseInt(this.value, 10);
                    if (!isNaN(qty) && qty > 0) {
                        statusSelect.value = 'available';
                    } else if (qty === 0) {
                        statusSelect.value = 'out_of_stock';
                    }
                });

                statusSelect.addEventListener('change', function() {
                    const qty = parseInt(newQtyInput.value, 10);
                    if (!isNaN(qty) && qty > 0 && this.value === 'out_of_stock') {
                        // Prevent setting out of stock if we have quantity
                        this.value = 'available';
                    }
                });
            }
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initFormLogic);
        } else {
            initFormLogic();
        }
        document.addEventListener('turbo:load', initFormLogic);
    </script>
{{ form_end(form) }}
