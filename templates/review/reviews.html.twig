{% extends 'layout/app_shell.html.twig' %}

{% block app_content %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
/* === Styles simplifiés === */
.left-box { flex:1; min-width:300px; position:sticky; top:20px; }
.right-box { flex:2; display:flex; flex-direction:column; gap:20px; }
.section-title { font-size:1.3rem; font-weight:600; margin-bottom:15px; color: #1e293b; }
.form-control, .reply-input, select { width:100%; padding:10px; border:1px solid #cbd5e1; border-radius:8px; font-family:inherit; }
.btn { padding:6px 12px; border:none; border-radius:6px; cursor:pointer; margin-right:5px; transition: all 0.2s; }
.btn:hover { opacity:0.9; transform: translateY(-1px); }
.btn-submit { background:#10b981; color:white; }
.btn-like { background:#e0f2fe; color:#0284c7; }
.btn-dislike { background:#ffe4e6; color:#b91c1c; }
.btn-edit { background:#fef08a; color:#854d0e; }
.btn-delete { background:#fee2e2; color:#b91c1c; }
.review-card, .reply-card { border-radius:10px; padding:20px; margin-bottom:15px; background:white; border: 1px solid #e2e8f0; }
.review-header { display:flex; justify-content:space-between; margin-bottom:10px; border-bottom: 1px solid #f1f5f9; padding-bottom:10px; }
.action-buttons { display:flex; gap:10px; margin-top:15px; align-items:center; }
.author-actions { margin-left:auto; display:flex; gap:5px; }
.reply-form { display:flex; gap:10px; margin-top:20px; background:#f8fafc; padding:15px; border-radius:8px; }
.star-active { color: #f59e0b; }
.star-inactive { color: #d1d5db; }

/* Star Rating Input */
.star-rating-input { display: flex; flex-direction: row-reverse; justify-content: flex-end; }
.star-rating-input input { display: none; }
.star-rating-input label { font-size: 2rem; color: #d1d5db; cursor: pointer; transition: color 0.2s; }
.star-rating-input input:checked ~ label,
.star-rating-input label:hover,
.star-rating-input label:hover ~ label { color: #f59e0b; }
</style>

<div class="reviews-wrapper" style="display:flex; gap:30px;">

    {# === Formulaire Patient === #}
    {% if is_granted('ROLE_PATIENT') and not is_granted('ROLE_ADMIN') and not is_granted('ROLE_THERAPIST') %}
    <div class="left-box">
        <div style="background:white; padding:20px; border-radius:12px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);">
            <h2 class="section-title">✨ Share your experience</h2>
            <form action="{{ path('app_reviews_add') }}" method="POST" id="addReviewForm">
                <textarea name="content" class="form-control" required minlength="11" placeholder="Write your review (min 11 chars)" style="height:120px; margin-bottom:15px;"></textarea>
                
                <label style="display:block; margin-bottom:5px; font-weight:500;">Rating:</label>
                <div class="star-rating-input">
                    {% for i in 5..1 %}
                        <input type="radio" id="star{{ i }}" name="rating" value="{{ i }}" {% if i == 5 %}checked{% endif %} />
                        <label for="star{{ i }}" title="{{ i }} stars">★</label>
                    {% endfor %}
                </div>

                <button type="submit" class="btn btn-submit" style="width:100%; margin-top:20px; font-weight:600; padding:12px;">Submit Review</button>
            </form>
        </div>
    </div>
    {% endif %}

    <div class="right-box">

        {# === Admin Dashboard === #}
        {% if is_granted('ROLE_ADMIN') %}
        <div style="background:#f1f5f9; padding:15px; border-radius:10px; margin-bottom:20px; display:flex; justify-content:space-between; flex-wrap:wrap; align-items:center;">
            <div style="flex:1;">
                <h2 class="section-title">📊 Admin Dashboard</h2>
                <form method="GET" action="{{ path('app_reviews_admin') }}" style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
                    <input type="text" name="search" value="{{ searchTerm|default('') }}" placeholder="Search reviews..." class="form-control" style="min-width:220px;">
                    <input type="hidden" name="sort" value="{{ currentSort|default('DESC') }}">
                    <button type="submit" class="btn btn-submit" style="width:auto; background:#3b82f6;">🔍 Search</button>
                </form>
                <a href="{{ path('app_reviews_admin', { sort: currentSort == 'ASC' ? 'DESC' : 'ASC', search: searchTerm|default('') }) }}"
                   class="btn btn-submit" style="width:auto; background:#64748b; margin-top:10px;">
                    {% if currentSort == 'ASC' %} ⏳ Sort: Oldest First {% else %} ⏳ Sort: Newest First {% endif %}
                </a>
            </div>
            <div style="width:220px; height:220px;">
                <canvas id="statsChart"></canvas>
            </div>
        </div>

        <script>
(function() {
    let answered = {{ stats.answeredPercent }};
    let unanswered = {{ stats.unansweredPercent }};

    new Chart(document.getElementById('statsChart'), {
        type: 'pie',
        data: {
            labels: ['Answered', 'Unanswered'],
            datasets: [{
                data: [answered, unanswered],
                backgroundColor: ['#10b981', '#f43f5e']
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { position: 'bottom' },
                title: {
                    display: true,
                    text: 'Review Response Rate (%)'
                }
            }
        }
    });
})();
</script>
        {% endif %}

        {# === Reviews List === #}
        {% if reviews is empty %}
            <div style="text-align:center; padding:40px; color:#64748b;">No reviews yet.</div>
        {% endif %}

        {% for review in reviews %}
        <div class="review-card" data-id="{{ review.id }}">
            <div class="review-header">
                <div>
                    <span class="review-author" style="font-weight:700; color:#0f172a;">{{ review.user.firstName|default('Anonymous') }} {{ review.user.lastName|default('') }}</span>
                    <div class="stars-display" style="margin-top:2px;">
                        {% for i in 1..5 %}
                            <span class="star {% if i <= review.rating %}star-active{% else %}star-inactive{% endif %}">★</span>
                        {% endfor %}
                    </div>
                </div>
                <span style="font-size:0.85rem; color:#64748b;">{{ review.createdAt|date('d M Y, H:i') }}</span>
            </div>
            <div class="review-content">{{ review.content }}</div>
            <div class="action-buttons">
                <button class="btn btn-like" onclick="likeDislike('review', {{ review.id }}, 'like', this)">👍 <span>{{ review.likes|default(0) }}</span></button>
                <button class="btn btn-dislike" onclick="likeDislike('review', {{ review.id }}, 'dislike', this)">👎 <span>{{ review.dislikes|default(0) }}</span></button>

                {% if app.user and (is_granted('ROLE_ADMIN') or app.user.email == review.user.email) %}
                <div class="author-actions">
                    <button class="btn btn-edit" 
                            data-content="{{ review.content|e('html_attr') }}"
                            onclick="editItem('review', {{ review.id }}, this.getAttribute('data-content'))">
                        Edit
                    </button>
                    <button class="btn btn-delete" onclick="deleteItem('review', {{ review.id }})">Delete</button>
                </div>
                {% endif %}
            </div>

            {# Replies #}
            <div class="replies-section">
                {% for reply in review.replies %}
                <div class="reply-card" data-id="{{ reply.id }}">
                    <strong>{{ reply.therapist.username|default('Therapist') }}</strong>
                    <div>{{ reply.content }}</div>
                    <div class="action-buttons">
                        <button class="btn btn-like" onclick="likeDislike('reply', {{ reply.id }}, 'like', this)">👍 <span>{{ reply.likes|default(0) }}</span></button>
                        <button class="btn btn-dislike" onclick="likeDislike('reply', {{ reply.id }}, 'dislike', this)">👎 <span>{{ reply.dislikes|default(0) }}</span></button>

                        {% if app.user and (is_granted('ROLE_ADMIN') or app.user.email == reply.therapist.email) %}
                        <div class="author-actions">
                            <button class="btn btn-edit" 
                                    data-content="{{ reply.content|e('html_attr') }}"
                                    onclick="editItem('reply', {{ reply.id }}, this.getAttribute('data-content'))">
                                Edit
                            </button>
                            <button class="btn btn-delete" onclick="deleteItem('reply', {{ reply.id }})">Delete</button>
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}

                {% if is_granted('ROLE_THERAPIST') %}
                <form class="reply-form" action="{{ path('app_reviews_reply', {'id': review.id}) }}" method="POST">
                    <textarea name="content" required minlength="11" class="reply-input" placeholder="Write a reply..."></textarea>
                    <button type="submit" class="btn btn-submit">Reply</button>
                </form>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
// Handle Flash Messages with SweetAlert2
document.addEventListener('DOMContentLoaded', function() {
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            Swal.fire({
                icon: '{{ label == "error" ? "error" : "success" }}',
                title: '{{ label|capitalize }}',
                text: '{{ message|e("js") }}',
                timer: 3000,
                showConfirmButton: false
            });
        {% endfor %}
    {% endfor %}
});

// Like/Dislike AJAX
function likeDislike(type, id, action, btn){
    let url = (type==='review') ? `/api/reviews/${id}/${action}` : `/api/review-replies/${id}/${action}`;
    fetch(url, { method:'POST' }).then(r=>r.json()).then(data=>{
        if(action==='like') btn.querySelector('span').innerText = data.likes;
        else btn.querySelector('span').innerText = data.dislikes;
    });
}

// Edit item
function editItem(type, id, content){
    Swal.fire({
        title: 'Edit ' + (type === 'review' ? 'your review' : 'your reply'),
        text: 'Do you really want to edit this ' + type + '?',
        input: 'textarea',
        inputValue: content,
        showCancelButton: true,
        confirmButtonText: 'Yes, update it!',
        cancelButtonText: 'Cancel',
        confirmButtonColor: '#10b981',
        inputValidator: (value) => {
            if (!value || value.trim().length <= 10) {
                return 'Content must be more than 10 characters!'
            }
        }
    }).then(result=>{
        if(result.isConfirmed){
            let url = (type==='review') ? `/reviews/${id}/edit` : `/reviews/reply/${id}/edit`;
            fetch(url, {
                method:'POST',
                headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ content: result.value })
            }).then(r=>r.json()).then(d=>{
                if(d.message) {
                    Swal.fire({ icon: 'success', title: 'Updated!', text: d.message, timer: 1500, showConfirmButton: false })
                        .then(() => location.reload());
                } else {
                    Swal.fire('Error', d.error || 'Something went wrong', 'error');
                }
            }).catch(err => {
                Swal.fire('Error', 'Communication error with server', 'error');
            });
        }
    });
}

// Delete item
function deleteItem(type, id){
    Swal.fire({
        title: 'Are you sure?',
        text: "Do you really want to delete this " + type + "? This action cannot be undone.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Yes, delete it!'
    }).then(result=>{
        if(result.isConfirmed){
            let url = (type==='review') ? `/reviews/${id}/delete` : `/reviews/reply/${id}/delete`;
            fetch(url, { method:'POST' }).then(r=>r.json()).then(d=>{
                if(d.message) {
                    Swal.fire({ icon: 'success', title: 'Deleted!', text: d.message, timer: 1500, showConfirmButton: false })
                        .then(() => location.reload());
                } else {
                    Swal.fire('Error', d.error || 'Something went wrong', 'error');
                }
            }).catch(err => {
                Swal.fire('Error', 'Communication error with server', 'error');
            });
        }
    });
}
</script>
{% endblock %}