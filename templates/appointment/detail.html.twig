{% extends 'layout/app_shell.html.twig' %}

{% block title %}Appointment Details{% endblock %}

{% block app_content %}
    <meta name="turbo-cache-control" content="no-cache">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <h1 style="margin:0; color:#1a201a;">Appointment Details</h1>
        <a href="{{ path('app_appointments_calendar') }}" style="text-decoration:none; background:#fdfaf8; color:#4a544a; border:1px solid #c2cdc2; border-radius:8px; padding:0.4rem 0.8rem; font-size:0.9rem; font-weight:500; transition:all 0.15s; display:inline-flex; align-items:center; gap:0.4rem;">
            &larr; Back to Calendar
        </a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div style="margin:0.7rem 0; padding:0.7rem 0.9rem; border-radius:10px; border:1px solid {{ label == 'error' ? '#fecaca' : '#bbf7d0' }}; background:{{ label == 'error' ? '#fef2f2' : '#f0fdf4' }}; color:{{ label == 'error' ? '#b91c1c' : '#166534' }};">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <section style="background:#fff; border:1px solid #c2cdc2; border-radius:14px; padding:1rem;">
        <div style="display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:0.7rem; color:#1a201a;">
            <div><strong>Date:</strong> {{ appointment.appointmentDate|date('Y-m-d') }}</div>
            <div><strong>Time:</strong> {{ appointment.startTime|date('H:i') }} - {{ appointment.endTime|date('H:i') }}</div>
            <div><strong>Status:</strong> {{ appointment.status|default('pending')|capitalize }}</div>
            <div><strong>Type:</strong> {{ appointment.type|default('n/a')|capitalize }}</div>
            <div><strong>Therapist:</strong> {{ appointment.therapist.firstName }} {{ appointment.therapist.lastName }}</div>
            <div><strong>Client:</strong> {{ appointment.patient.firstName }} {{ appointment.patient.lastName }}</div>
        </div>

        {% if jitsi_url %}
            <div id="jitsi-container" style="display:none; margin-top:1.2rem; padding-top:1rem; border-top:1px solid #fdfaf8;">
                <a href="{{ jitsi_url }}" target="_blank" style="text-decoration:none; background:#748764; color:#fff; border-radius:10px; padding:0.6rem 1.2rem; font-weight:600; display:inline-flex; align-items:center; gap:0.5rem; transition:all 0.2s; box-shadow:0 4px 6px -1px rgb(0 0 0 / 0.1);">
                    <svg style="width:20px; height:20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                    Join Video Consultation
                </a>
                <p style="margin:0.5rem 0 0; font-size:0.8rem; color:#5d665d;">Powered by Jitsi Meet. No login required.</p>
            </div>
        {% endif %}
    </section>

    {% if can_manage_status %}
        <section style="margin-top:1rem; background:#fff; border:1px solid #c2cdc2; border-radius:14px; padding:1rem;">
            <h2 style="margin-top:0; color:#1a201a; font-size:1.1rem;">Manage Status</h2>
            {% if next_statuses is empty %}
                <p style="color:#5d665d; margin-bottom:0;">No further status transitions available.</p>
            {% else %}
                <form id="status-form" method="post" action="{{ path('app_appointments_status', {id: appointment.id}) }}" style="display:flex; gap:0.6rem; flex-wrap:wrap;">
                    {% for status in next_statuses %}
                        {% if status == 'cancelled' %}
                            <button
                                type="button"
                                onclick="Swal.fire({title:'Cancel Appointment?', text:'This action cannot be undone and will delete the appointment.', icon:'warning', showCancelButton:true, confirmButtonColor:'#d33', confirmButtonText:'Yes, cancel it!'}).then(r => { if(r.isConfirmed){ const f = document.getElementById('status-form'); const i = document.createElement('input'); i.type='hidden'; i.name='status'; i.value='cancelled'; f.appendChild(i); f.submit(); } })"
                                style="border:none; background:#ef4444; color:#fff; border-radius:8px; padding:0.5rem 0.75rem; cursor:pointer;"
                            >Cancel</button>
                        {% else %}
                            <button
                                type="submit"
                                name="status"
                                value="{{ status }}"
                                style="border:none; background:{{
                                    status == 'confirmed' ? '#22c55e' :
                                    (status == 'completed' ? '#748764' : '#eab308')
                                }}; color:#fff; border-radius:8px; padding:0.5rem 0.75rem; cursor:pointer;"
                            >
                                {{ status == 'confirmed' ? 'Confirm' : (status == 'completed' ? 'Mark Completed' : status|capitalize) }}
                            </button>
                        {% endif %}
                    {% endfor %}
                </form>
            {% endif %}
        </section>
    {% endif %}

    {% if appointment.status == 'completed' %}
        {% set show_mood = false %}
        {% if is_granted('ROLE_THERAPIST') or (is_granted('ROLE_PATIENT') and app.user.id == appointment.patient.id) %}
            {% set show_mood = true %}
        {% endif %}

        {% if show_mood %}
            <section style="margin-top:1rem; background:#fff; border:1px solid #c2cdc2; border-radius:14px; padding:1rem;">
                <h2 style="margin-top:0; color:#1a201a; font-size:1.1rem;">Patient Mood</h2>
                {% if appointment.patientMood %}
                    <p style="color:#4a544a;">
                        {% if is_granted('ROLE_THERAPIST') %}
                            The patient reported their mood as:
                        {% else %}
                            You reported your mood as:
                        {% endif %}
                        <strong>{{ appointment.patientMood }}</strong>
                    </p>
                {% elseif is_granted('ROLE_PATIENT') and app.user.id == appointment.patient.id %}
                    <form id="mood-form" method="post" action="{{ path('app_appointments_patient_mood', {id: appointment.id}) }}" style="display:block; margin-top:0.5rem;">
                        <label for="patient_mood" style="color:#334155; font-weight:600; font-size:1.05rem; display:block; margin-bottom:1rem;">How are you feeling after this session?</label>
                        
                        <div class="mood-selector" style="display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:1.5rem;">
                            {% set moods = {'Excellent': '🤩 Excellent', 'Good': '😊 Good', 'Neutral': '😐 Neutral', 'Bad': '🙁 Bad', 'Terrible': '😢 Terrible'} %}
                            {% for val, label in moods %}
                                <label style="cursor:pointer; position:relative;">
                                    <input type="radio" name="patient_mood" value="{{ val }}" required style="position:absolute; opacity:0; width:0; height:0;">
                                    <div class="mood-card" style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.5rem; padding:1rem 1.5rem; border:2px solid #e2e8f0; border-radius:16px; background:#f8fafc; transition:all 0.2s cubic-bezier(0.4, 0, 0.2, 1); min-width:105px;">
                                        <span style="font-size:2.2rem; filter:drop-shadow(0 2px 4px rgb(0 0 0 / 0.1)); line-height:1;">{{ label|split(' ')|first }}</span>
                                        <span style="font-weight:600; color:#475569; font-size:0.95rem;">{{ label|split(' ')|last }}</span>
                                    </div>
                                </label>
                            {% endfor %}
                        </div>

                        <button type="submit" class="submit-mood-btn" style="border:none; background:#8b5cf6; color:#fff; border-radius:10px; padding:0.75rem 1.5rem; font-weight:600; cursor:pointer; font-size:1rem; box-shadow:0 4px 6px -1px rgb(139 92 246 / 0.3); transition:all 0.2s;">Submit Reflection</button>
                    </form>
                {% else %}
                    <p style="color:#5d665d; font-style:italic; font-size:0.9rem;">Patient has not yet submitted their mood feedback.</p>
                {% endif %}
            </section>
        {% endif %}
    {% endif %}

    {% if not is_granted('ROLE_ADMIN') %}
    <section style="margin-top:1rem; background:#fff; border:1px solid #c2cdc2; border-radius:14px; padding:1rem;">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1rem;">
            <h2 style="margin:0; color:#1a201a; font-size:1.1rem;">Session Notes</h2>
            {% if notes is not empty %}
                <button id="summarize-btn" type="button" style="border:1px solid #c2cdc2; background:#f8fafc; color:#1e293b; border-radius:8px; padding:0.4rem 0.8rem; font-size:0.85rem; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:0.4rem; transition:all 0.2s;">
                    <svg style="width:16px; height:16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Summarize with Gemini AI
                </button>
            {% endif %}
        </div>

        <div id="ai-summary-container" style="display:none; margin-bottom:1.5rem; background:#fdfaf8; border:1px solid #c2cdc2; border-radius:12px; padding:1rem;">
            <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem; color:#748764; font-weight:600; font-size:0.9rem;">
                <svg style="width:18px; height:18px;" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 100 2h1z"></path></svg>
                Gemini AI Summary
            </div>
            <div id="ai-summary-text" style="color:#1a201a; line-height:1.5; font-size:0.95rem;"></div>
        </div>

        {% if can_manage_notes %}
            <form method="post" action="{{ path('app_appointments_add_note', {id: appointment.id}) }}" style="display:grid; gap:0.55rem; margin-bottom:1rem;">
                <label style="font-size:0.9rem; color:#4a544a;">Add Note</label>
                <textarea name="content" rows="3" required style="border:1px solid #c2cdc2; border-radius:8px; padding:0.55rem;"></textarea>
                <input type="text" name="mood" placeholder="Mood (optional)" style="border:1px solid #c2cdc2; border-radius:8px; padding:0.55rem;">
                <button type="submit" style="width:max-content; border:none; background:#627255; color:#fff; border-radius:8px; padding:0.45rem 0.75rem; cursor:pointer;">Save Note</button>
            </form>
        {% endif %}

        {% if notes is empty %}
            <p style="color:#5d665d;">No notes yet.</p>
        {% else %}
            {% for note in notes %}
                <article style="border:1px solid #c2cdc2; border-radius:10px; padding:0.7rem; margin-bottom:0.6rem;">
                    <div style="font-size:0.86rem; color:#5d665d; margin-bottom:0.4rem;">
                        {{ note.createdAt|date('Y-m-d H:i') }}{% if note.mood %} • Mood: {{ note.mood }}{% endif %}
                    </div>
                    <p style="margin:0; color:#1a201a; white-space:pre-wrap;">{{ note.content }}</p>

                    {% if can_manage_notes %}
                        <form method="post" action="{{ path('app_appointments_edit_note', {noteId: note.id}) }}" style="display:grid; gap:0.45rem; margin-top:0.6rem;">
                            <textarea name="content" rows="2" style="border:1px solid #c2cdc2; border-radius:8px; padding:0.5rem;">{{ note.content }}</textarea>
                            <input type="text" name="mood" value="{{ note.mood }}" placeholder="Mood (optional)" style="border:1px solid #c2cdc2; border-radius:8px; padding:0.45rem;">
                            <div style="display:flex; gap:0.45rem;">
                                <button type="submit" style="border:none; background:#627255; color:#fff; border-radius:8px; padding:0.35rem 0.7rem; cursor:pointer;">Update</button>
                                <button type="button" onclick="const form=this.closest('form'); Swal.fire({title:'Are you sure?', text:'This will permanently delete this note.', icon:'warning', showCancelButton:true, confirmButtonColor:'#d33', confirmButtonText:'Yes, delete!'}).then(r => { if(r.isConfirmed){ form.action='{{ path('app_appointments_delete_note', {noteId: note.id}) }}'; form.submit(); } })" style="border:none; background:#ef4444; color:#fff; border-radius:8px; padding:0.35rem 0.7rem; cursor:pointer;">Delete</button>
                            </div>
                        </form>
                    {% endif %}
                </article>
            {% endfor %}
        {% endif %}
    </section>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function() {
            function initAppointmentDetailPage() {
                // 1. Gemini AI Summarization
                const summarizeBtn = document.getElementById('summarize-btn');
                if (summarizeBtn && !summarizeBtn.dataset.listenerBound) {
                    summarizeBtn.dataset.listenerBound = 'true';
                    summarizeBtn.addEventListener('click', async () => {
                        summarizeBtn.disabled = true;
                        const originalContent = summarizeBtn.innerHTML;
                        summarizeBtn.innerHTML = '<span style="display:inline-block; animation: spin 1s linear infinite;">⏳</span> Summarizing...';
                        
                        try {
                            const response = await fetch('{{ path('app_appointments_summarize', {id: appointment.id}) }}', {
                                method: 'POST',
                                headers: { 'X-Requested-With': 'XMLHttpRequest' }
                            });
                            
                            const data = await response.json();
                            if (data.summary) {
                                const container = document.getElementById('ai-summary-container');
                                const text = document.getElementById('ai-summary-text');
                                text.innerText = data.summary;
                                container.style.display = 'block';
                                container.scrollIntoView({ behavior: 'smooth', block: 'start' });
                            } else if (data.error) {
                                Swal.fire('Error', data.error, 'error');
                            }
                        } catch (e) {
                            Swal.fire('Error', 'Failed to connect to AI service.', 'error');
                        } finally {
                            summarizeBtn.disabled = false;
                            summarizeBtn.innerHTML = originalContent;
                        }
                    });
                }

                // 2. Jitsi Auto-Join (only if video appointment and not already opened)
                {% if jitsi_url and appointment.status != 'completed' and appointment.status != 'cancelled' %}
                const jitsiKey = 'jitsi_opened_' + {{ appointment.id }};
                if (!sessionStorage.getItem(jitsiKey)) {
                    const aptStartStr = "{{ appointment.appointmentDate|date('Y-m-d') }}T{{ appointment.startTime|date('H:i:s') }}";
                    const aptEndStr = "{{ appointment.appointmentDate|date('Y-m-d') }}T{{ appointment.endTime|date('H:i:s') }}";
                    const aptStart = new Date(aptStartStr);
                    const aptEnd = new Date(aptEndStr);

                    window.jitsiInterval = setInterval(() => {
                        const now = new Date();
                        if (now >= aptStart && now <= aptEnd) {
                            sessionStorage.setItem(jitsiKey, 'true');
                            clearInterval(window.jitsiInterval);
                            
                            Swal.fire({
                                title: 'Session Started',
                                text: 'Redirecting you to the video consultation session automatically...',
                                icon: 'info',
                                timer: 3000,
                                showConfirmButton: false
                            });
                            
                            setTimeout(() => {
                                window.location.href = "{{ jitsi_url }}";
                            }, 1500);
                        }
                    }, 10000);
                }
                {% endif %}

                // 3. Jitsi Button Visibility (Show at start time, hide 15 mins after)
                {% if jitsi_url %}
                    const aptStartStrBtn = "{{ appointment.appointmentDate|date('Y-m-d') }}T{{ appointment.startTime|date('H:i:s') }}";
                    const aptStartBtn = new Date(aptStartStrBtn);
                    const aptEndBtn = new Date(aptStartBtn.getTime() + 15 * 60000); // 15 mins later
                    
                    function updateJitsiButton() {
                        const now = new Date();
                        const container = document.getElementById('jitsi-container');
                        if (container) {
                            if (now >= aptStartBtn && now <= aptEndBtn && "{{ appointment.status }}" !== "completed" && "{{ appointment.status }}" !== "cancelled") {
                                container.style.display = 'block';
                            } else {
                                container.style.display = 'none';
                            }
                        }
                    }
                    
                    updateJitsiButton();
                    setInterval(updateJitsiButton, 1000);
                {% endif %}
            }

            // Bind to all possible load events
            document.addEventListener('turbo:load', initAppointmentDetailPage);
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initAppointmentDetailPage);
            } else {
                initAppointmentDetailPage();
            }
        })();
    </script>

    <style>
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        
        .mood-selector label input:checked + .mood-card {
            border-color: #8b5cf6 !important;
            background: #f5f3ff !important;
            transform: translateY(-4px) scale(1.03);
            box-shadow: 0 10px 15px -3px rgb(139 92 246 / 0.15), 0 4px 6px -4px rgb(139 92 246 / 0.1);
        }
        .mood-selector label:hover .mood-card {
            border-color: #c4b5fd;
            background: #faf5ff;
        }
        .submit-mood-btn:hover {
            background: #7c3aed !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 8px -1px rgb(139 92 246 / 0.4) !important;
        }
    </style>
{% endblock %}