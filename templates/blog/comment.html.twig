<div style="margin-left: {{ comment.parent_id ? 40 : 0 }}px; border:1px solid #ccc; padding:10px; margin-top:10px">

    <p><b>Commentaire :</b> {{ comment.content }}</p>

    <button onclick="showReply({{ comment.id }})">Reply</button>

    <button onclick="deleteComment({{ comment.id }})">Delete</button>

    <!-- FORM REPLY -->
    <div id="reply-form-{{ comment.id }}" style="display:none; margin-top:10px;">
        <textarea id="reply-content-{{ comment.id }}" placeholder="Votre réponse"></textarea><br>
        <button onclick="sendReply({{ comment.id }})">Envoyer</button>
    </div>

</div>