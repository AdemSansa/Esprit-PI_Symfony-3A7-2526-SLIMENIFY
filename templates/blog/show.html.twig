{% extends 'layout/app_shell.html.twig' %}

{% block title %}{{ blog.title }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .blog-layout-wrapper {
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 4rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        align-items: start;
    }
    @media (max-width: 1024px) {
        .blog-layout-wrapper {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }
    .article-main {
        min-width: 0; /* Prevents grid breakout */
    }
    .article-header {
        margin-bottom: 2rem;
    }
    .article-title {
        font-size: 2.8rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        color: #242424;
    }
    .article-author {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .author-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #757575;
    }
    .author-info {
        display: flex;
        flex-direction: column;
    }
    .author-name {
        font-weight: 600;
        color: #242424;
    }
    .article-meta {
        font-size: 0.9rem;
        color: #757575;
    }
    .article-image {
        width: 100%;
        max-height: 450px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 3rem;
    }
    .article-body {
        font-size: 1.25rem;
        line-height: 1.6;
        color: #242424;
        white-space: pre-line;
    }
    .article-interactions {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-top: 4rem;
        padding: 1.5rem 0;
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
    }
    /* Existing btn-interact styles */
    .btn-interact {
        display: flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        border: none;
        color: #757575;
        cursor: pointer;
        padding: 8px;
        border-radius: 20px;
        transition: background 0.2s, color 0.2s;
        font-size: 0.95rem;
    }
    .btn-interact:hover {
        background: #f2f2f2;
        color: #242424;
    }
    .btn-interact.is-active {
        color: #b2936a;
    }
    .blog-sidebar {
        position: sticky;
        top: 2rem;
    }
    .comments-section {
        margin-top: 0;
    }
    .comment-form {
        margin-bottom: 2.5rem;
        background: #fff;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        border: 1px solid #f0f0f0;
    }
    .comment-form .comment-input,
    .comment-form textarea {
        width: 100%;
        min-height: 100px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
        font-family: inherit;
        resize: vertical;
        font-size: 0.95rem;
    }
    .btn-comment {
        background: #627255;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 20px;
        font-weight: 600;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .comment-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .comment-item {
        padding: 1.25rem;
        background: #fcfcfc;
        border-radius: 10px;
        border: 1px solid #f1f5f9;
    }
    .comment-author-info {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.75rem;
    }
    .comment-content {
        color: #242424;
        line-height: 1.5;
        white-space: pre-wrap;
        font-size: 0.95rem;
    }
    .comment-actions {
        display: flex;
        gap: 0.4rem;
        align-items: center;
    }
    .meta-item {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #555;
        font-size: 14px;
    }
    .fav-btn {
        background: none;
        border: none;
        cursor: pointer;
    }
    .heart {
        transition: all 0.2s ease;
    }
    .heart.active {
        color: red;
        transform: scale(1.2);
    }
    /* Star Rating Styles */
    .star-rating-container {
        display: flex;
        gap: 5px;
        margin-bottom: 15px;
        align-items: center;
    }
    .star-rating-input-wrapper {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }
    .star-rating-input-wrapper input {
        display: none;
    }
    .star-rating-input-wrapper label {
        cursor: pointer;
        color: #e2e8f0;
        font-size: 1.5rem;
        transition: color 0.2s ease, transform 0.2s ease;
        padding: 0 2px;
    }
    .star-rating-input-wrapper label:hover,
    .star-rating-input-wrapper label:hover ~ label,
    .star-rating-input-wrapper input:checked ~ label {
        color: #ffb400; /* Amazon-like gold */
    }
    .star-rating-input-wrapper label:hover {
        transform: scale(1.2);
    }
    .star-display {
        color: #ffb400;
        display: inline-flex;
        gap: 2px;
        margin-bottom: 5px;
    }
    .star-display svg {
        width: 16px;
        height: 16px;
    }
    .star-display .star-muted {
        color: #cbd5e1;
    }
</style>
{% endblock %}

{% block app_content %}
<div class="blog-layout-wrapper">
    <article class="article-main">
        <header class="article-header">
            <h1 class="article-title">{{ blog.title }}</h1>
            <div class="article-author">
                <div class="author-avatar">
                    {{ blog.therapist.firstName|first|upper }}
                </div>
                <div class="author-info">
                    <span class="author-name">{{ blog.therapist.firstName }} {{ blog.therapist.lastName }}</span>
                    <span class="article-meta">
                        {{ blog.createdAt|date('M d, Y') }} · 5 min read
                        {% if blog.category %}
                            · <span style="color: #627255; font-weight: 600;">{{ blog.category.name }}</span>
                        {% endif %}
                    </span>
                </div>
            </div>
        </header>

        {% if blog.photo %}
            <img src="{{ asset('uploads/blogs/' ~ blog.photo) }}" class="article-image" alt="Article Cover">
        {% else %}
            <div class="article-image" style="background: #f8fafc; border-radius: 8px; margin-bottom: 3rem; height: 300px; display: flex; align-items: center; justify-content: center; color: #94a3b8; border: 1px solid #e2e8f0;">
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
        {% endif %}

        <div class="article-body">
            {{ blog.content }}
        </div>

        <div class="article-interactions">
            {% if not is_granted('ROLE_ADMIN') %}
                {% set userLiked = false %}
                {% if app.user %}
                    {% for like in blog.likes %}
                        {% if (like.user and like.user is same as(app.user)) or (like.therapist and like.therapist.email == app.user.userIdentifier) %}
                            {% set userLiked = true %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                <button type="button" id="likeBtn" class="btn-interact {{ userLiked ? 'is-active' : '' }}" onclick="toggleLike()">
                    <svg width="24" height="24" viewBox="0 0 24 24"
                         fill="{{ userLiked ? 'currentColor' : 'none' }}"
                         stroke="currentColor" stroke-width="2">
                        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
                    </svg>
                    <span id="likeCount">{{ blog.likes|length }}</span>
                </button>
            {% else %}
                <span class="btn-interact" style="cursor: default;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
                    </svg>
                    {{ blog.likes|length }}
                </span>
            {% endif %}

            <span class="btn-interact" style="cursor: default;">
                <svg width="24" height="24" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
                </svg>
                {{ blog.comments|length }}
            </span>

            {% if not is_granted('ROLE_ADMIN') %}
                {% set isFav = false %}
                {% if app.user %}
                    {% for fav in blog.favorites %}
                        {% if fav.user and fav.user is same as(app.user) %}
                            {% set isFav = true %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                <button class="meta-item fav-btn" data-id="{{ blog.id }}">
                    <svg class="heart {% if isFav %}active{% endif %}"
                         width="18" height="18"
                         viewBox="0 0 24 24"
                         fill="{% if isFav %}red{% else %}none{% endif %}"
                         stroke="currentColor"
                         stroke-width="2">
                        <path d="M20.8 4.6c-1.8-1.7-4.6-1.7-6.4 0L12 6.9 9.6 4.6c-1.8-1.7-4.6-1.7-6.4 0-1.9 1.8-1.9 4.8 0 6.6L12 21l8.8-9.8c1.9-1.8 1.9-4.8 0-6.6z"/>
                    </svg>
                    <span>Favoris</span>
                </button>
            {% endif %}
        </div>
    </article>

    <aside class="blog-sidebar">
        <section class="comments-section" id="comments">
            <h3 style="margin-bottom: 2rem; font-size: 1.25rem; font-weight: 700;">Comments ({{ blog.comments|length }})</h3>
            
            {% if is_granted('ROLE_USER') and not (is_granted('ROLE_ADMIN') or is_granted('ROLE_THERAPIST')) %}
                {% if not editingCommentId %}
                    <div class="comment-form">
                        {{ form_start(commentForm) }}
                            {{ form_errors(commentForm) }}
                            {{ form_row(commentForm.content, {
                                label: false,
                                required: false,
                                attr: { class: 'comment-input', placeholder: 'What are your thoughts?' }
                            }) }}
                            <div class="star-rating-container">
                                <span style="font-size: 0.9rem; color: #757575; font-weight: 600;">Rating:</span>
                                <div class="star-rating-input-wrapper">
                                    <input type="radio" id="star5" name="rating_stars" value="5" /><label for="star5" title="5 stars">★</label>
                                    <input type="radio" id="star4" name="rating_stars" value="4" /><label for="star4" title="4 stars">★</label>
                                    <input type="radio" id="star3" name="rating_stars" value="3" /><label for="star3" title="3 stars">★</label>
                                    <input type="radio" id="star2" name="rating_stars" value="2" /><label for="star2" title="2 stars">★</label>
                                    <input type="radio" id="star1" name="rating_stars" value="1" /><label for="star1" title="1 star">★</label>
                                </div>
                                {{ form_widget(commentForm.rating, { attr: { style: 'display:none', class: 'rating-hidden-input' } }) }}
                            </div>
                            <div style="display: flex; justify-content: flex-end;">
                                <button type="submit" class="btn-comment">Respond</button>
                            </div>
                        {{ form_end(commentForm) }}
                    </div>
                {% else %}
                    <p style="color: #757575; margin-bottom: 1.5rem; font-size: 0.9rem;">
                        <a href="{{ path('app_blog_web_show', { id: blog.id }) }}#comments">Cancel editing</a> to write a new comment.
                    </p>
                {% endif %}
            {% else %}
                <p style="color: #757575; font-size: 0.9rem; margin-bottom: 2rem;">
                    Please <a href="{{ path('app_login') }}">login</a> to leave a comment.
                </p>
            {% endif %}

            <div class="comment-list">
                {% for comment in blog.comments|reverse %}
                    {% set isAuthor = app.user and ((comment.user and comment.user is same as(app.user)) or (comment.therapist and comment.therapist.email == app.user.userIdentifier)) %}
                    <div class="comment-item" id="comment-{{ comment.id }}">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                            <div class="comment-author-info">
                                <div style="width: 32px; height: 32px; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: bold;">
                                    {% if comment.user %}
                                        {{ comment.user.firstName|first }}
                                    {% else %}
                                        {{ comment.therapist.firstName|first }}
                                    {% endif %}
                                </div>
                                <div style="display: flex; flex-direction: column;">
                                    <span style="font-size: 0.85rem; font-weight: 600;">
                                        {% if comment.user %}
                                            {{ comment.user.firstName }} {{ comment.user.lastName }}
                                        {% else %}
                                            {{ comment.therapist.firstName }} {{ comment.therapist.lastName }}
                                        {% endif %}
                                    </span>
                                    <span style="font-size: 0.7rem; color: #757575;">{{ comment.createdAt|date('M d, Y') }}</span>
                                </div>
                            </div>
                            {% if app.user and (isAuthor or is_granted('ROLE_ADMIN')) %}
                                <div class="comment-actions">
                                    <a href="{{ path('app_blog_web_show', { id: blog.id, editComment: comment.id }) }}#comment-{{ comment.id }}" class="btn-interact" style="padding: 4px 8px; font-size: 0.75rem; text-decoration: none;">Edit</a>
                                    <form method="post" action="{{ path('app_blog_comment_delete', { blogId: blog.id, commentId: comment.id }) }}" onsubmit="return confirm('Delete this comment?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_comment' ~ comment.id) }}">
                                        <button type="submit" class="btn-interact" style="padding: 4px 8px; font-size: 0.75rem; color: #ef4444;">Delete</button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>

                        {% if editCommentForm and editingCommentId == comment.id %}
                            <div class="comment-form" style="margin-top: 0.75rem;">
                                {{ form_start(editCommentForm) }}
                                    {{ form_errors(editCommentForm) }}
                                    {{ form_row(editCommentForm.content, {
                                        label: false,
                                        required: false,
                                        attr: { class: 'comment-input', rows: 4 }
                                    }) }}
                                    <div style="display: flex; gap: 0.5rem; justify-content: flex-end; align-items: center;">
                                        <a href="{{ path('app_blog_web_show', { id: blog.id }) }}#comment-{{ comment.id }}" class="btn-interact" style="text-decoration: none; padding: 6px 12px; font-size: 0.8rem;">Cancel</a>
                                        <button type="submit" class="btn-comment" style="padding: 8px 16px;">Save</button>
                                    </div>
                                {{ form_end(editCommentForm) }}
                            </div>
                        {% else %}
                            {% if comment.rating %}
                                <div class="star-display">
                                    {% for i in 1..5 %}
                                        {% if i <= comment.rating %}
                                            <svg viewBox="0 0 24 24" fill="currentColor">
                                                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                            </svg>
                                        {% else %}
                                            <svg viewBox="0 0 24 24" fill="currentColor" class="star-muted">
                                                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                            </svg>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <div class="comment-content">
                                {{ comment.content }}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </section>
    </aside>
</div>

<script>
async function toggleLike() {
    try {
        const response = await fetch('{{ path('api_blog_like', {id: blog.id}) }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();

        if (data.count !== undefined) {
            document.getElementById('likeCount').innerText = data.count;
            const btn = document.getElementById('likeBtn');
            const svg = btn.querySelector('svg');

            if (data.liked) {
                btn.classList.add('is-active');
                svg.setAttribute('fill', 'currentColor');
            } else {
                btn.classList.remove('is-active');
                svg.setAttribute('fill', 'none');
            }
        }
    } catch (e) {
        console.error("Like failed", e);
    }
}

document.querySelectorAll('.fav-btn').forEach(btn => {
    btn.addEventListener('click', function (e) {
        e.preventDefault();
        const id = this.dataset.id;
        const heart = this.querySelector('.heart');

        fetch('/api/interactive/blog/' + id + '/favorite', {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.favorited) {
                heart.classList.add('active');
                heart.setAttribute('fill', 'red');
            } else {
                heart.classList.remove('active');
                heart.setAttribute('fill', 'none');
            }
        })
        .catch(err => console.error('Error toggling favorite:', err));
    });
});

// Star Rating Interaction
document.querySelectorAll('input[name="rating_stars"]').forEach(input => {
    input.addEventListener('change', function() {
        const wrapper = this.closest('.comment-form');
        const hiddenInput = wrapper.querySelector('.rating-hidden-input');
        if (hiddenInput) {
            hiddenInput.value = this.value;
        }
    });
});
</script>
{% endblock %}
