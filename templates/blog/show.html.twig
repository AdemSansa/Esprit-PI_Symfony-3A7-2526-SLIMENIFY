{% extends 'layout/app_shell.html.twig' %}

{% block title %}{{ blog.title }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .article-container {
        max-width: 720px;
        margin: 0 auto;
        padding-top: 2rem;
    }
    .article-header {
        margin-bottom: 2rem;
    }
    .article-title {
        font-size: 2.8rem;
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.04em;
        margin-bottom: 1.5rem;
        color: #242424;
    }
    .article-author {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }
    .author-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: #757575;
    }
    .author-info {
        display: flex;
        flex-direction: column;
    }
    .author-name {
        font-weight: 600;
        color: #242424;
    }
    .article-meta {
        font-size: 0.9rem;
        color: #757575;
    }
    .article-image {
        width: 100%;
        max-height: 450px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 3rem;
    }
    .article-body {
        font-size: 1.25rem;
        line-height: 1.6;
        color: #242424;
        white-space: pre-line;
    }
    .article-interactions {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-top: 4rem;
        padding: 1.5rem 0;
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
    }
    .btn-interact {
        display: flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        border: none;
        color: #757575;
        cursor: pointer;
        padding: 8px;
        border-radius: 20px;
        transition: background 0.2s, color 0.2s;
        font-size: 0.95rem;
    }
    .btn-interact:hover {
        background: #f2f2f2;
        color: #242424;
    }
    .btn-interact.is-active {
        color: #b2936a;
    }
    .comments-section {
        margin-top: 3rem;
    }
    .comment-form {
        margin-bottom: 3rem;
        background: #fff;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    }
    .comment-form .comment-input,
    .comment-form textarea {
        width: 100%;
        min-height: 100px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
        font-family: inherit;
        resize: vertical;
    }
    .btn-comment {
        background: #627255;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 20px;
        font-weight: 600;
        cursor: pointer;
    }
    .comment-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    .comment-item {
        padding-bottom: 2rem;
        border-bottom: 1px solid #f1f5f9;
    }
    .comment-author-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }
    .comment-content {
        color: #242424;
        line-height: 1.5;
        white-space: pre-wrap;
    }
    .comment-actions {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }
    .comment-actions form {
        margin: 0;
    }
</style>
{% endblock %}

{% block app_content %}
<article class="article-container">
    <header class="article-header">
        <h1 class="article-title">{{ blog.title }}</h1>
        <div class="article-author">
            <div class="author-avatar">
                {{ blog.therapist.firstName|first|upper }}
            </div>
            <div class="author-info">
                <span class="author-name">{{ blog.therapist.firstName }} {{ blog.therapist.lastName }}</span>
                <span class="article-meta">{{ blog.createdAt|date('M d, Y') }} · 5 min read</span>
            </div>
        </div>
    </header>

    <img src="{{ asset('uploads/blogs/' ~ blog.photo) }}" class="article-image" alt="Article Cover">

    <div class="article-body">
        {{ blog.content }}
    </div>

    <div class="article-interactions">
        {% set userLiked = false %}
        {% if app.user %}
            {% for like in blog.likes %}
                {% if (like.user and like.user is same as(app.user)) or (like.therapist and like.therapist.email == app.user.userIdentifier) %}
                    {% set userLiked = true %}
                {% endif %}
            {% endfor %}
        {% endif %}

        <button type="button" id="likeBtn" class="btn-interact {{ userLiked ? 'is-active' : '' }}" onclick="toggleLike()">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="{{ userLiked ? 'currentColor' : 'none' }}" stroke="currentColor" stroke-width="2">
                <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
            </svg>
            <span id="likeCount">{{ blog.likes|length }}</span>
        </button>

        <span class="btn-interact" style="cursor: default;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            {{ blog.comments|length }}
        </span>
    </div>

    <section class="comments-section" id="comments">
        <h3 style="margin-bottom: 1.5rem;">Comments ({{ blog.comments|length }})</h3>

        {% if app.user and not editingCommentId %}
            <div class="comment-form">
                {{ form_start(commentForm) }}
                    {{ form_errors(commentForm) }}
                    {{ form_row(commentForm.content, {
                        label: false,
                        attr: { class: 'comment-input', placeholder: 'What are your thoughts?' }
                    }) }}
                    <div style="display: flex; justify-content: flex-end;">
                        <button type="submit" class="btn-comment">Respond</button>
                    </div>
                {{ form_end(commentForm) }}
            </div>
        {% elseif app.user and editingCommentId %}
            <p style="color: #757575; margin-bottom: 1.5rem;"><a href="{{ path('app_blog_web_show', { id: blog.id }) }}#comments">Cancel editing</a> to write a new comment.</p>
        {% else %}
            <p style="color: #757575;">Please <a href="{{ path('app_login') }}">login</a> to leave a comment.</p>
        {% endif %}

        <div class="comment-list">
            {% for comment in blog.comments|reverse %}
                {% set isAuthor = app.user and ((comment.user and comment.user is same as(app.user)) or (comment.therapist and comment.therapist.email == app.user.userIdentifier)) %}
                <div class="comment-item" id="comment-{{ comment.id }}">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                        <div class="comment-author-info">
                            <div style="width: 32px; height: 32px; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: bold;">
                                {% if comment.user %}
                                    {{ comment.user.firstName|first }}
                                {% else %}
                                    {{ comment.therapist.firstName|first }}
                                {% endif %}
                            </div>
                            <div style="display: flex; flex-direction: column;">
                                <span style="font-size: 0.9rem; font-weight: 600;">
                                    {% if comment.user %}
                                        {{ comment.user.firstName }} {{ comment.user.lastName }}
                                    {% else %}
                                        {{ comment.therapist.firstName }} {{ comment.therapist.lastName }}
                                    {% endif %}
                                </span>
                                <span style="font-size: 0.75rem; color: #757575;">{{ comment.createdAt|date('M d, Y') }}</span>
                            </div>
                        </div>
                        {% if app.user and (isAuthor or is_granted('ROLE_ADMIN')) %}
                            <div class="comment-actions">
                                <a href="{{ path('app_blog_web_show', { id: blog.id, editComment: comment.id }) }}#comment-{{ comment.id }}" class="btn-interact" style="padding: 4px 10px; font-size: 0.8rem; text-decoration: none;">
                                    Edit
                                </a>
                                <form method="post"
                                      action="{{ path('app_blog_comment_delete', { blogId: blog.id, commentId: comment.id }) }}"
                                      onsubmit="return confirm('Delete this comment?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_comment' ~ comment.id) }}">
                                    <button type="submit" class="btn-interact" style="padding: 4px 10px; font-size: 0.8rem; color: #ef4444;">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    </div>

                    {% if editCommentForm and editingCommentId == comment.id %}
                        <div class="comment-form" style="margin-top: 0.75rem;">
                            {{ form_start(editCommentForm) }}
                                {{ form_errors(editCommentForm) }}
                                {{ form_row(editCommentForm.content, {
                                    label: false,
                                    attr: { class: 'comment-input', rows: 6 }
                                }) }}
                                <div style="display: flex; gap: 0.5rem; justify-content: flex-end; align-items: center;">
                                    <a href="{{ path('app_blog_web_show', { id: blog.id }) }}#comment-{{ comment.id }}" class="btn-interact" style="text-decoration: none; padding: 8px 14px;">Cancel</a>
                                    <button type="submit" class="btn-comment">Save</button>
                                </div>
                            {{ form_end(editCommentForm) }}
                        </div>
                    {% else %}
                        <div class="comment-content">
                            {{ comment.content }}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </section>
</article>

<script>
async function toggleLike() {
    try {
        const response = await fetch('{{ path('api_blog_like', {id: blog.id}) }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        const data = await response.json();

        if (data.count !== undefined) {
            document.getElementById('likeCount').innerText = data.count;
            const btn = document.getElementById('likeBtn');
            const svg = btn.querySelector('svg');

            if (data.liked) {
                btn.classList.add('is-active');
                svg.setAttribute('fill', 'currentColor');
            } else {
                btn.classList.remove('is-active');
                svg.setAttribute('fill', 'none');
            }
        }
    } catch (e) {
        console.error("Like failed", e);
    }
}
</script>
{% endblock %}
