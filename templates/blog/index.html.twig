{% extends 'layout/app_shell.html.twig' %}

{% block title %}Explore Blogs{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .blog-feed {
        display: flex;
        flex-direction: column;
        gap: 3rem;
        padding: 2rem 0;
    }
    .blog-card {
        display: grid;
        grid-template-columns: 1fr 200px;
        gap: 2rem;
        align-items: flex-start;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding-bottom: 2rem;
    }
    .blog-card:hover {
        transform: translateY(-2px);
    }
    .blog-card__content {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .blog-card__meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.85rem;
        color: #757575;
    }
    .blog-card__author {
        font-weight: 600;
        color: #242424;
    }
    .blog-card__title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #242424;
        line-height: 1.2;
        margin: 0.25rem 0;
    }
    .blog-card__excerpt {
        font-size: 1rem;
        color: #757575;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.5;
    }
    .blog-card__footer {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-top: 1rem;
        font-size: 0.85rem;
        color: #757575;
    }
    .blog-card__image {
        width: 100%;
        aspect-ratio: 4/3;
        object-fit: cover;
        border-radius: 4px;
        background: #f0f0f0;
    }
    .badge-premium {
        background: #f2f2f2;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.75rem;
    }
    .icon-inline {
        vertical-align: middle;
        margin-right: 4px;
    }
</style>
{% endblock %}

{% block app_content %}
<div class="blog-header" style="margin-bottom: 3rem;">
    <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em;">Human stories & ideas</h1>
    <p style="color: #757575; font-size: 1.1rem;">A place to read, write, and deepen your understanding.</p>
</div>

<div class="blog-feed">
    {% for blog in blogs %}
        <a href="{{ path('app_blog_web_show', {id: blog.id}) }}" class="blog-card">
            <div class="blog-card__content">
                <div class="blog-card__meta">
                    <span class="blog-card__author">
                        {{ blog.therapist.firstName }} {{ blog.therapist.lastName }}
                    </span>
                    <span>·</span>
                    <span>{{ blog.createdAt|date('M d, Y') }}</span>
                    {% if loop.index < 3 %}
                        <span class="badge-premium">Featured</span>
                    {% endif %}
                </div>
                <h2 class="blog-card__title">{{ blog.title }}</h2>
                <div class="blog-card__excerpt">{{ blog.content }}</div>
                <div class="blog-card__footer">
                    <span>
                        <svg class="icon-inline" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
                        {{ blog.likes|length }}
                    </span>
                    <span>
                        <svg class="icon-inline" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                        Comments
                    </span>
                </div>
            </div>
            <div class="blog-card__visual">
                <img src="{{ asset('uploads/blogs/' ~ blog.photo) }}" class="blog-card__image" alt="Article image">
            </div>
        </a>
    {% else %}
        <div style="text-align: center; padding: 4rem; color: #757575;">
            <p>No stories found yet. Be the first to share your thoughts!</p>
        </div>
    {% endfor %}
</div>
{% endblock %}
