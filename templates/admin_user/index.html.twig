{% extends 'layout/app_shell.html.twig' %}

{% block title %}User Management{% endblock %}

{% block app_content %}
<style>
    .admin-wrapper {
        background-color: transparent;
        padding: 0px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .top-header-card {
        background: #fff;
        border-radius: 12px;
        padding: 20px 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }
    .top-header-card h2 {
        color: #7A5B49;
        margin: 0;
        font-weight: bold;
    }
    .btn-brown {
        background: linear-gradient(135deg, #7A5B49, #B8977E);
        color: white;
        border: none;
        border-radius: 20px;
        padding: 8px 24px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }
    .btn-brown:hover {
        opacity: 0.9;
        color: white;
    }
    
    .main-card {
        background: #fff;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    
    .toolbar {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
    }
    .search-input {
        border: 1px solid #D2C4B7;
        border-radius: 20px;
        padding: 8px 18px;
        width: 350px;
        color: #7A5B49;
        outline: none;
    }
    
    .btn-outline-brown {
        border: 2px solid #A8866E;
        color: #A8866E;
        background: transparent;
        border-radius: 20px;
        padding: 6px 20px;
        font-weight: 600;
        margin-left: 10px;
        cursor: pointer;
    }
    .btn-outline-brown:hover:not(:disabled) {
        background: #A8866E;
        color: white;
    }
    .btn-outline-red {
        border: 2px solid #D9534F;
        color: #D9534F;
        background: transparent;
        border-radius: 20px;
        padding: 6px 20px;
        font-weight: 600;
        margin-left: 10px;
        cursor: pointer;
    }
    .btn-outline-red:hover:not(:disabled) {
        background: #D9534F;
        color: white;
    }
    
    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    .admin-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }
    .admin-table th {
        background: linear-gradient(180deg, #F9F7F3, #EBE6DF);
        color: #5d4a3e;
        padding: 12px 15px;
        font-weight: bold;
        border-bottom: 2px solid #D2C4B7;
        text-align: left;
    }
    .admin-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #F0EEEA;
        color: #5A5A5A;
        cursor: pointer;
    }
    .admin-table tbody tr {
        transition: background-color 0.2s;
    }
    .admin-table tbody tr:hover {
        background-color: #FBF8F6;
    }
    .admin-table tbody tr.selected {
        background-color: #E6DFD7 !important;
        font-weight: 500;
    }
    .hidden-delete-form {
        display: none;
    }
</style>

<div class="admin-wrapper">
    
    <div class="top-header-card">
        <h2>User Management</h2>
        <a href="{{ path('app_admin_user_new') }}" class="btn-brown">+ Add New User</a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success mt-2 mb-3" style="border-radius: 12px;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="main-card">
        <div class="toolbar">
            <form id="searchForm" method="GET" action="{{ path('app_admin_user_index') }}" style="display: flex; gap: 15px; align-items: center; flex: 1;">
                <input type="text" name="q" class="search-input" placeholder="Search users by name or email..." value="{{ searchQuery }}">
                <select name="role" class="search-input" style="width: 150px; appearance: auto; cursor: pointer;">
                    <option value="">All Roles</option>
                    <option value="patient" {% if roleFilter == 'patient' %}selected{% endif %}>Patient</option>
                    <option value="therapist" {% if roleFilter == 'therapist' %}selected{% endif %}>Therapist</option>
                    <option value="admin" {% if roleFilter == 'admin' %}selected{% endif %}>Admin</option>
                </select>
                <button type="submit" style="display:none;">Search</button>
            </form>
            <div>
                <button class="btn-outline-brown" id="btnEditSelected" disabled>Edit Selected</button>
                <button class="btn-outline-red" id="btnDeleteSelected" disabled>Delete Selected</button>
            </div>
        </div>

        <div style="overflow-x: auto;" id="tableContainer">
            <table class="admin-table" id="usersTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for u in users %}
                    <tr data-id="{{ u.id }}" class="user-row">
                        <td>{{ u.id }}</td>
                        <td>{{ u.firstName }} {{ u.lastName }}</td>
                        <td>{{ u.email }}</td>
                        <td>{{ u.role }}</td>
                        <td>
                            <a href="{{ path('app_admin_user_show', {'id': u.id}) }}" style="color: #7A5B49; text-decoration: none;">View</a>
                            
                            {# Hidden delete form for each user #}
                            <div class="hidden-delete-form">
                                {{ include('admin_user/_delete_form.html.twig', {'user': u}, with_context = false) }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center p-4">No users found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            <div style="margin-top: 20px; display: flex; justify-content: center;">
                {{ knp_pagination_render(users) }}
            </div>
        </div>
    </div>
</div>

<script>
    function setupAdminTable() {
        const rows = document.querySelectorAll('.user-row');
        const btnEdit = document.getElementById('btnEditSelected');
        const btnDelete = document.getElementById('btnDeleteSelected');
        let selectedUserId = null;
        let selectedRow = null;

        if (!btnEdit || !btnDelete) return;

        rows.forEach(row => {
            row.addEventListener('click', function(e) {
                // Ignore clicks on links directly
                if(e.target.tagName.toLowerCase() === 'a') return;

                // Deselect all
                rows.forEach(r => r.classList.remove('selected'));
                
                // Select current
                this.classList.add('selected');
                selectedUserId = this.getAttribute('data-id');
                selectedRow = this;
                
                btnEdit.disabled = false;
                btnDelete.disabled = false;
            });
        });

        btnEdit.addEventListener('click', function() {
            if (selectedUserId && !this.disabled) {
                window.location.href = '/admin/users/' + selectedUserId + '/edit';
            }
        });

        btnDelete.addEventListener('click', function() {
            if (selectedRow && !this.disabled) {
                const form = selectedRow.querySelector('form');
                if (form) {
                    if (confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?')) {
                        form.submit();
                    }
                }
            }
        });
        
        // (The backend search using PHP query parameters naturally handles filtering)
    }

    document.addEventListener('DOMContentLoaded', () => {
        setupAdminTable();

        const form = document.getElementById('searchForm');
        const tableBody = document.querySelector('#usersTable tbody');
        let timeout = null;

        if (form && tableBody) {
            form.addEventListener('input', () => {
                clearTimeout(timeout);
                timeout = setTimeout(() => {
                    const url = new URL(form.action || window.location.href);
                    const formData = new FormData(form);
                    const searchParams = new URLSearchParams(formData);
                    // Remove page param when searching to start from page 1
                    searchParams.delete('page');
                    url.search = searchParams.toString();

                    fetch(url, { headers: {'X-Requested-With': 'XMLHttpRequest'} })
                        .then(response => response.text())
                        .then(html => {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const newContainer = doc.getElementById('tableContainer');
                            
                            if (newContainer) {
                                const container = document.getElementById('tableContainer');
                                container.innerHTML = newContainer.innerHTML;
                                setupAdminTable(); // Re-bind events to new rows
                            }
                            window.history.pushState({}, '', url);
                        });
                }, 300); // 300ms debounce to avoid spamming the database
            });
        }
    });

    document.addEventListener('turbo:load', setupAdminTable);
</script>
{% endblock %}
