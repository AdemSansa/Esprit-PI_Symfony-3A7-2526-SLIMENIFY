{% extends 'layout/app_shell.html.twig' %}

{% block title %}User Profile - {{ user.firstName }} {{ user.lastName }}{% endblock %}

{% block app_content %}
<style>
    .profile-wrapper {
        max-width: 850px;
        margin: 0 auto;
        animation: fadeIn 0.5s ease;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .profile-card {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(122, 91, 73, 0.08);
        border: 1px solid rgba(122, 91, 73, 0.05);
        position: relative;
    }

    .profile-banner {
        height: 110px;
        background: linear-gradient(135deg, #A8866E, #F6F3E6);
        position: relative;
        z-index: 1;
    }

    .btn-back-container {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 10;
    }

    .btn-back {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(4px);
        color: #7A5B49;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 15px;
        border-radius: 30px;
        transition: all 0.2s;
    }

    .btn-back:hover {
        background: #fff;
        color: #5D4A3E;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .profile-header-content {
        display: flex;
        align-items: flex-end;
        padding: 0 40px;
        margin-top: -55px;
        margin-bottom: 25px;
        position: relative;
        z-index: 10;
    }

    .profile-avatar-wrapper {
        border: 5px solid #fff;
        border-radius: 50%;
        background: #F6F3E6;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        overflow: hidden;
        flex-shrink: 0;
        width: 130px;
        height: 130px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .profile-avatar-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-icon {
        width: 60px;
        height: 60px;
        color: #A8866E;
    }

    .profile-title {
        margin-left: 25px;
        margin-bottom: 10px;
    }

    .profile-name {
        color: #5D4A3E;
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0 0 5px 0;
    }

    .role-badge {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: #EBE6DF;
        color: #7A5B49;
    }

    .role-badge.admin {
        background: #FAD1D0;
        color: #D9534F;
    }

    .role-badge.therapist {
        background: #D4E1E6;
        color: #4A8399;
    }

    .profile-body {
        padding: 0 40px 40px 40px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 25px;
        margin-top: 20px;
    }

    .info-item {
        background: #FDFDFD;
        border: 1px solid #F0EEEA;
        padding: 15px 20px;
        border-radius: 12px;
    }

    .info-label {
        font-size: 0.8rem;
        color: #A8866E;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .info-value {
        font-size: 1.05rem;
        color: #4A4A4A;
        font-weight: 600;
        word-break: break-word;
    }

    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 35px;
        padding-top: 20px;
        border-top: 1px solid #F0EEEA;
    }

    .btn-edit {
        background: #F6F3E6;
        color: #A8866E;
        border: 2px solid transparent;
        border-radius: 20px;
        padding: 8px 25px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-edit:hover {
        background: #A8866E;
        color: white;
    }

    .delete-form form button {
        background: transparent;
        color: #D9534F;
        border: 2px solid #D9534F;
        border-radius: 20px;
        padding: 8px 25px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
    }
    
    .delete-form form button:hover {
        background: #D9534F;
        color: white;
    }
</style>

<div class="profile-wrapper">
    <div class="profile-card">
        
        <div class="profile-banner">
            <div class="btn-back-container">
                <a href="{{ path('app_admin_user_index') }}" class="btn-back">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    Back to Directory
                </a>
            </div>
        </div>

        <div class="profile-header-content">
            <div class="profile-avatar-wrapper">
                {% if user.photoUrl %}
                    <img src="{{ user.photoUrl }}" alt="Profile Photo">
                {% else %}
                    <svg class="avatar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                {% endif %}
            </div>
            <div class="profile-title">
                <h2 class="profile-name">{{ user.firstName }} {{ user.lastName }}</h2>
                <div class="role-badge {% if user.role == 'admin' %}admin{% elseif user.role == 'therapist' %}therapist{% endif %}">
                    {{ user.role|capitalize }}
                </div>
            </div>
        </div>

        <div class="profile-body">
            
            <h4 style="color: #7A5B49; font-weight: 700; margin-bottom: 5px; font-size: 1.1rem;">Personal Information</h4>
            <div style="height: 2px; width: 40px; background: #A8866E; margin-bottom: 20px;"></div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Email Address</div>
                    <div class="info-value">{{ user.email }}</div>
                </div>
                
                <div class="info-item">
                    <div class="info-label">Phone Number</div>
                    <div class="info-value">{{ user.phone ?: '<span style="color: #bbb; font-weight: normal; font-style: italic;">Not provided</span>'|raw }}</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Gender</div>
                    <div class="info-value">{{ user.gender ?: '<span style="color: #bbb; font-weight: normal; font-style: italic;">Not provided</span>'|raw }}</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Date of Birth</div>
                    <div class="info-value">{{ user.dateNaissance ? user.dateNaissance|date('F j, Y') : '<span style="color: #bbb; font-weight: normal; font-style: italic;">Not provided</span>'|raw }}</div>
                </div>
            </div>

            <h4 style="color: #7A5B49; font-weight: 700; margin-top: 40px; margin-bottom: 5px; font-size: 1.1rem;">System Information</h4>
            <div style="height: 2px; width: 40px; background: #A8866E; margin-bottom: 20px;"></div>

            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Account ID</div>
                    <div class="info-value">#{{ user.id }}</div>
                </div>

                <div class="info-item">
                    <div class="info-label">Account Status</div>
                    <div class="info-value">
                        {% if user.isVerified %}
                            <span style="color: #4CAF50;">Verified ✓</span>
                        {% else %}
                            <span style="color: #FF9800;">Pending Verification</span>
                        {% endif %}
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">Joined On</div>
                    <div class="info-value">{{ user.createdAt ? user.createdAt|date('F j, Y, g:i a') : '' }}</div>
                </div>
            </div>

            <div class="action-bar">
                <a href="{{ path('app_admin_user_edit', {'id': user.id}) }}" class="btn-edit">Edit Profile</a>
                
                <div class="delete-form">
                    {{ include('admin_user/_delete_form.html.twig') }}
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const deleteForms = document.querySelectorAll('form[action*="/admin/users/"]');
        deleteForms.forEach(f => {
            if(f.querySelector('button.btn')) {
                f.parentElement.classList.add('delete-form');
                const btn = f.querySelector('button');
                btn.className = '';
                btn.textContent = 'Drop User';
            }
        });
    });
</script>
{% endblock %}
