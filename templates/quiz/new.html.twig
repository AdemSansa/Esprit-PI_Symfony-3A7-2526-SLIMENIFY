{% extends 'layout/app_shell.html.twig' %}

{% block title %}New Quiz{% endblock %}

{% block app_content %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1 style="margin:0; font-size:2rem; font-weight: 800; color: #5D4A3E;">Create <span style="color: #A8866E; font-weight: 400;">New Quiz</span></h1>
        <a href="{{ path('app_quiz_index') }}" style="display: flex; align-items: center; gap: 0.5rem; color: #748764; text-decoration: none; font-weight: 600; padding: 0.6rem 1rem; background: rgba(116, 135, 100, 0.1); border-radius: 8px; transition: all 0.2s;" onmouseover="this.style.background='rgba(116, 135, 100, 0.2)'" onmouseout="this.style.background='rgba(116, 135, 100, 0.1)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            Back to list
        </a>
    </div>

    {{ include('quiz/_form.html.twig', {'button_label': 'Create Quiz'}) }}
{% endblock %}
