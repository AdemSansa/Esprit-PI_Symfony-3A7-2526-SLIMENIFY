<script>
    function confirmDelete(message) {
        return confirm(message);
    }
</script>
<form method="post" action="{{ path('app_quiz_delete', {'id': quiz.id}) }}" onsubmit="return confirmDelete('Are you sure you want to delete this quiz?');" style="margin: 0; display: inline-block;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
    <button class="btn-delete" style="background: rgba(220, 53, 69, 0.08); color: #DC3545; border: 1px solid rgba(220, 53, 69, 0.2); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; display: inline-flex; align-items: center; gap: 4px;" onmouseover="this.style.background='#DC3545'; this.style.color='white'" onmouseout="this.style.background='rgba(220, 53, 69, 0.08)'; this.style.color='#DC3545'">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
        Delete
    </button>
</form>
