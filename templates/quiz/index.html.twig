{% extends 'layout/app_shell.html.twig' %}

{% block title %}Quiz{% endblock %}

{% block app_content %}
    <h1 style="margin-top:0; font-size:1.75rem;">Quizzes</h1>
    {% if quizzes is empty %}
        <p style="color:#64748b;">No quizzes yet.</p>
    {% else %}
        <ul style="list-style:none; padding:0; margin:1rem 0 0;">
            {% for quiz in quizzes %}
                <li style="background:#fff; border-radius:10px; padding:1rem 1.25rem; margin-bottom:0.75rem; box-shadow:0 1px 3px rgba(0,0,0,.08);">
                    <strong>{{ quiz.title }}</strong>
                    {% if quiz.category %}
                        <span style="color:#64748b; font-size:0.9rem;"> — {{ quiz.category }}</span>
                    {% endif %}
                    {% if quiz.description %}
                        <p style="margin:0.5rem 0 0; color:#475569; font-size:0.95rem;">{{ quiz.description }}</p>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
