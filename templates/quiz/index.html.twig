{% extends 'layout/app_shell.html.twig' %}

{% block title %}Quiz{% endblock %}

{% block app_content %}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h1 style="margin:0; font-size:1.75rem;">Quizzes Management</h1>
        <a href="{{ path('app_quiz_new') }}" style="background: #3b82f6; color: white; padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; font-weight: 500; font-size: 0.95rem; box-shadow: 0 2px 4px rgba(59, 130, 246, 0.2);">
            + Create New Quiz
        </a>
    </div>

    {% if quizzes is empty %}
        <div style="background: #fff; padding: 3rem; text-align: center; border-radius: 12px; border: 1px dashed #cbd5e1;">
            <p style="color:#64748b; font-size: 1.1rem; margin-bottom: 1rem;">No quizzes have been created yet.</p>
            <a href="{{ path('app_quiz_new') }}" class="auth-link">Create your first quiz</a>
        </div>
    {% else %}
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
            {% for quiz in quizzes %}
                <div style="background:#fff; border-radius:12px; padding:1.5rem; box-shadow:0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -2px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; display: flex; flex-direction: column; transition: transform 0.2s ease, box-shadow 0.2s ease;" onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 10px 15px -3px rgba(0,0,0,0.05)'" onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -2px rgba(0,0,0,0.05)'">
                    
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                        <span style="background: {{ quiz.active ? '#dcfce7' : '#f1f5f9' }}; color: {{ quiz.active ? '#166534' : '#64748b' }}; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em;">
                            {{ quiz.active ? 'Active' : 'Inactive' }}
                        </span>
                        {% if quiz.category %}
                            <span style="background: #eff6ff; color: #2563eb; padding: 0.2rem 0.6rem; border-radius: 6px; font-weight: 500; font-size: 0.8rem;">
                                {{ quiz.category }}
                            </span>
                        {% endif %}
                    </div>

                    <h2 style="font-size: 1.25rem; font-weight: 600; color: #0f172a; margin: 0 0 0.5rem 0;">{{ quiz.title }}</h2>
                    
                    <p style="color: #64748b; font-size: 0.95rem; margin: 0 0 1.5rem 0; flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 3; -line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">
                        {{ quiz.description ?: 'No description provided.' }}
                    </p>

                    <div style="background: #f8fafc; border-radius: 8px; padding: 0.75rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-bottom: 1.25rem; text-align: center;">
                        <div>
                            <div style="font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Questions</div>
                            <div style="font-weight: 600; color: #334155;">{{ quiz.totalQuestions }}</div>
                        </div>
                        <div>
                            <div style="font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Min</div>
                            <div style="font-weight: 600; color: #334155;">{{ quiz.minScore }}</div>
                        </div>
                        <div>
                            <div style="font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em;">Max</div>
                            <div style="font-weight: 600; color: #334155;">{{ quiz.maxScore }}</div>
                        </div>
                    </div>

                    <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: auto; border-top: 1px solid #f1f5f9; padding-top: 1rem;">
                        <a href="{{ path('app_quiz_edit', {'id': quiz.id}) }}" style="background: white; color: #3b82f6; text-decoration: none; font-size: 0.85rem; padding: 0.4rem 0.75rem; border: 1px solid #bfdbfe; border-radius: 6px; font-weight: 500; transition: all 0.2s;" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='white'">Edit</a>
                        {{ include('quiz/_delete_form.html.twig', {'quiz': quiz}) }}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
