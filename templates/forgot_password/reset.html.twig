{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
<style>
    /* Styling for the new Login Template */
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f6f5ed url('{{ asset("psy.png") }}') top left repeat;
        background-size: auto; 
        padding: 2rem;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    }
    .login-card {
        display: flex;
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
        width: 100%;
        max-width: 500px;
    }
    .login-right {
        flex: 1;
        padding: 3rem; 
        background: #fafaf5; 
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .form-group {
        margin-bottom: 1.5rem;
    }
    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        font-weight: 500;
        color: #475569;
    }
    .form-input {
        width: 100%;
        padding: 0.65rem 0.9rem; 
        border: 1px solid #cbd5e1;
        border-radius: 10px; 
        font-size: 0.9rem; 
        outline: none;
        transition: all 0.2s;
        box-sizing: border-box;
    }
    .form-input:focus {
        border-color: #627255;
        box-shadow: 0 0 0 3px rgba(98, 114, 85, 0.08);
    }
    .btn-login {
        width: 100%;
        background: linear-gradient(135deg, #748764, #546549);
        color: white;
        padding: 0.75rem; 
        border-radius: 30px; 
        border: none;
        font-weight: 600;
        font-size: 0.95rem; 
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 10px -1px rgba(98, 114, 85, 0.2);
    }
    .btn-login:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 12px -2px rgba(98, 114, 85, 0.3);
    }
</style>

<main class="login-container">
    <div class="login-card" style="display: block;">
        <div class="login-right" style="border-left: none;">
            <div style="text-align: center; margin-bottom: 2rem;">
                 <h2 style="font-size: 1.75rem; font-weight: 700; color: #1e293b; margin: 0 0 0.25rem 0;">Nouveau mot de passe</h2>
                 <p style="color: #94a3b8; font-size: 0.85rem; margin: 0;">Saisissez votre nouveau mot de passe sécurisé.</p>
            </div>

            {% for message in app.flashes('error') %}
                <div style="background: #fef2f2; border: 1px solid #fecaca; color: #ef4444; padding: 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1.5rem;">
                    {{ message }}
                </div>
            {% endfor %}

            <form method="post">
                <div class="form-group">
                    <label class="form-label" for="inputPassword">Nouveau mot de passe</label>
                    <input type="password" name="password" id="inputPassword" class="form-input" required autofocus>
                </div>

                <div style="display:flex; justify-content: space-between; align-items:center; margin-top: 1rem;">
                    <a href="{{ path('app_login') }}" style="color: #64748b; text-decoration: none; font-size: 0.9rem;">Annuler</a>
                    <button class="btn-login" type="submit" style="width: auto; padding-left: 2rem; padding-right: 2rem;">
                        Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>
{% endblock %}
