{% extends 'layout/app_shell.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block app_content %}
<style>
    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }
    .profile-header h1 {
        font-size: 1.8rem;
        color: #5D4A3E;
        margin: 0;
    }
    .btn-edit {
        background: #687560;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 20px;
        font-weight: 700;
        text-decoration: none;
        transition: background 0.2s;
    }
    .btn-edit:hover {
        background: #4F5D44;
        color: white;
        text-decoration: none;
    }
    .profile-card {
        background: #fff;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(122, 91, 73, 0.08);
        border: 1px solid rgba(122, 91, 73, 0.05);
        display: flex;
        gap: 40px;
        align-items: flex-start;
    }
    .profile-sidebar {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        min-width: 200px;
    }
    .profile-avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #EAF0E4;
        margin-bottom: 15px;
    }
    .profile-name {
        font-size: 1.4rem;
        font-weight: 800;
        color: #5D4A3E;
        margin: 0;
    }
    .profile-role {
        font-size: 0.9rem;
        color: #A8866E;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        margin-top: 5px;
    }
    .profile-details {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        background: #F9F8F5;
        padding: 30px;
        border-radius: 12px;
        border: 1px solid #EAF0E4;
    }
    .detail-group {
        display: flex;
        flex-direction: column;
    }
    .detail-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        color: #A8866E;
        font-weight: 700;
        margin-bottom: 5px;
    }
    .detail-value {
        font-size: 1.1rem;
        color: #2D2D2D;
        font-weight: 600;
    }
    .flash-success {
        background: #EAF0E4;
        color: #4F5D44;
        padding: 15px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }
</style>

<div class="profile-header">
    <h1>Profile Overview</h1>
    <a href="{{ path('app_profile_edit') }}" class="btn-edit">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 5px; margin-bottom: -2px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
        Edit Information
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="flash-success">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        {{ message }}
    </div>
{% endfor %}

<div class="profile-card">
    <div class="profile-sidebar">
        {% if user.photoUrl %}
            <img src="{{ user.photoUrl }}" alt="Photo" class="profile-avatar">
        {% else %}
            <img src="https://ui-avatars.com/api/?name={{ user.firstName }}+{{ user.lastName }}&background=EAF0E4&color=4F5D44&size=150" alt="Avatar" class="profile-avatar">
        {% endif %}
        <h2 class="profile-name">{{ user.firstName }} {{ user.lastName }}</h2>
        <div class="profile-role">{{ user.role }}</div>
    </div>

    <div class="profile-details">
        <div class="detail-group">
            <span class="detail-label">Email Address</span>
            <span class="detail-value">{{ user.email }}</span>
        </div>
        <div class="detail-group">
            <span class="detail-label">Phone Number</span>
            <span class="detail-value">{{ user.phone ?: 'Not provided' }}</span>
        </div>
        <div class="detail-group">
            <span class="detail-label">Gender</span>
            <span class="detail-value">{{ user.gender ?: 'Not provided' }}</span>
        </div>
        <div class="detail-group">
            <span class="detail-label">Date of Birth</span>
            <span class="detail-value">{{ user.dateNaissance ? user.dateNaissance|date('d M Y') : 'Not provided' }}</span>
        </div>
        <div class="detail-group" style="grid-column: 1 / -1;">
            <span class="detail-label">Member Since</span>
            <span class="detail-value">{{ user.createdAt ? user.createdAt|date('d F Y') : 'Unknown' }}</span>
        </div>
    </div>
</div>
{% endblock %}
