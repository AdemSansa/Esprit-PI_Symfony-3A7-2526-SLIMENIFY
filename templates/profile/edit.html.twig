{% extends 'layout/app_shell.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block app_content %}
<style>
    .form-header {
        margin-bottom: 30px;
    }
    .form-header h1 {
        font-size: 1.8rem;
        color: #5D4A3E;
        margin: 0;
    }
    .form-card {
        background: #fff;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(122, 91, 73, 0.08);
        border: 1px solid rgba(122, 91, 73, 0.05);
        max-width: 600px;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #7A5B49;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .form-control {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #EBE6DF;
        border-radius: 8px;
        background-color: #FDFDFD;
        font-size: 1rem;
        color: #2D2D2D;
    }
    .form-control:focus {
        outline: none;
        border-color: #A8866E;
        box-shadow: 0 0 0 3px rgba(168, 134, 110, 0.1);
    }
    .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #F0EEEA;
    }
    .btn-cancel {
        background: #F0EEEA;
        color: #5D4A3E;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 700;
        text-decoration: none;
        transition: background 0.2s;
    }
    .btn-cancel:hover {
        background: #EBE6DF;
        color: #5D4A3E;
        text-decoration: none;
    }
    .btn-save {
        background: #687560;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s;
    }
    .btn-save:hover {
        background: #4F5D44;
    }
    
    /* Target Symfony Form Output directly */
    .form-card input, .form-card select, .form-card textarea {
        display: block;
        width: 100%;
        padding: 12px 14px;
        border: 1px solid #EBE6DF;
        border-radius: 8px;
        background-color: #FDFDFD;
        font-size: 1rem;
        color: #2D2D2D;
        box-sizing: border-box;
    }
    .form-card div {
        margin-bottom: 20px;
    }

    /* Gender Cards (copied from register) */
    .gender-cards-container {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
    }
    .gender-card {
        flex: 1;
        cursor: pointer;
        position: relative;
    }
    .gender-radio-input {
        position: absolute;
        opacity: 0;
        width: 0;
        height: 0;
    }
    .gender-card-content {
        border: 2px solid #EBE6DF;
        border-radius: 12px;
        padding: 1rem;
        text-align: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        color: #A8866E;
    }
    .gender-icon {
        width: 32px;
        height: 32px;
        margin: 0 auto 8px auto;
        display: block;
        stroke: currentColor;
        transition: all 0.3s ease;
    }
    .gender-label {
        display: block;
        font-weight: 700;
        font-size: 0.95rem;
    }
    .gender-card:hover .gender-card-content {
        border-color: #A8866E;
        transform: translateY(-2px);
        color: #A8866E;
    }
    .gender-radio-input:checked + .gender-card-content {
        border-color: #687560;
        color: #687560;
        box-shadow: 0 4px 15px rgba(104, 117, 96, 0.15);
        background: #FDFDFD;
        transform: translateY(-2px);
    }
    .form-group ul {
        color: #D9534F;
        list-style: none;
        padding: 0;
        margin-top: 8px;
        font-size: 0.9rem;
        font-weight: 600;
    }
</style>

<div class="form-header">
    <h1>Edit Profile</h1>
</div>

<div class="form-card">
    {{ form_start(form) }}
        
        <div style="color: #D9534F; font-size: 0.9rem; margin-bottom: 15px;">
            {{ form_errors(form) }}
        </div>

        <div class="form-group">
            {{ form_label(form.firstName) }}
            {{ form_widget(form.firstName) }}
            {{ form_errors(form.firstName) }}
        </div>
        
        <div class="form-group">
            {{ form_label(form.lastName) }}
            {{ form_widget(form.lastName) }}
            {{ form_errors(form.lastName) }}
        </div>

        <div class="form-group">
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email) }}
        </div>

        <div class="form-group">
            {{ form_label(form.phone) }}
            {{ form_widget(form.phone) }}
            {{ form_errors(form.phone) }}
        </div>

        <div class="form-group">
            {{ form_label(form.gender) }}
            <div class="gender-cards-container">
                {% for child in form.gender %}
                    <label class="gender-card">
                        {{ form_widget(child, {'attr': {'class': 'gender-radio-input'}}) }}
                        <div class="gender-card-content">
                            {% if child.vars.value == 'Male' %}
                                <svg class="gender-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="14" r="5"></circle><line x1="13.5" y1="10.5" x2="21" y2="3"></line><line x1="16" y1="3" x2="21" y2="3"></line><line x1="21" y1="3" x2="21" y2="8"></line></svg>
                            {% else %}
                                <svg class="gender-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="5"></circle><line x1="12" y1="15" x2="12" y2="22"></line><line x1="9" y1="19" x2="15" y2="19"></line></svg>
                            {% endif %}
                            <span class="gender-label">{{ child.vars.label }}</span>
                        </div>
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(form.gender) }}
        </div>

        <div class="form-group">
            {{ form_label(form.dateNaissance) }}
            {{ form_widget(form.dateNaissance) }}
            {{ form_errors(form.dateNaissance) }}
        </div>

        <div class="form-group">
            {{ form_label(form.photoUrl) }}
            {{ form_widget(form.photoUrl) }}
            {{ form_errors(form.photoUrl) }}
        </div>

        <div class="action-bar">
            <!-- Added reset password link next to Edit Profile actions -->
            <a href="{{ path('app_forgot_password') }}" class="btn-cancel" style="margin-right: auto; background-color: #f7e1d7; color: #d00000;">Reset Password</a>
            
            <a href="{{ path('app_profile_index') }}" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-save">Save Changes</button>
        </div>
    {{ form_end(form) }}
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const dateInput = document.getElementById('profile_dateNaissance');
        if (dateInput) {
            const today = new Date();
            const twentyYearsAgo = new Date(today.getFullYear() - 20, today.getMonth(), today.getDate());
            dateInput.max = twentyYearsAgo.toISOString().split('T')[0];
        }
    });
</script>
{% endblock %}
