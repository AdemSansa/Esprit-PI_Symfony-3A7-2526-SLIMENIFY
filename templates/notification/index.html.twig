{% extends 'layout/app_shell.html.twig' %}

{% block title %}My Notifications{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .notif-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 0 1rem;
    }
    .notif-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }
    .notif-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border-left: 4px solid transparent;
        transition: transform 0.2s, box-shadow 0.2s;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
    .notif-card.unread {
        border-left-color: #627255;
        background: #fdfefb;
    }
    .notif-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }
    .notif-content {
        flex: 1;
    }
    .notif-title {
        font-weight: 700;
        font-size: 1.1rem;
        color: #668e57;
        margin-bottom: 0.25rem;
    }
    .notif-message {
        color: #5fa275;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
    }
    .notif-meta {
        font-size: 0.8rem;
        color: #a0aec0;
    }
    .notif-actions {
        margin-left: 1rem;
    }
    .btn-mark-read {
        background: #edf2f7;
        color: #4a5568;
        border: none;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-mark-read:hover {
        background: #e2e8f0;
    }
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #718096;
    }
</style>
{% endblock %}

{% block app_content %}
<div class="notif-container">
    <div class="notif-header">
        <h1 style="font-size: 2rem; font-weight: 800; color: #499680;">Notifications</h1>
        {% if notifications|length > 0 %}
            <form action="{{ path('app_notification_read_all') }}" method="POST">
                <button type="submit" class="btn btn-outline-secondary" style="font-size: 0.9rem; border-radius: 8px;">
                    Mark all as read
                </button>
            </form>
        {% endif %}
    </div>

    {% for notification in notifications %}
        <div class="notif-card {{ not notification.isRead ? 'unread' : '' }}">
            <div class="notif-content">
                <div class="notif-title">
                    {{ notification.title }}
                </div>
                <div class="notif-message">
                    {{ notification.message }}
                </div>
                <div class="notif-meta">
                    {{ notification.createdAt|date('M d, Y H:i') }}
                    {% if notification.blog %}
                        · <a href="{{ path('app_blog_web_show', {id: notification.blog.id}) }}" style="color: #85a76a; font-weight: 600; text-decoration: none;">View Blog</a>
                    {% endif %}
                </div>
            </div>
            <div class="notif-actions">
                {% if not notification.isRead %}
                    <form action="{{ path('app_notification_read', {id: notification.id}) }}" method="POST">
                        <button type="submit" class="btn-mark-read">Mark as read</button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 1rem; opacity: 0.5;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <p>You're all caught up! No notifications for now.</p>
            <a href="{{ path('app_blog_web_index') }}" style="color: #627255; font-weight: 600; text-decoration: none; display: inline-block; margin-top: 1rem;">Back to Blogs</a>
        </div>
    {% endfor %}
</div>
{% endblock %}
