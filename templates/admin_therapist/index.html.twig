{% extends 'layout/app_shell.html.twig' %}

{% block title %}Therapist Directory{% endblock %}

{% block app_content %}
<style>
    /* Overall Container Settings */
    .dashboard-container {
        max-width: 1100px;
        margin: 0 auto;
        animation: fadeIn 0.4s ease;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Top Directory Header Box */
    .directory-header {
        background: #ffffff;
        border-radius: 12px;
        padding: 20px 30px;
        box-shadow: 0 4px 15px rgba(122, 91, 73, 0.05);
        border: 1px solid rgba(122, 91, 73, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

    .directory-title-section h1 {
        color: #A8866E;
        font-size: 1.6rem;
        font-weight: 800;
        margin: 0 0 5px 0;
    }

    .directory-title-section p {
        color: #4A4A4A;
        font-size: 0.85rem;
        margin: 0;
    }

    .directory-actions {
        display: flex;
        gap: 15px;
    }

    .btn-new-therapist {
        background: #687560;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 20px;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-new-therapist:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(104, 117, 96, 0.3);
        color: white;
    }

    .btn-outline-action {
        background: transparent;
        color: #687560;
        border: 1px solid #687560;
        border-radius: 30px;
        padding: 10px 20px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: background 0.2s, color 0.2s;
    }

    .btn-outline-action:hover {
        background: #687560;
        color: white;
    }

    /* Filter Toolbar Component */
    .filter-toolbar {
        background: #ffffff;
        border-radius: 12px;
        padding: 15px 30px;
        box-shadow: 0 4px 15px rgba(122, 91, 73, 0.05);
        border: 1px solid rgba(122, 91, 73, 0.1);
        display: flex;
        align-items: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
        gap: 20px;
    }

    .filter-group {
        display: flex;
        flex-direction: column;
    }

    .filter-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: #5D4A3E;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .filter-input {
        padding: 8px 12px;
        border: 1px solid #EBE6DF;
        border-radius: 8px;
        background-color: #FDFDFD;
        color: #4A4A4A;
        font-size: 0.9rem;
        outline: none;
        transition: border 0.2s;
    }

    .filter-input:focus {
        border-color: #687560;
    }
    
    .filter-select {
        cursor: pointer;
        appearance: auto;
    }

    .btn-reset {
        margin-top: 18px; /* align with inputs that have labels */
        background: transparent;
        color: #5D4A3E;
        border: 1px solid #D5D9D1;
        border-radius: 20px;
        padding: 8px 15px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: all 0.2s;
    }

    .btn-reset:hover {
        background: #F0EEEA;
    }

    /* Therapist Grid Layout */
    .therapist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    /* Therapist Card Design */
    .therapist-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(122, 91, 73, 0.06);
        border: 1px solid rgba(122, 91, 73, 0.05);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .therapist-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(122, 91, 73, 0.1);
    }

    .card-header-top {
        display: flex;
        gap: 15px;
    }

    .card-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #F0EEEA;
    }

    .card-title {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .card-name {
        font-size: 1.15rem;
        font-weight: 800;
        color: #2D2D2D;
        margin: 0 0 5px 0;
    }

    .status-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: #EAF0E4;
        color: #4F5D44;
        align-self: flex-start;
    }

    .card-body-content {
        margin-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex-grow: 1;
    }

    .info-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }

    .info-icon {
        color: #A8866E;
        margin-top: 2px;
        flex-shrink: 0;
    }

    .info-text {
        font-size: 0.85rem;
        color: #555;
        line-height: 1.4;
    }

    .info-text strong {
        color: #5D4A3E;
    }

    .card-actions {
        margin-top: 20px;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        align-items: center;
    }

    .btn-edit-card {
        background: transparent;
        color: #687560;
        border: 1px solid #D5D9D1;
        border-radius: 20px;
        padding: 6px 20px;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-edit-card:hover {
        background: #F0EEEA;
        color: #4F5D44;
    }

    .delete-form-inline form button {
        background: #687560;
        color: white;
        border: none;
        border-radius: 20px;
        padding: 7px 20px;
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
    }
    
    .delete-form-inline form button:hover {
        background: #4F5D44;
    }

</style>

<div class="dashboard-container">
    
    <div class="directory-header">
        <div class="directory-title-section">
            <h1>Therapist Directory</h1>
            <p>{{ therapists|length }} therapist(s) registered</p>
        </div>
        <div class="directory-actions">
            <a href="{{ path('app_admin_therapist_new') }}" class="btn-new-therapist">
                + New Therapist
            </a>
        </div>
    </div>

    <div class="filter-toolbar">
        <div class="filter-group" style="flex: 1; min-width: 200px;">
            <div class="filter-label">Search</div>
            <input type="text" id="searchInput" class="filter-input" placeholder="Name, surname...">
        </div>
        
        <div class="filter-group" style="width: 160px;">
            <div class="filter-label">Specialty</div>
            <select id="specialtyFilter" class="filter-input filter-select">
                <option value="">All specialties</option>
                {# We could dynamically populate this, but keeping it simple for now #}
                <option value="Psychologie">Psychologie</option>
                <option value="Sexologie">Sexologie</option>
                <option value="Thérapie de couple">Thérapie de couple</option>
            </select>
        </div>

        <div class="filter-group" style="width: 140px;">
            <div class="filter-label">Mode</div>
            <select id="modeFilter" class="filter-input filter-select">
                <option value="">All modes</option>
                <option value="ONLINE">Online</option>
                <option value="IN_PERSON">In Person</option>
                <option value="BOTH">Both</option>
            </select>
        </div>

        <button class="btn-reset" onclick="resetFilters()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
            Reset
        </button>
    </div>

    <div class="therapist-grid" id="therapistGrid">
        {% for therapist in therapists %}
            <div class="therapist-card" 
                 data-name="{{ therapist.firstName }} {{ therapist.lastName }}" 
                 data-specialty="{{ therapist.specialization }}" 
                 data-mode="{{ therapist.consultationType }}">
                
                <div class="card-header-top">
                    {% if therapist.photoUrl and therapist.photoUrl != 'default.png' %}
                        <img src="{{ therapist.photoUrl }}" alt="Dr. {{ therapist.lastName }}" class="card-avatar">
                    {% else %}
                        {# Fallback #}
                        <img src="https://ui-avatars.com/api/?name={{ therapist.firstName }}+{{ therapist.lastName }}&background=EAF0E4&color=4F5D44" alt="Avatar" class="card-avatar">
                    {% endif %}
                    
                    <div class="card-title">
                        <h3 class="card-name">Dr. {{ therapist.firstName }} {{ therapist.lastName }}</h3>
                        <div class="status-badge">{{ therapist.consultationType ?: 'ONLINE' }}</div>
                    </div>
                </div>

                <div class="card-body-content">
                    <div class="info-row">
                        <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        <span class="info-text"><strong>Email:</strong> {{ therapist.email }}</span>
                    </div>
                    
                    <div class="info-row">
                        <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                        <span class="info-text"><strong>Phone:</strong> {{ therapist.phoneNumber }}</span>
                    </div>

                    <div class="info-row" style="align-items: flex-start;">
                        <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        <span class="info-text">
                            <strong>Bio:</strong> 
                            {% if therapist.description|length > 60 %}
                                {{ therapist.description|slice(0, 60) }}...
                            {% else %}
                                {{ therapist.description ?: 'No bio provided.' }}
                            {% endif %}
                        </span>
                    </div>

                    <div class="info-row">
                        <svg class="info-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
                        <span class="info-text"><strong>Specialty:</strong> {{ therapist.specialization }}</span>
                    </div>
                </div>

                <div class="card-actions">
                    <a href="{{ path('app_admin_therapist_edit', {'id': therapist.id}) }}" class="btn-edit-card">Edit</a>
                    <div class="delete-form-inline">
                        <form method="post" action="{{ path('app_admin_therapist_delete', {'id': therapist.id}) }}" onsubmit="return confirm('Etes-vous sûr de vouloir supprimer ce thérapeute ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ therapist.id) }}">
                            <button type="submit">Delete</button>
                        </form>
                    </div>
                </div>

            </div>
        {% else %}
            <div style="grid-column: 1 / -1; text-align: center; padding: 40px; color: #7A5B49; background: #fff; border-radius: 12px;">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-bottom: 15px;"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
                <h3>No therapists found</h3>
                <p>There are no therapists registered in the system yet.</p>
            </div>
        {% endfor %}
    </div>

</div>

<script>
    const searchInput = document.getElementById('searchInput');
    const specialtyFilter = document.getElementById('specialtyFilter');
    const modeFilter = document.getElementById('modeFilter');
    const cards = document.querySelectorAll('.therapist-card');

    function filterCards() {
        const searchText = searchInput.value.toLowerCase();
        const specialtySearch = specialtyFilter.value.toLowerCase();
        const modeSearch = modeFilter.value.toLowerCase();

        cards.forEach(card => {
            const name = (card.getAttribute('data-name') || '').toLowerCase();
            const spec = (card.getAttribute('data-specialty') || '').toLowerCase();
            const mode = (card.getAttribute('data-mode') || '').toLowerCase();

            const matchesSearch = name.includes(searchText);
            const matchesSpec = specialtySearch === '' || spec.includes(specialtySearch);
            // Since Mode isn't perfectly clean, do a substring check
            const matchesMode = modeSearch === '' || mode.includes(modeSearch);

            if (matchesSearch && matchesSpec && matchesMode) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function resetFilters() {
        searchInput.value = '';
        specialtyFilter.value = '';
        modeFilter.value = '';
        filterCards();
    }

    searchInput.addEventListener('keyup', filterCards);
    specialtyFilter.addEventListener('change', filterCards);
    modeFilter.addEventListener('change', filterCards);
</script>
{% endblock %}
