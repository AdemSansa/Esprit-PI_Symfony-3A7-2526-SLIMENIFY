{% extends 'layout/app_shell.html.twig' %}

{% block title %}Edit Therapist{% endblock %}

{% block app_content %}
<style>
    /* Repeating the same styles from new.html.twig for simplicity */
    .dashboard-form-container {
        max-width: 800px;
        margin: 0 auto;
        animation: fadeIn 0.4s ease;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .dashboard-form-card {
        background: #ffffff;
        border-radius: 16px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(122, 91, 73, 0.08);
        border: 1px solid rgba(122, 91, 73, 0.1);
    }

    .dashboard-form-header {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
        border-bottom: 2px solid #F0EEEA;
        padding-bottom: 20px;
    }

    .dashboard-form-title {
        color: #5D4A3E;
        font-size: 1.5rem;
        font-weight: 800;
        margin: 0;
        flex-grow: 1;
        text-align: center;
    }

    .btn-back {
        color: #A8866E;
        text-decoration: none;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;
    }

    .btn-back:hover {
        color: #7A5B49;
    }

    .custom-field {
        margin-bottom: 20px;
    }

    .custom-label {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: #7A5B49;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .custom-input, textarea.custom-input {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #EBE6DF;
        border-radius: 10px;
        background-color: #FDFDFD;
        color: #4A4A4A;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .custom-input:focus, textarea.custom-input:focus {
        outline: none;
        border-color: #A8866E;
        background-color: #fff;
        box-shadow: 0 0 0 4px rgba(168, 134, 110, 0.1);
    }
    
    .custom-select {
        cursor: pointer;
        appearance: none;
        background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%237A5B49' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
        background-repeat: no-repeat;
        background-position: right 1rem center;
        background-size: 1em;
    }

    .btn-submit {
        background: linear-gradient(135deg, #7A5B49, #A8866E);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 14px 30px;
        font-size: 1.05rem;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(122, 91, 73, 0.2);
    }
    
    .password-hint {
        font-size: 0.8rem;
        color: #999;
        margin-top: 6px;
        display: block;
    }

    .action-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }
</style>

<div class="dashboard-form-container">
    <div class="dashboard-form-card">
        <div class="dashboard-form-header">
            <a href="{{ path('app_admin_therapist_index') }}" class="btn-back">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Back
            </a>
            <h2 class="dashboard-form-title">Update Therapist Profile</h2>
            <div style="width: 70px;"></div>
        </div>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            
            <div style="display: flex; gap: 20px;">
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.firstName, 'First Name', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.firstName, {'attr': {'class': 'custom-input'}}) }}
                </div>
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.lastName, 'Last Name', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.lastName, {'attr': {'class': 'custom-input'}}) }}
                </div>
            </div>

            <div style="display: flex; gap: 20px;">
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.email, 'Email Address', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'custom-input'}}) }}
                </div>
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.phoneNumber, 'Phone Number', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.phoneNumber, {'attr': {'class': 'custom-input'}}) }}
                </div>
            </div>

            <div style="display: flex; gap: 20px;">
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.specialization, 'Specialty', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.specialization, {'attr': {'class': 'custom-input custom-select'}}) }}
                </div>
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.consultationType, 'Mode', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.consultationType, {'attr': {'class': 'custom-input custom-select'}}) }}
                </div>
            </div>

            <div class="custom-field">
                {{ form_label(form.description, 'Biography / Description', {'label_attr': {'class': 'custom-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'custom-input', 'rows': '4'}}) }}
            </div>

            <div style="display: flex; gap: 20px;">
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.photoUrl, 'Photo URL', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.photoUrl, {'attr': {'class': 'custom-input', 'placeholder': 'Optional URL or file path'}}) }}
                </div>
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.diplomaPath, 'Diploma Path', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.diplomaPath, {'attr': {'class': 'custom-input', 'placeholder': 'Optional URL or file path'}}) }}
                </div>
            </div>

            <div style="display: flex; gap: 20px;">
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.status, 'Account Status', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.status, {'attr': {'class': 'custom-input custom-select'}}) }}
                </div>
                <div class="custom-field" style="flex: 1;">
                    {{ form_label(form.password, 'Change Password', {'label_attr': {'class': 'custom-label'}}) }}
                    {{ form_widget(form.password, {'attr': {'class': 'custom-input'}}) }}
                    <span class="password-hint">Leave blank to keep the current password.</span>
                </div>
            </div>

            <div class="action-group">
                <button type="submit" class="btn-submit" style="flex: 3;">Commit Changes</button>
                <div style="flex: 1;">
                    {# delete link here maybe, but simple for now #}
                </div>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
