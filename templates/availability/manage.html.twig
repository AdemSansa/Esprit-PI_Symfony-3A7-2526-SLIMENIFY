{% extends 'layout/app_shell.html.twig' %}

{% block title %}Availability Management{% endblock %}

{% block app_content %}
    <h1 style="margin-top:0; font-size:1.7rem; color:#334155;">Availability Management</h1>
    <p style="color:#64748b; max-width:70ch;">
        Set recurring business hours and one-off unavailable exceptions.
    </p>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div style="margin:0.75rem 0; padding:0.7rem 0.9rem; border-radius:10px; border:1px solid {{ label == 'error' ? '#fecaca' : '#bbf7d0' }}; background:{{ label == 'error' ? '#fef2f2' : '#f0fdf4' }}; color:{{ label == 'error' ? '#b91c1c' : '#166534' }};">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-top:1rem;">
        <section style="background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:1rem;">
            <h2 style="margin-top:0; font-size:1.1rem; color:#334155;">Add Business Hours</h2>
            <form method="post" action="{{ path('app_availability_add_business_hours') }}">
                <div style="display:grid; gap:0.75rem;">
                    <label style="font-size:0.9rem; color:#475569;">Weekday</label>
                    <select name="day" required style="border:1px solid #cbd5e1; border-radius:8px; padding:0.55rem;">
                        {% for day in ['MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY','SUNDAY'] %}
                            <option value="{{ day }}">{{ day|title }}</option>
                        {% endfor %}
                    </select>
                    <label style="font-size:0.9rem; color:#475569;">Start Time</label>
                    <input type="time" name="start_time" required style="border:1px solid #cbd5e1; border-radius:8px; padding:0.55rem;">
                    <label style="font-size:0.9rem; color:#475569;">End Time</label>
                    <input type="time" name="end_time" required style="border:1px solid #cbd5e1; border-radius:8px; padding:0.55rem;">
                    <button type="submit" style="margin-top:0.25rem; background:#627255; color:#fff; border:none; border-radius:10px; padding:0.65rem 0.8rem; cursor:pointer;">Save Business Hour</button>
                </div>
            </form>
        </section>

        <section style="background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:1rem;">
            <h2 style="margin-top:0; font-size:1.1rem; color:#334155;">Add Date Exception</h2>
            <form method="post" action="{{ path('app_availability_add_exception') }}">
                <div style="display:grid; gap:0.75rem;">
                    <label style="font-size:0.9rem; color:#475569;">Specific Date</label>
                    <input type="date" name="specific_date" required style="border:1px solid #cbd5e1; border-radius:8px; padding:0.55rem;">
                    <label style="font-size:0.9rem; color:#475569;">Blocked From</label>
                    <input type="time" name="start_time" required style="border:1px solid #cbd5e1; border-radius:8px; padding:0.55rem;">
                    <label style="font-size:0.9rem; color:#475569;">Blocked To</label>
                    <input type="time" name="end_time" required style="border:1px solid #cbd5e1; border-radius:8px; padding:0.55rem;">
                    <button type="submit" style="margin-top:0.25rem; background:#627255; color:#fff; border:none; border-radius:10px; padding:0.65rem 0.8rem; cursor:pointer;">Save Exception</button>
                </div>
            </form>
        </section>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-top:1rem;">
        <section style="background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:1rem;">
            <h2 style="margin-top:0; font-size:1.1rem; color:#334155;">Current Business Hours</h2>
            {% if business_hours is empty %}
                <p style="color:#64748b;">No recurring business hours yet.</p>
            {% else %}
                {% for row in business_hours %}
                    <div style="display:flex; justify-content:space-between; align-items:center; border:1px solid #e2e8f0; border-radius:10px; padding:0.55rem 0.7rem; margin-bottom:0.5rem;">
                        <span style="color:#334155;">{{ row.day|title }} • {{ row.startTime|date('H:i') }} - {{ row.endTime|date('H:i') }}</span>
                        <div style="display:flex; gap:0.45rem;">
                            <details>
                                <summary style="list-style:none; cursor:pointer; border:none; background:#dbeafe; color:#1e40af; border-radius:8px; padding:0.35rem 0.6rem; font-size:0.85rem;">Edit</summary>
                                <form method="post" action="{{ path('app_availability_update', {id: row.id}) }}" style="margin-top:0.5rem; padding:0.6rem; border:1px solid #e2e8f0; border-radius:8px; background:#f8fafc; display:grid; gap:0.45rem;">
                                    <select name="day" required style="border:1px solid #cbd5e1; border-radius:7px; padding:0.4rem;">
                                        {% for day in ['MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY','SUNDAY'] %}
                                            <option value="{{ day }}" {{ row.day == day ? 'selected' : '' }}>{{ day|title }}</option>
                                        {% endfor %}
                                    </select>
                                    <input type="time" name="start_time" required value="{{ row.startTime|date('H:i') }}" style="border:1px solid #cbd5e1; border-radius:7px; padding:0.4rem;">
                                    <input type="time" name="end_time" required value="{{ row.endTime|date('H:i') }}" style="border:1px solid #cbd5e1; border-radius:7px; padding:0.4rem;">
                                    <button type="submit" style="border:none; background:#627255; color:#fff; border-radius:7px; padding:0.35rem 0.55rem; cursor:pointer;">Save</button>
                                </form>
                            </details>
                            <form method="post" action="{{ path('app_availability_delete', {id: row.id}) }}">
                                <button type="submit" style="border:none; background:#fee2e2; color:#991b1b; border-radius:8px; padding:0.35rem 0.6rem; cursor:pointer;">Delete</button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </section>

        <section style="background:#fff; border:1px solid #e2e8f0; border-radius:14px; padding:1rem;">
            <h2 style="margin-top:0; font-size:1.1rem; color:#334155;">Date Exceptions</h2>
            {% if exceptions is empty %}
                <p style="color:#64748b;">No date exceptions yet.</p>
            {% else %}
                {% for row in exceptions %}
                    <div style="display:flex; justify-content:space-between; align-items:center; border:1px solid #e2e8f0; border-radius:10px; padding:0.55rem 0.7rem; margin-bottom:0.5rem;">
                        <span style="color:#334155;">{{ row.specificDate|date('Y-m-d') }} • {{ row.startTime|date('H:i') }} - {{ row.endTime|date('H:i') }}</span>
                        <div style="display:flex; gap:0.45rem;">
                            <details>
                                <summary style="list-style:none; cursor:pointer; border:none; background:#dbeafe; color:#1e40af; border-radius:8px; padding:0.35rem 0.6rem; font-size:0.85rem;">Edit</summary>
                                <form method="post" action="{{ path('app_availability_update', {id: row.id}) }}" style="margin-top:0.5rem; padding:0.6rem; border:1px solid #e2e8f0; border-radius:8px; background:#f8fafc; display:grid; gap:0.45rem;">
                                    <input type="date" name="specific_date" required value="{{ row.specificDate|date('Y-m-d') }}" style="border:1px solid #cbd5e1; border-radius:7px; padding:0.4rem;">
                                    <input type="time" name="start_time" required value="{{ row.startTime|date('H:i') }}" style="border:1px solid #cbd5e1; border-radius:7px; padding:0.4rem;">
                                    <input type="time" name="end_time" required value="{{ row.endTime|date('H:i') }}" style="border:1px solid #cbd5e1; border-radius:7px; padding:0.4rem;">
                                    <button type="submit" style="border:none; background:#627255; color:#fff; border-radius:7px; padding:0.35rem 0.55rem; cursor:pointer;">Save</button>
                                </form>
                            </details>
                            <form method="post" action="{{ path('app_availability_delete', {id: row.id}) }}">
                                <button type="submit" style="border:none; background:#fee2e2; color:#991b1b; border-radius:8px; padding:0.35rem 0.6rem; cursor:pointer;">Delete</button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </section>
    </div>
{% endblock %}
