{% extends 'layout/app_shell.html.twig' %}

{% block title %}Secure Payment | Slimenify Wellness{% endblock %}

{% block app_content %}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap');

    .checkout-wrapper {
        font-family: 'Outfit', sans-serif;
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 0;
        animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .checkout-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .checkout-title {
        font-size: 3rem;
        font-weight: 800;
        background: linear-gradient(135deg, #2c3624 0%, #6b8256 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
        letter-spacing: -1px;
    }

    .checkout-subtitle {
        color: #64748b;
        font-size: 1.15rem;
        font-weight: 400;
    }

    .checkout-grid {
        display: grid;
        grid-template-columns: 1fr 400px;
        gap: 2.5rem;
        align-items: start;
    }

    /* Form Side */
    .form-container {
        background: #ffffff;
        border-radius: 24px;
        padding: 3rem;
        box-shadow: 0 25px 50px -12px rgba(107, 130, 86, 0.08);
        border: 1px solid rgba(107, 130, 86, 0.1);
        position: relative;
    }

    .form-container::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 6px;
        background: linear-gradient(90deg, #6b8256, #d4b58f);
        border-radius: 24px 24px 0 0;
    }

    .section-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .section-title i {
        color: #6b8256;
        background: #f3f6f0;
        padding: 10px;
        border-radius: 12px;
        font-size: 1.2rem;
    }

    .floating-group {
        position: relative;
        margin-bottom: 1.5rem;
    }

    .floating-input {
        width: 100%;
        padding: 1.2rem 1.25rem 0.8rem;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        font-size: 1.05rem;
        font-family: inherit;
        background: #fcfcfc;
        transition: all 0.3s ease;
        box-sizing: border-box;
        color: #334155;
    }

    .floating-input:focus {
        outline: none;
        border-color: #6b8256;
        background: #ffffff;
        box-shadow: 0 0 0 4px rgba(107, 130, 86, 0.1);
    }

    .floating-label {
        position: absolute;
        left: 1.25rem;
        top: 1rem;
        color: #94a3b8;
        font-size: 1.05rem;
        transition: all 0.2s ease;
        pointer-events: none;
        font-family: inherit;
    }

    .floating-input:focus ~ .floating-label,
    .floating-input:not(:placeholder-shown) ~ .floating-label {
        top: 0.4rem;
        font-size: 0.75rem;
        color: #6b8256;
        font-weight: 600;
    }

    .payment-methods {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }

    .method-card {
        position: relative;
        cursor: pointer;
    }

    .method-card input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .method-content {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.5rem 1rem;
        background: #ffffff;
        border-radius: 20px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        text-align: center;
        z-index: 1;
        min-height: 160px;
    }

    .method-content::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 20px;
        padding: 3px; /* Border thickness */
        background: #e2e8f0; /* Default color */
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        transition: all 0.4s ease;
        pointer-events: none;
    }

    .method-content img {
        width: 190px;
        height: 110px;
        object-fit: contain;
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        filter: drop-shadow(0 5px 8px rgba(0,0,0,0.06));
    }

    .method-card:hover .method-content {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.04);
    }
    .method-card:hover .method-content::before {
        background: #cbd5e1;
    }

    .method-card input:checked + .method-content {
        background: #fdfbf9;
        box-shadow: 0 15px 35px rgba(107, 130, 86, 0.15);
    }

    .method-card input:checked + .method-content::before {
        background: linear-gradient(135deg, #6b8256, #d4b58f, #6b8256);
        background-size: 200% 200%;
        animation: gradientBorder 3s ease infinite;
    }

    @keyframes gradientBorder {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    .method-card input:checked + .method-content img {
        transform: scale(1.15) translateY(-2px);
    }

    .submit-btn {
        width: 100%;
        background: linear-gradient(135deg, #6b8256, #4e603e);
        color: white;
        border: none;
        padding: 1.35rem;
        border-radius: 16px;
        font-size: 1.15rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 2.5rem;
        box-shadow: 0 10px 20px rgba(107, 130, 86, 0.25);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .submit-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 30px rgba(107, 130, 86, 0.35);
    }

    .submit-btn i {
        font-size: 1.25rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        margin-top: 1.5rem;
        color: #94a3b8;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.2s;
        gap: 8px;
    }

    .back-link:hover {
        color: #475569;
    }

    /* Summary Side */
    .summary-container {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 24px;
        padding: 2.5rem;
        border: 1px solid rgba(255, 255, 255, 0.6);
        box-shadow: 0 20px 40px rgba(0,0,0,0.03);
        position: sticky;
        top: 2rem;
    }

    .summary-title {
        font-size: 1.35rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 2rem;
    }

    .cart-items {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin-bottom: 2rem;
        max-height: 350px;
        overflow-y: auto;
        padding-right: 0.5rem;
    }

    /* custom scrollbar */
    .cart-items::-webkit-scrollbar { width: 4px; }
    .cart-items::-webkit-scrollbar-track { background: transparent; }
    .cart-items::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

    .cart-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem;
        border-radius: 16px;
        background: #ffffff;
        border: 1px solid #f1f5f9;
        transition: transform 0.2s;
    }

    .cart-item:hover {
        transform: translateX(5px);
    }

    .item-image {
        width: 65px;
        height: 65px;
        border-radius: 12px;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

    .item-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .item-details { flex: 1; overflow: hidden; }
    
    .item-name {
        font-weight: 700;
        font-size: 0.95rem;
        color: #334155;
        margin-bottom: 0.25rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .item-qty {
        font-size: 0.85rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .item-price {
        font-weight: 800;
        color: #6b8256;
        font-size: 1rem;
    }

    .totals {
        border-top: 2px dashed #e2e8f0;
        padding-top: 1.5rem;
    }

    .total-line {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        color: #64748b;
        font-weight: 500;
    }

    .total-line span:last-child {
        color: #334155;
        font-weight: 600;
    }

    .total-final {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
    }

    .total-final-label {
        font-size: 1.25rem;
        font-weight: 600;
        color: #1e293b;
    }

    .total-final-amount {
        font-size: 1.75rem;
        font-weight: 800;
        color: #6b8256;
        letter-spacing: -0.5px;
    }

    .trust-badge {
        margin-top: 2rem;
        background: #fbfdf9;
        border: 1px solid #eef5e9;
        padding: 1.25rem;
        border-radius: 16px;
        display: flex;
        align-items: start;
        gap: 1rem;
    }

    .trust-icon {
        color: #6b8256;
        font-size: 1.5rem;
        margin-top: 3px;
    }

    .trust-text {
        font-size: 0.85rem;
        color: #64748b;
        line-height: 1.5;
    }
    .trust-text strong {
        display: block;
        color: #334155;
        margin-bottom: 0.4rem;
        font-size: 0.95rem;
    }

    @media (max-width: 968px) {
        .checkout-grid { grid-template-columns: 1fr; }
        .summary-container { order: -1; position: static; }
        .form-container { padding: 2rem; }
    }
</style>

<!-- FontAwesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="checkout-wrapper">
    <div class="checkout-header">
        <h1 class="checkout-title">Payment & Delivery</h1>
        <p class="checkout-subtitle">Complete your order securely with Slimenify.</p>
    </div>

    <div class="checkout-grid">
        
        <!-- FORM SIDE -->
        <div class="form-container">
            <form action="{{ path('app_cart_confirm') }}" method="POST" data-turbo="false">
                
                <h2 class="section-title">
                    <i class="fa-solid fa-map-location-dot"></i>
                    Delivery Information
                </h2>
                
                <div class="floating-group">
                    <input type="text" id="address" name="address" class="floating-input" placeholder=" " required minlength="8">
                    <label for="address" class="floating-label">Full Address (Street, City, Postal Code)</label>
                </div>

                <div class="floating-group">
                    <input type="tel" id="phone" name="phone" class="floating-input" placeholder=" " required pattern="^[0-9]{8}$" title="Please enter an 8-digit number">
                    <label for="phone" class="floating-label">Phone Number (8 digits)</label>
                </div>

                <h2 class="section-title" style="margin-top: 3.5rem;">
                    <i class="fa-solid fa-wallet"></i>
                    Payment Method
                </h2>

                <div class="payment-methods">
                    <label class="method-card" title="Cash on Delivery">
                        <input type="radio" name="payment_method" value="cash_on_delivery" checked>
                        <div class="method-content">
                            <img src="{{ asset('images/livraison.png') }}" alt="Cash on Delivery">
                        </div>
                    </label>

                    <label class="method-card" title="Bank Card">
                        <input type="radio" name="payment_method" value="bank_card">
                        <div class="method-content">
                            <img src="{{ asset('images/carte.png') }}" alt="Bank Card">
                        </div>
                    </label>
                </div>

                <button type="submit" class="submit-btn">
                    <i class="fa-solid fa-shield-check" style="font-size: 1.1rem;"></i>
                    Confirm Order
                </button>

                <a href="{{ path('app_cart_index') }}" class="back-link">
                    <i class="fa-solid fa-arrow-left-long"></i>
                    Back to cart
                </a>
            </form>
        </div>

        <!-- SUMMARY SIDE -->
        <div class="summary-container">
            <h3 class="summary-title">Order Summary</h3>
            
            <div class="cart-items">
                {% for item in items %}
                    <div class="cart-item">
                        <div class="item-image">
                            <img src="{{ item.product.photoUrl ?: 'https://images.unsplash.com/photo-1542282088-fe8426682b8f?q=80&w=100' }}" alt="">
                        </div>
                        <div class="item-details">
                            <div class="item-name">{{ item.product.name }}</div>
                            <div class="item-qty">Qty: {{ item.quantity }}</div>
                        </div>
                        <div class="item-price">{{ (item.product.price * item.quantity)|number_format(2, ',', ' ') }} TND</div>
                    </div>
                {% endfor %}
            </div>

            <div class="totals">
                <div class="total-line">
                    <span>Subtotal</span>
                    <span>{{ total|number_format(2, ',', ' ') }} TND</span>
                </div>
                <div class="total-line">
                    <span>Shipping Fee</span>
                    <span style="color: #6b8256; font-weight: 700; background: #eef5e9; padding: 2px 8px; border-radius: 6px;">FREE</span>
                </div>
                
                <div class="total-final">
                    <span class="total-final-label">Total Amount</span>
                    <span class="total-final-amount">{{ total|number_format(2, ',', ' ') }} TND</span>
                </div>
            </div>

            <div class="trust-badge">
                <i class="fa-solid fa-lock trust-icon"></i>
                <div class="trust-text">
                    <strong>Super-Secure Payment</strong>
                    Your data is AES-256 encrypted. No banking information is stored on our servers.
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
