{% extends 'layout/app_shell.html.twig' %}

{% block title %}Shopping Cart | Slimenify Wellness{% endblock %}

{% block app_content %}
<style>
    .cart-container {
        padding: 1.5rem;
        animation: fadeIn 0.8s ease-out;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .page-title {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(90deg, #3d4a32, #6a7c5c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 2rem;
    }

    .cart-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 2rem;
    }

    .cart-items {
        background: #fff;
        border-radius: 24px;
        padding: 1.5rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

    .cart-item {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.5rem 0;
        border-bottom: 1px solid #f1f5f9;
    }
    .cart-item:last-child { border-bottom: none; }

    .item-img {
        width: 80px;
        height: 80px;
        background: #f8faf7;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }
    .item-img img { width: 80%; height: 80%; object-fit: contain; }

    .item-info { flex: 1; }
    .item-name { font-weight: 700; color: #1e293b; font-size: 1.1rem; margin-bottom: 0.25rem; }
    .item-cat { font-size: 0.8rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }

    .item-qty {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: #f8fafc;
        padding: 0.4rem 0.75rem;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
    }
    .qty-btn {
        background: none;
        border: none;
        color: #64748b;
        cursor: pointer;
        font-weight: bold;
        padding: 0 5px;
        font-size: 1.1rem;
    }
    .qty-btn:hover { color: #627255; }

    .item-price { font-weight: 800; color: #627255; font-size: 1.1rem; width: 120px; text-align: right; }

    .btn-remove {
        color: #ef4444;
        background: #fee2e2;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-remove:hover { background: #ef4444; color: #fff; }

    /* Summary Side */
    .cart-summary {
        background: #fff;
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
        height: min-content;
        position: sticky;
        top: 2rem;
    }
    .summary-title { font-size: 1.25rem; font-weight: 800; color: #1e293b; margin-bottom: 1.5rem; }
    .summary-row { display: flex; justify-content: space-between; margin-bottom: 1rem; color: #64748b; }
    .summary-total { border-top: 1px solid #f1f5f9; padding-top: 1rem; margin-top: 1rem; font-weight: 800; color: #1e293b; font-size: 1.3rem; }

    .btn-checkout {
        width: 100%;
        background: #627255;
        color: #fff;
        border: none;
        padding: 1.1rem;
        border-radius: 16px;
        font-weight: 700;
        font-size: 1rem;
        margin-top: 1.5rem;
        cursor: pointer;
        transition: all 0.3s;
        box-shadow: 0 4px 12px rgba(98, 114, 85, 0.2);
    }
    .btn-checkout:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(98, 114, 85, 0.3); }

    .btn-clear {
        width: 100%;
        background: transparent;
        color: #94a3b8;
        border: 1px solid #e2e8f0;
        padding: 0.75rem;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 1rem;
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-clear:hover { background: #f8fafc; color: #ef4444; border-color: #fca5a5; }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: #fff;
        border-radius: 24px;
        border: 1px dashed #e2e8f0;
    }
    .empty-icon { font-size: 4rem; margin-bottom: 1rem; opacity: 0.5; }

    @media (max-width: 900px) {
        .cart-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="cart-container">
    <h1 class="page-title">Your Shopping Cart</h1>

    {% if items|length > 0 %}
        <div class="cart-grid">
            <div class="cart-items">
                {% for item in items %}
                    <div class="cart-item">
                        <div class="item-img">
                            <img src="{{ item.product.photoUrl ?: 'https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=150&q=80' }}" alt="">
                        </div>
                        <div class="item-info">
                            <div class="item-cat">{{ item.product.category }}</div>
                            <div class="item-name">{{ item.product.name }}</div>
                            <a href="{{ path('app_cart_remove', {id: item.product.id}) }}" style="font-size: 0.8rem; color: #ef4444; border: none; background: none; text-decoration: none;">Remove</a>
                        </div>
                        
                        <div class="item-qty">
                            <form action="{{ path('app_cart_update', {id: item.product.id}) }}" method="POST" style="display: flex; align-items: center; gap: 0.5rem;">
                                <button type="submit" name="quantity" value="{{ item.quantity - 1 }}" class="qty-btn" {{ item.quantity <= 1 ? 'disabled' : '' }}>-</button>
                                <span style="font-weight: 700; min-width: 20px; text-align: center;">{{ item.quantity }}</span>
                                <button type="submit" name="quantity" value="{{ item.quantity + 1 }}" class="qty-btn">+</button>
                            </form>
                        </div>

                        <div class="item-price">
                            {{ item.total|number_format(2) }} TND
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="cart-summary">
                <h2 class="summary-title">Order Summary</h2>
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>{{ total|number_format(2) }} TND</span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span style="color: #627255; font-weight: 700;">FREE</span>
                </div>
                <div class="summary-total">
                    <span>Total</span>
                    <span>{{ total|number_format(2) }} TND</span>
                </div>

                <button class="btn-checkout" onclick="alert('Order placed successfully! In a real app, this would redirect to payment.')">
                    Place Order Now
                </button>

                <a href="{{ path('app_cart_clear') }}" class="btn-clear" style="display: block; text-align: center; text-decoration: none;">
                    Clear Cart
                </a>
                
                <a href="{{ path('app_product_index') }}" style="display: block; text-align: center; margin-top: 1.5rem; font-size: 0.85rem; color: #64748b; text-decoration: none;">
                    ← Continue Shopping
                </a>
            </div>
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-icon">🛒</div>
            <h2 style="font-weight: 800; color: #1e293b;">Your cart is empty</h2>
            <p style="color: #64748b; margin-bottom: 2rem;">It looks like you haven't added any products to your cart yet.</p>
            <a href="{{ path('app_product_index') }}" class="btn-checkout" style="text-decoration: none; padding: 1rem 2rem;">
                Back to Wellness Shop
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
