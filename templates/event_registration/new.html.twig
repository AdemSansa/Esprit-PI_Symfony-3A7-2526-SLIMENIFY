{% extends 'layout/app_shell.html.twig' %}

{% block title %}Register - {{ event.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-container {
            max-width: 900px;
            margin: 2rem auto;
            display: grid;
            grid-template-columns: 1fr 340px;
            gap: 2rem;
            animation: fadeIn 0.8s ease-out;
            font-family: 'Inter', sans-serif;
        }

        @media (max-width: 860px) {
            .page-container { grid-template-columns: 1fr; }
        }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .register-card {
            background: white;
            border-radius: 24px;
            padding: 2.5rem;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            border: 1px solid #f1f5f9;
        }

        .section-header { margin-bottom: 2rem; }
        .section-header h1 { font-size: 1.75rem; font-weight: 800; color: #0f172a; margin: 0 0 0.5rem; letter-spacing: -0.02em; }
        .section-header p { color: #64748b; margin: 0; font-size: 0.95rem; line-height: 1.6; }

        .sidebar-card {
            background: #f8fafc;
            border-radius: 20px;
            padding: 1.5rem;
            border: 1px solid #e2e8f0;
            position: sticky;
            top: 2rem;
            height: fit-content;
        }

        .event-summary { margin-bottom: 1.5rem; }
        .event-thumb { width: 100%; height: 180px; border-radius: 12px; object-fit: cover; margin-bottom: 1rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .event-summary-title { font-size: 1.1rem; font-weight: 700; color: #1e293b; margin-bottom: 1rem; }
        
        .meta-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.85rem; }
        .meta-item { display: flex; align-items: flex-start; gap: 0.75rem; font-size: 0.85rem; color: #475569; }
        .meta-icon { width: 24px; height: 24px; display: flex; items-center; justify-center; background: #fff; border-radius: 6px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); flex-shrink: 0; }

        .form-group { margin-bottom: 1.25rem; }
        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: #334155; font-size: 0.9rem; }
        .form-control { width: 100%; padding: 0.85rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 12px; font-size: 0.95rem; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); box-sizing: border-box; background: #fdfdfd; font-family: inherit; }
        .form-control:focus { outline: none; border-color: #748764; background: #fff; box-shadow: 0 0 0 4px rgba(116, 135, 100, 0.1); }
        
        .btn-submit { width: 100%; border: none; padding: 1rem; border-radius: 14px; font-weight: 700; font-size: 1rem; cursor: pointer; transition: all 0.3s ease; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; background: linear-gradient(135deg, #748764, #748764); color: white; margin-top: 1.5rem; box-shadow: 0 4px 15px rgba(116, 135, 100, 0.3); }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(116, 135, 100, 0.4); filter: brightness(1.05); }

        .cancel-btn { display: block; text-align: center; margin-top: 1rem; color: #94a3b8; text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: color 0.2s; }
        .cancel-btn:hover { color: #64748b; text-decoration: underline; }

        .form-error, 
        .form-group ul,
        .form-group ul li { 
            color: #ef4444 !important; 
            font-size: 0.85rem; 
            margin-top: 0.5rem; 
            font-weight: 600;
            list-style: none;
            padding: 0;
        }
    </style>
{% endblock %}

{% block app_content %}
<div class="page-container">
    <div class="register-card">
        <div class="section-header">
            <h1>Confirm Attendance</h1>
            <p>Fill in your details below to secure your spot at this event. We will generate a unique QR ticket for you.</p>
        </div>
        
        {{ form_start(form, {'attr': {'class': 'signup-form', 'novalidate': 'novalidate'}}) }}
            <div class="form-group">
                {{ form_row(form.participantName, {
                    'label_attr': {'class': 'form-label'},
                    'attr': {'class': 'form-control', 'placeholder': 'e.g. Jean Dupont'}
                }) }}
            </div>
            
            <div class="form-group">
                {{ form_row(form.participantEmail, {
                    'label_attr': {'class': 'form-label'},
                    'attr': {'class': 'form-control', 'placeholder': 'e.g. jean@example.com'}
                }) }}
            </div>
            
            <div class="form-group">
                {{ form_row(form.participantPhone, {
                    'label_attr': {'class': 'form-label'},
                    'attr': {'class': 'form-control', 'placeholder': '+216 00 000 000'}
                }) }}
            </div>
            
            <div class="form-group">
                {{ form_row(form.participantNotes, {
                    'label_attr': {'class': 'form-label'},
                    'attr': {'class': 'form-control', 'placeholder': 'Any dietary needs or special requests?', 'rows': '3'}
                }) }}
            </div>

            <button type="submit" class="btn-submit">
                <i data-lucide="check-circle" style="width: 20px; height: 20px;"></i> Finalize Registration
            </button>
        {{ form_end(form) }}
        
        <a href="{{ path('app_event_index') }}" class="cancel-btn">Discard registration</a>
    </div>

    <aside class="sidebar-card">
        <div class="event-summary">
            {% if event.imageUrl %}
                <img src="{{ event.imageUrl starts with 'http' ? event.imageUrl : asset(event.imageUrl) }}" alt="Event Preview" class="event-thumb">
            {% else %}
                <div style="width:100%; height:180px; background:#e2e8f0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; margin-bottom:1rem;">
                    <i data-lucide="image" style="width: 32px; height: 32px;"></i>
                </div>
            {% endif %}
            
            <h3 class="event-summary-title">{{ event.title }}</h3>
            
            <ul class="meta-list">
                <li class="meta-item">
                    <span class="meta-icon"><i data-lucide="calendar" style="width: 14px; height: 14px; color: #6366f1;"></i></span>
                    <div>
                        <div style="font-weight:700; color:#1e293b;">Date & Time</div>
                        <div>{{ event.dateStart|date('d M Y, H:i') }}</div>
                    </div>
                </li>
                <li class="meta-item">
                    <span class="meta-icon"><i data-lucide="map-pin" style="width: 14px; height: 14px; color: #ec4899;"></i></span>
                    <div>
                        <div style="font-weight:700; color:#1e293b;">Location</div>
                        <div>{{ event.location ?: 'Virtual/To be decided' }}</div>
                    </div>
                </li>
                <li class="meta-item">
                    <span class="meta-icon"><i data-lucide="layers" style="width: 14px; height: 14px; color: #0ea5e9;"></i></span>
                    <div>
                        <div style="font-weight:700; color:#1e293b;">Event Type</div>
                        <div style="text-transform: capitalize;">{{ event.type }} Event</div>
                    </div>
                </li>
            </ul>
        </div>
        
        <div style="padding-top: 1.5rem; border-top: 1px solid #e2e8f0; text-align: center; font-size: 0.8rem; color: #94a3b8;">
            By registering, you agree to our event participation guidelines.
        </div>
    </aside>
    <script>
        document.addEventListener('DOMContentLoaded', () => { if(window.lucide) lucide.createIcons(); });
        document.addEventListener('turbo:load', () => { if(window.lucide) lucide.createIcons(); });
    </script>
</div>
{% endblock %}


