{% extends 'layout/app_shell.html.twig' %}

{% block title %}Manage Registrations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .page-container {
            width: 98%;
            max-width: 1600px;
            margin: 1.5rem auto;
            font-family: 'Inter', sans-serif;
        }

        .header-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 2px solid #e2e8f0;
        }

        .header-title h1 { font-size: 2rem; font-weight: 800; color: #0f172a; margin: 0; letter-spacing: -0.02em; }
        .header-title p { color: #64748b; margin: 0.25rem 0 0; font-size: 0.95rem; }

        .table-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            border: 1px solid #f1f5f9;
            overflow: hidden;
        }

        .table-responsive { overflow-x: auto; }
        
        table { width: 100%; border-collapse: collapse; }
        
        th {
            background: #f8fafc;
            padding: 1rem 1.5rem;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid #e2e8f0;
        }

        td {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .row-hover:hover { background: #fbfcfe; transition: background 0.2s; }

        .participant-info { display: flex; align-items: center; gap: 1rem; }
        .participant-avatar {
            width: 40px;
            height: 40px;
            background: #eef2ff;
            color: #748764;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
        }

        .participant-details div:first-child { font-weight: 700; color: #1e293b; font-size: 0.95rem; }
        .participant-details div:last-child { color: #94a3b8; font-size: 0.8rem; }

        .event-link {
            color: #748764;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: color 0.2s;
        }
        .event-link:hover { color: #2d1e16; text-decoration: underline; }

        .status-badge {
            padding: 0.4rem 0.85rem;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: capitalize;
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
        }
        .status-registered { background: #e0f2fe; color: #0369a1; }
        .status-attended { background: #dcfce7; color: #166534; }
        .status-cancelled { background: #fee2e2; color: #991b1b; }

        .actions-group { display: flex; gap: 0.5rem; align-items: center; }
        
        .btn-action {
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            background: white;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.9rem;
            padding: 0;
        }

        .btn-checkin:hover { background: #10b981; color: white; border-color: #10b981; }
        .btn-cancel:hover { background: #f59e0b; color: white; border-color: #f59e0b; }
        .btn-delete:hover { background: #ef4444; color: white; border-color: #ef4444; }

        /* Tooltip-like hints */
        .btn-action[title]:hover::after {
            content: attr(title);
            position: absolute;
            bottom: 100%;
            background: #1e293b;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            white-space: nowrap;
        }

        .empty-state {
            padding: 4rem;
            text-align: center;
            color: #94a3b8;
        }
    </style>
{% endblock %}

{% block app_content %}
<div class="page-container">
    <div class="header-section">
        <div class="header-title">
            <h1>Attendance Hub</h1>
            <p>Manage and track all event registrations in one place.</p>
        </div>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Participant</th>
                        <th>Event</th>
                        <th>Status</th>
                        <th>Date Registered</th>
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_THERAPIST') %}
                            <th>Actions</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for reg in registrations %}
                        <tr class="row-hover">
                            <td>
                                <div class="participant-info">
                                    <div class="participant-avatar">
                                        {{ reg.participantName|slice(0, 1)|upper }}
                                    </div>
                                    <div class="participant-details">
                                        <div>{{ reg.participantName }}</div>
                                        <div>{{ reg.participantEmail }}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_THERAPIST') %}
                                    <a href="{{ path('app_event_edit', {'id': reg.event.id}) }}" class="event-link">
                                        {{ reg.event.title }}
                                    </a>
                                {% else %}
                                    <span class="event-link">
                                        {{ reg.event.title }}
                                    </span>
                                {% endif %}
                                <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 0.15rem;">📍 {{ reg.event.location ?: 'Online' }}</div>
                            </td>
                            <td>
                                <span class="status-badge status-{{ reg.status }}">
                                    {% if reg.status == 'attended' %}
                                        ✨ Attended
                                    {% elseif reg.status == 'cancelled' %}
                                        ⏳ Cancelled
                                    {% else %}
                                        🎫 Registered
                                    {% endif %}
                                </span>
                            </td>
                            <td style="font-size: 0.85rem; color: #64748b;">
                                {{ reg.registrationDate|date('M d, Y') }}
                            </td>
                            {% if is_granted('ROLE_ADMIN') or reg.event.organizerId == app.user.id %}
                            <td>
                                <div class="actions-group">
                                    {% if reg.status != 'attended' %}
                                        <form method="post" action="{{ path('app_event_registration_status', {'id': reg.id, 'status': 'attended'}) }}" onsubmit="return confirm('Check-in {{ reg.participantName }}?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ reg.id) }}">
                                            <button type="submit" class="btn-action btn-checkin" title="Check-in">✓</button>
                                        </form>
                                    {% endif %}
                                    
                                    {% if reg.status != 'cancelled' %}
                                        <form method="post" action="{{ path('app_event_registration_status', {'id': reg.id, 'status': 'cancelled'}) }}" onsubmit="return confirm('Cancel this registration?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ reg.id) }}">
                                            <button type="submit" class="btn-action btn-cancel" title="Cancel">✕</button>
                                        </form>
                                    {% endif %}
                                    
                                    <form method="post" action="{{ path('app_event_registration_delete', {'id': reg.id}) }}" onsubmit="return confirm('Delete record permanently?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reg.id) }}">
                                        <button type="submit" class="btn-action btn-delete" title="Delete record">🗑️</button>
                                    </form>
                                </div>
                            </td>
                            {% endif %}
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="{{ (is_granted('ROLE_ADMIN') or is_granted('ROLE_THERAPIST')) ? '5' : '4' }}">
                                <div class="empty-state">
                                    <div style="font-size: 3rem; margin-bottom: 1rem;">🎫</div>
                                    <h3>No registrations found</h3>
                                    <p>When someone signs up for an event, they will appear here.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}


