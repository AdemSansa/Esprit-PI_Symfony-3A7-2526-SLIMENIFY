{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<main class="auth-page">
    <form class="auth-card" method="post" action="{{ path('app_login') }}">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="auth-state">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}

        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to continue to your account.</p>

        <div class="auth-field">
            <label class="auth-label" for="inputEmail">Email</label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="auth-input" autocomplete="email" required autofocus>
        </div>

        <div class="auth-field">
            <label class="auth-label" for="inputPassword">Password</label>
            <input type="password" name="password" id="inputPassword" class="auth-input" autocomplete="current-password" required>
        </div>

        <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

        <button class="auth-submit" type="submit">
            Sign in
        </button>

        <p class="auth-subtitle auth-footer-text" style="margin-top: 1rem; text-align: center;">
            Don't have an account? <a class="auth-link" href="{{ path('app_register') }}">Register here</a>
        </p>

        <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #e2e8f0;">
            <p class="auth-subtitle" style="text-align: center; margin-bottom: 0.5rem; font-size: 0.8rem;">Dev Tools (Auto-fill)</p>
            <div style="display: flex; gap: 10px; justify-content: center;">
                <button type="button" style="padding: 5px 10px; font-size: 0.85rem; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc; color: #475569; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#f8fafc'" onclick="document.getElementById('inputEmail').value='patient@gmail.com'; document.getElementById('inputPassword').value='123456';">Patient</button>
                <button type="button" style="padding: 5px 10px; font-size: 0.85rem; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc; color: #475569; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#f8fafc'" onclick="document.getElementById('inputEmail').value='therapist@gmail.com'; document.getElementById('inputPassword').value='123456';">Therapist</button>
                <button type="button" style="padding: 5px 10px; font-size: 0.85rem; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc; color: #475569; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#e2e8f0'" onmouseout="this.style.background='#f8fafc'" onclick="document.getElementById('inputEmail').value='admin@gmail.com'; document.getElementById('inputPassword').value='123456';">Admin</button>
            </div>
        </div>
    </form>
</main>
{% endblock %}
