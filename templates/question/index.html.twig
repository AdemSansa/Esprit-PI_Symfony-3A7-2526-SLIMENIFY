{% extends 'layout/app_shell.html.twig' %}

{% block title %}Questions{% endblock %}

{% block app_content %}
    <h1 style="margin-top:0; font-size:1.75rem;">Questions</h1>
    {% if questions is empty %}
        <p style="color:#64748b;">No questions yet.</p>
    {% else %}
        <ul style="list-style:none; padding:0; margin:1rem 0 0;">
            {% for q in questions %}
                <li style="background:#fff; border-radius:10px; padding:1rem 1.25rem; margin-bottom:0.75rem; box-shadow:0 1px 3px rgba(0,0,0,.08);">
                    {{ q.questionText }}
                    {% if q.required %}
                        <span style="color:#64748b; font-size:0.85rem;"> (required)</span>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
