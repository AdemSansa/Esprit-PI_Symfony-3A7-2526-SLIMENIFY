{% extends 'layout/app_shell.html.twig' %}

{% block title %}Questions Management{% endblock %}

{% block app_content %}
    <style>
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; gap: 1rem; flex-wrap: wrap; }
        .search-form { display: flex; flex: 1; max-width: 450px; gap: 0.5rem; margin-left: auto; background: #fff; padding: 0.3rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(98, 114, 85, 0.08); border: 1px solid rgba(122, 91, 73, 0.1); }
        .search-input { flex: 1; padding: 0.6rem 1.2rem; border-radius: 8px; border: none; outline: none; font-size: 0.95rem; color: #5D4A3E; background: transparent; }
        .search-btn { background: #627255; color: white; border: none; padding: 0.6rem 1.2rem; border-radius: 8px; cursor: pointer; font-weight: 600; transition: all 0.2s ease; display: flex; align-items: center; gap: 0.4rem; }
        .search-btn:hover { background: #4f5d44; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(98, 114, 85, 0.2); }
        .create-btn { background: linear-gradient(135deg, #748764, #627255); color: white; padding: 0.8rem 1.5rem; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 0.95rem; box-shadow: 0 4px 15px rgba(98, 114, 85, 0.25); white-space: nowrap; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 0.5rem; border: none; }
        .create-btn:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 6px 20px rgba(98, 114, 85, 0.35); text-decoration: none; color: white; }
        
        .question-list { list-style:none; padding:0; margin:0; display: flex; flex-direction: column; gap: 1rem; animation: fadeInSlideUp 0.5s ease-out forwards; }
        .question-item { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); border-radius: 16px; padding: 1.5rem; border: 1px solid rgba(255, 255, 255, 0.6); box-shadow: 0 4px 10px rgba(0,0,0,0.02); display: flex; justify-content: space-between; align-items: center; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); position: relative; overflow: hidden; }
        .question-item::before { content: ''; position: absolute; left: 0; top: 0; width: 4px; height: 100%; background: #A8866E; opacity: 0; transition: opacity 0.3s; }
        .question-item:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(98,114,85,0.1); border-color: rgba(168, 134, 110, 0.3); }
        .question-item:hover::before { opacity: 1; }
        
        .q-text { font-weight: 700; font-size: 1.15rem; margin-bottom: 0.6rem; color: #5D4A3E; line-height: 1.4; }
        .q-meta { color: #808c75; font-size: 0.85rem; display: flex; gap: 1rem; align-items: center; }
        .q-badge { padding: 0.2rem 0.6rem; border-radius: 6px; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
        .badge-req { background: rgba(168, 134, 110, 0.15); color: #A8866E; }
        .badge-opt { background: #f1f5f9; color: #94a3b8; }
        
        .q-actions { display: flex; gap: 0.75rem; flex-shrink: 0; align-items: center; }
        .btn-edit { background: white; color: #748764; text-decoration: none; font-size: 0.85rem; padding: 0.5rem 1rem; border: 1px solid #748764; border-radius: 8px; font-weight: 600; transition: all 0.2s; display: inline-flex; align-items: center; gap: 4px; }
        .btn-edit:hover { background: #748764; color: white; }
    </style>

    <div class="page-header">
        <h1 style="margin:0; font-size:2rem; font-weight: 800; color: #5D4A3E;">Questions <span style="color: #A8866E; font-weight: 400;">Library</span></h1>
        
        <form method="get" action="{{ path('app_question_index') }}" class="search-form">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A8866E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 12px; align-self: center;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" name="q" value="{{ searchQuery ?? '' }}" placeholder="Search questions..." class="search-input">
            {% if searchQuery %}
                <a href="{{ path('app_question_index') }}" style="display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; background: #fee2e2; color: #ef4444; border-radius: 8px; text-decoration: none; font-weight: bold; align-self: center; margin-right: 4px;" title="Clear search">×</a>
            {% endif %}
            <button type="submit" class="search-btn">Search</button>
        </form>

        <a href="{{ path('app_question_new') }}" class="create-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Create New Question
        </a>
    </div>

    {% if questions is empty %}
        <div style="background: rgba(255,255,255,0.6); padding: 4rem 2rem; text-align: center; border-radius: 16px; border: 2px dashed rgba(122,91,73,0.2); backdrop-filter: blur(10px);">
            <div style="width: 64px; height: 64px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#A8866E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <h3 style="color: #5D4A3E; font-size: 1.3rem; margin-bottom: 0.5rem;">No questions found</h3>
            <p style="color:#808c75; font-size: 1rem; margin-bottom: 2rem; max-width: 400px; margin-left: auto; margin-right: auto;">It looks like you haven't created any questions yet, or none match your search.</p>
            <a href="{{ path('app_question_new') }}" class="create-btn" style="padding: 0.6rem 1.2rem;">Start Creating</a>
        </div>
    {% else %}
        <ul class="question-list">
            {% for q in questions %}
                <li class="question-item">
                    <div style="padding-right: 1.5rem; flex: 1;">
                        <div class="q-text">{{ q.questionText }}</div>
                        <div class="q-meta">
                            <span class="q-badge {{ q.required ? 'badge-req' : 'badge-opt' }}">
                                {{ q.required ? 'Required' : 'Optional' }}
                            </span>
                            {% if q.imagePath %}
                                <a href="{{ q.imagePath }}" target="_blank" style="color: #748764; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; font-weight: 600; padding: 0.2rem 0.6rem; background: rgba(116, 135, 100, 0.1); border-radius: 6px; transition: all 0.2s;"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg> View Image</a>
                            {% endif %}
                        </div>
                    </div>
                    <div class="q-actions">
                        <a href="{{ path('app_question_edit', {'id': q.id}) }}" class="btn-edit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            Edit
                        </a>
                        {{ include('question/_delete_form.html.twig', {'question': q}) }}
                    </div>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
