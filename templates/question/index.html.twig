{% extends 'layout/app_shell.html.twig' %}

{% block title %}Questions Management{% endblock %}

{% block app_content %}
    <style>
        .question-shell { display: grid; gap: 1rem; }
        .hero { background: linear-gradient(135deg, #ffffff, #f6f5ed); border: 1px solid rgba(168, 134, 110, 0.22); border-radius: 20px; padding: 1.2rem; box-shadow: 0 10px 24px rgba(98,114,85,0.08); }
        .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; gap: 1rem; flex-wrap: wrap; }
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.6rem; }
        .stat-card { background: #fff; border: 1px solid rgba(122,91,73,0.14); border-radius: 12px; padding: 0.65rem 0.8rem; }
        .stat-label { font-size: 0.72rem; color: #A8866E; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 700; }
        .stat-value { font-size: 1.2rem; color: #5D4A3E; font-weight: 800; }
        .search-form { display: grid; grid-template-columns: 1fr auto auto auto; width: 100%; gap: 0.5rem; margin-top: 0.75rem; background: #fff; padding: 0.45rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(98, 114, 85, 0.08); border: 1px solid rgba(122, 91, 73, 0.1); }
        .search-input { padding: 0.65rem 1rem; border-radius: 9px; border: 1px solid rgba(122,91,73,0.12); outline: none; font-size: 0.95rem; color: #5D4A3E; background: #fff; }
        .category-filter { padding: 0.65rem 0.8rem; border-radius: 9px; border: 1px solid rgba(122,91,73,0.12); outline: none; font-size: 0.92rem; color: #5D4A3E; background: #fff; min-width: 170px; }
        .search-btn { background: #627255; color: white; border: none; padding: 0.65rem 1rem; border-radius: 9px; cursor: pointer; font-weight: 700; transition: all 0.2s ease; }
        .search-btn:hover { background: #4f5d44; transform: translateY(-1px); }
        .create-btn { background: linear-gradient(135deg, #748764, #627255); color: white; padding: 0.78rem 1.35rem; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 0.92rem; box-shadow: 0 4px 15px rgba(98, 114, 85, 0.25); white-space: nowrap; transition: all 0.3s ease; display: inline-flex; align-items: center; gap: 0.45rem; border: none; }
        .create-btn:hover { transform: translateY(-2px) scale(1.02); text-decoration: none; color: white; }
        .question-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; align-items: start; }
        .question-item { background: #fff; border-radius: 16px; padding: 1rem; border: 1px solid rgba(122,91,73,0.13); box-shadow: 0 4px 10px rgba(0,0,0,0.02); transition: transform 0.25s ease, box-shadow 0.25s ease; position: relative; opacity: 0; transform: translateY(10px); animation: qIn .45s ease forwards; animation-delay: calc(var(--i, 0) * 40ms); }
        .question-item:hover { transform: translateY(-3px); box-shadow: 0 12px 24px rgba(98,114,85,0.12); }
        .q-media { margin: -0.15rem -0.15rem 0.8rem; border-radius: 12px; overflow: hidden; border: 1px solid rgba(122,91,73,0.14); background: #f6f5ed; }
        .q-media img { width: 100%; height: 180px; object-fit: cover; display: block; transition: transform 0.35s ease; }
        .question-item:hover .q-media img { transform: scale(1.03); }
        .q-text { font-weight: 800; font-size: 1.02rem; margin-bottom: 0.55rem; color: #5D4A3E; line-height: 1.45; min-height: 48px; }
        .q-meta { color: #808c75; font-size: 0.82rem; display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.8rem; }
        .q-badge { padding: 0.22rem 0.58rem; border-radius: 999px; font-weight: 700; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.05em; }
        .badge-req { background: rgba(168, 134, 110, 0.15); color: #A8866E; }
        .badge-opt { background: #f1f5f9; color: #94a3b8; }
        .badge-cat { background: rgba(98, 114, 85, 0.1); color: #627255; }
        .q-actions { display: flex; gap: 0.55rem; align-items: center; justify-content: flex-end; border-top: 1px dashed rgba(122,91,73,0.18); padding-top: 0.75rem; }
        .btn-edit { background: white; color: #748764; text-decoration: none; font-size: 0.82rem; padding: 0.45rem 0.9rem; border: 1px solid #748764; border-radius: 8px; font-weight: 700; transition: all 0.2s; display: inline-flex; align-items: center; gap: 4px; }
        .btn-edit:hover { background: #748764; color: white; }
        .pagination { display: flex; justify-content: center; gap: 0.45rem; margin-top: 1rem; flex-wrap: wrap; }
        .page-link { background: #fff; color: #627255; border: 1px solid rgba(98,114,85,0.25); border-radius: 8px; padding: 0.45rem 0.75rem; text-decoration: none; font-weight: 700; font-size: 0.85rem; }
        .page-link.current { background: #627255; color: #fff; border-color: #627255; }
        .page-link.disabled { opacity: 0.45; pointer-events: none; }
        @keyframes qIn { to { opacity: 1; transform: translateY(0); } }
    </style>

    <div class="question-shell">
        <div class="hero">
            <div class="page-header">
                <h1 style="margin:0; font-size:2rem; font-weight: 800; color: #5D4A3E;">Questions <span style="color: #A8866E; font-weight: 400;">Library</span></h1>
                <a href="{{ path('app_question_new') }}" class="create-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                    New Question
                </a>
            </div>

            <div class="stats">
                <div class="stat-card">
                    <div class="stat-label">Results</div>
                    <div class="stat-value">{{ totalQuestions }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Current Page</div>
                    <div class="stat-value">{{ currentPage }}/{{ totalPages }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Category Filter</div>
                    <div class="stat-value" style="font-size:0.95rem;">{{ selectedCategory ?: 'All' }}</div>
                </div>
            </div>

            <form method="get" action="{{ path('app_question_index') }}" class="search-form">
                <input type="text" name="q" value="{{ searchQuery ?? '' }}" placeholder="Search question text..." class="search-input">
                <select name="category" class="category-filter">
                    <option value="">All categories</option>
                    {% for label, value in categoryOptions %}
                        <option value="{{ value }}" {{ selectedCategory == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
                {% if searchQuery or selectedCategory %}
                    <a href="{{ path('app_question_index') }}" style="display:flex; align-items:center; justify-content:center; width:38px; background:#fee2e2; color:#ef4444; border-radius:8px; text-decoration:none; font-weight:800;" title="Clear search">×</a>
                {% endif %}
                <button type="submit" class="search-btn">Apply</button>
            </form>
        </div>
    </div>

    {% if questions is empty %}
        <div style="background: rgba(255,255,255,0.6); padding: 4rem 2rem; text-align: center; border-radius: 16px; border: 2px dashed rgba(122,91,73,0.2); backdrop-filter: blur(10px);">
            <div style="width: 64px; height: 64px; background: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#A8866E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <h3 style="color: #5D4A3E; font-size: 1.3rem; margin-bottom: 0.5rem;">No questions found</h3>
            <p style="color:#808c75; font-size: 1rem; margin-bottom: 2rem; max-width: 400px; margin-left: auto; margin-right: auto;">It looks like you haven't created any questions yet, or none match your search.</p>
            <a href="{{ path('app_question_new') }}" class="create-btn" style="padding: 0.6rem 1.2rem;">Start Creating</a>
        </div>
    {% else %}
        <ul class="question-grid" style="list-style:none; padding:0; margin:0;">
            {% for q in questions %}
                <li class="question-item" style="--i: {{ loop.index0 }};">
                    <div style="flex: 1;">
                        {% if q.imagePath %}
                            <a href="{{ q.imagePath }}" target="_blank" class="q-media" title="Open full image">
                                <img src="{{ q.imagePath }}" alt="Question visual" loading="lazy">
                            </a>
                        {% endif %}
                        <div class="q-text">{{ q.questionText }}</div>
                        <div class="q-meta">
                            <span class="q-badge {{ q.required ? 'badge-req' : 'badge-opt' }}">
                                {{ q.required ? 'Required' : 'Optional' }}
                            </span>
                            {% if q.category %}
                                <span class="q-badge badge-cat">{{ q.category }}</span>
                            {% endif %}
                            {% if q.imagePath %}
                                <a href="{{ q.imagePath }}" target="_blank" style="color: #748764; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; font-weight: 700; padding: 0.2rem 0.6rem; background: rgba(116, 135, 100, 0.1); border-radius: 999px; transition: all 0.2s;">View Image</a>
                            {% endif %}
                        </div>
                    </div>
                    <div class="q-actions">
                        <a href="{{ path('app_question_edit', {'id': q.id}) }}" class="btn-edit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            Edit
                        </a>
                        {{ include('question/_delete_form.html.twig', {'question': q}) }}
                    </div>
                </li>
            {% endfor %}
        </ul>

        {% if totalPages > 1 %}
            <nav class="pagination" aria-label="Questions pagination">
                {% set prevPage = currentPage - 1 %}
                {% set nextPage = currentPage + 1 %}

                <a class="page-link {{ currentPage <= 1 ? 'disabled' : '' }}"
                   href="{{ path('app_question_index', {'q': searchQuery, 'category': selectedCategory, 'page': prevPage}) }}">
                    Prev
                </a>

                {% for p in 1..totalPages %}
                    <a class="page-link {{ p == currentPage ? 'current' : '' }}"
                       href="{{ path('app_question_index', {'q': searchQuery, 'category': selectedCategory, 'page': p}) }}">
                        {{ p }}
                    </a>
                {% endfor %}

                <a class="page-link {{ currentPage >= totalPages ? 'disabled' : '' }}"
                   href="{{ path('app_question_index', {'q': searchQuery, 'category': selectedCategory, 'page': nextPage}) }}">
                    Next
                </a>
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}
