<style>
    .custom-form-container {
        background: #ffffff; border-radius: 16px; box-shadow: 0 10px 30px rgba(98, 114, 85, 0.1); padding: 2.5rem; border: 1px solid rgba(122, 91, 73, 0.1); margin-top: 1rem; position: relative; max-width: 800px;
    }
    .custom-form-container::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 6px; background: linear-gradient(to right, #748764, #A8866E); border-radius: 16px 16px 0 0;
    }
    .form-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
    .form-label { font-weight: 600; color: #5D4A3E; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; }
    .form-control {
        padding: 0.85rem 1.2rem; border-radius: 10px; border: 1px solid #d5d9d1; font-size: 1rem; color: #5D4A3E; background: #fafaf9; transition: all 0.3s; width: 100%; box-sizing: border-box;
    }
    .form-control:focus { outline: none; border-color: #748764; box-shadow: 0 0 0 4px rgba(116, 135, 100, 0.1); background: #ffffff; }
    
    .modern-checkbox {
        appearance: none; width: 1.4rem; height: 1.4rem; border: 2px solid #A8866E; border-radius: 6px; position: relative; cursor: pointer; background: white; margin: 0; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center;
    }
    .modern-checkbox:checked { background: #627255; border-color: #627255; }
    .modern-checkbox:checked::after {
        content: ''; width: 6px; height: 10px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); margin-top: -2px;
    }
    
    .switch-wrap { display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0; padding: 1rem 1.5rem; background: #f6f8f5; border-radius: 10px; border: 1px solid rgba(98, 114, 85, 0.1); }
    .form-actions { display: flex; justify-content: flex-end; gap: 1rem; border-top: 1px solid rgba(122, 91, 73, 0.1); padding-top: 1.5rem; }
    .btn-submit {
        background: linear-gradient(135deg, #748764, #627255); color: white; border: none; padding: 0.8rem 2rem; border-radius: 10px; cursor: pointer; font-size: 1rem; font-weight: 700; transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(98, 114, 85, 0.3); display: inline-flex; align-items: center; gap: 0.5rem;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(98, 114, 85, 0.4); }

    /* Custom form errors styling */
    .custom-form-container > ul, .form-group ul, .switch-wrap ul {
        list-style: none;
        padding: 0;
        margin: 0.3rem 0 1rem 0;
        color: #dc3545;
        font-size: 0.85rem;
        font-weight: 500;
    }
    .custom-form-container > ul li, .form-group ul li, .switch-wrap ul li {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .custom-form-container > ul li::before, .form-group ul li::before, .switch-wrap ul li::before {
        content: '⚠';
    }
</style>

{{ form_start(form, {'attr': {'class': 'custom-form-container', 'novalidate': 'novalidate'}}) }}
    {{ form_errors(form) }}

    <div class="form-group">
        {{ form_label(form.questionText, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.questionText, {'attr': {'class': 'form-control', 'placeholder': 'Enter the question text...', 'rows': 3}}) }}
        {{ form_errors(form.questionText) }}
    </div>

    <div class="form-group">
        {{ form_label(form.imagePath, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.imagePath, {'attr': {'class': 'form-control', 'placeholder': 'Optional: URL for an associated image'}}) }}
        {{ form_errors(form.imagePath) }}
    </div>

    <div class="switch-wrap">
        {{ form_widget(form.required, {'attr': {'class': 'modern-checkbox'}}) }}
        {{ form_label(form.required, 'Is this question required?', {'label_attr': {'class': 'form-label', 'style': 'cursor: pointer; margin: 0;'}}) }}
        {{ form_errors(form.required) }}
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            {{ button_label|default('Save Question') }}
        </button>
    </div>
{{ form_end(form) }}
