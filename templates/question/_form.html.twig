<style>
    .custom-form-container {
        background: #ffffff; border-radius: 16px; box-shadow: 0 10px 30px rgba(98, 114, 85, 0.1); padding: 2.5rem; border: 1px solid rgba(122, 91, 73, 0.1); margin-top: 1rem; position: relative; max-width: 800px;
    }
    .custom-form-container::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 6px; background: linear-gradient(to right, #748764, #A8866E); border-radius: 16px 16px 0 0;
    }
    .form-group { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem; }
    .form-label { font-weight: 600; color: #5D4A3E; font-size: 0.95rem; display: flex; align-items: center; gap: 0.5rem; }
    .form-control {
        padding: 0.85rem 1.2rem; border-radius: 10px; border: 1px solid #d5d9d1; font-size: 1rem; color: #5D4A3E; background: #fafaf9; transition: all 0.3s; width: 100%; box-sizing: border-box;
    }
    .form-control:focus { outline: none; border-color: #748764; box-shadow: 0 0 0 4px rgba(116, 135, 100, 0.1); background: #ffffff; }
    
    .modern-checkbox {
        appearance: none; width: 1.4rem; height: 1.4rem; border: 2px solid #A8866E; border-radius: 6px; position: relative; cursor: pointer; background: white; margin: 0; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center;
    }
    .modern-checkbox:checked { background: #627255; border-color: #627255; }
    .modern-checkbox:checked::after {
        content: ''; width: 6px; height: 10px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); margin-top: -2px;
    }
    
    .switch-wrap { display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0; padding: 1rem 1.5rem; background: #f6f8f5; border-radius: 10px; border: 1px solid rgba(98, 114, 85, 0.1); }
    .form-actions { display: flex; justify-content: flex-end; gap: 1rem; border-top: 1px solid rgba(122, 91, 73, 0.1); padding-top: 1.5rem; }
    .btn-submit {
        background: linear-gradient(135deg, #748764, #627255); color: white; border: none; padding: 0.8rem 2rem; border-radius: 10px; cursor: pointer; font-size: 1rem; font-weight: 700; transition: all 0.3s;
        box-shadow: 0 4px 15px rgba(98, 114, 85, 0.3); display: inline-flex; align-items: center; gap: 0.5rem;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(98, 114, 85, 0.4); }

    /* Custom form errors styling */
    .custom-form-container > ul, .form-group ul, .switch-wrap ul {
        list-style: none;
        padding: 0;
        margin: 0.3rem 0 1rem 0;
        color: #dc3545;
        font-size: 0.85rem;
        font-weight: 500;
    }
    .custom-form-container > ul li, .form-group ul li, .switch-wrap ul li {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .custom-form-container > ul li::before, .form-group ul li::before, .switch-wrap ul li::before {
        content: '⚠';
    }
    .btn-ai {
        background: linear-gradient(135deg, #A8866E, #8C6D58); color: white; border: none; padding: 0.6rem 1.2rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: all 0.3s;
        box-shadow: 0 4px 10px rgba(168, 134, 110, 0.3); display: inline-flex; align-items: center; gap: 0.4rem; font-family: inherit; margin-top: 0.5rem;
    }
    .btn-ai:hover { transform: translateY(-2px); box-shadow: 0 6px 12px rgba(168, 134, 110, 0.4); }
    .btn-ai:disabled { background: #d5d9d1; cursor: not-allowed; box-shadow: none; transform: none; }
    .ai-loading { font-size: 0.9rem; color: #5D4A3E; margin-top: 0.8rem; font-style: italic; display: none; }
    .ai-error { color: #dc3545; font-size: 0.85rem; margin-top: 0.8rem; display: none; font-weight: 600; }
    .ai-suggestions-container {
        margin-top: 1rem; display: none; flex-direction: column; gap: 0.6rem;
    }
    .suggestion-chip {
        background: #f6f8f5; border: 1px solid #d5d9d1; padding: 0.8rem 1rem; border-radius: 8px; cursor: pointer; font-size: 0.95rem; color: #5D4A3E; text-align: left; transition: all 0.2s; position: relative; font-family: inherit; line-height: 1.4;
    }
    .suggestion-chip:hover {
        background: #ffffff; border-color: #A8866E; box-shadow: 0 2px 8px rgba(168, 134, 110, 0.1);
    }
    .suggestion-chip span.label {
        font-size: 0.75rem; font-weight: 700; color: #748764; text-transform: uppercase; margin-bottom: 0.3rem; display: block;
    }
    
    .btn-mic {
        position: absolute; right: 10px; background: #eef1ec; border: none; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s; font-size: 1.1rem; color: #5D4A3E; outline: none;
    }
    .btn-mic:hover { background: #d5d9d1; transform: scale(1.05); }
    .btn-mic.recording {
        background: #dc3545; color: white; animation: pulse-mic 1.5s infinite; filter: hue-rotate(0deg);
    }
    @keyframes pulse-mic {
        0% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(220, 53, 69, 0); }
        100% { box-shadow: 0 0 0 0 rgba(220, 53, 69, 0); }
    }
</style>

{{ form_start(form, {'attr': {'class': 'custom-form-container', 'novalidate': 'novalidate'}}) }}
    {{ form_errors(form) }}

    <div class="form-group">
        {{ form_label(form.questionText, null, {'label_attr': {'class': 'form-label'}}) }}
        <div style="position: relative; display: flex; align-items: center;">
            {{ form_widget(form.questionText, {'attr': {'class': 'form-control', 'placeholder': 'Enter the question text...', 'rows': 3, 'style': 'padding-right: 3.5rem;'}}) }}
            <button type="button" id="btn-mic" class="btn-mic" title="Click to speak your question">
                🎙️
            </button>
        </div>
        {{ form_errors(form.questionText) }}
        
        <div class="ai-suggestion-wrapper">
            <button type="button" id="btn-ai-suggest" class="btn-ai" title="Get AI rewrites for your question">
                ✨ Give me AI suggestion
            </button>
            <div id="ai-loading" class="ai-loading">Generating AI suggestions... ⏳</div>
            <div id="ai-error" class="ai-error"></div>
            <div id="ai-suggestions-container" class="ai-suggestions-container"></div>
        </div>
    </div>

    <div class="form-group">
        {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.imageFile) }}
        {% if question is defined and question.imagePath %}
            <div style="margin-top: 0.6rem;">
                <a href="{{ question.imagePath }}" target="_blank" style="font-size: 0.85rem; color: #627255; font-weight: 600; text-decoration: none;">
                    Preview current image
                </a>
            </div>
        {% endif %}
    </div>

    <div class="form-group">
        {{ form_label(form.category, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.category, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Anxiety, Depression, Behavior'}}) }}
        {{ form_errors(form.category) }}
    </div>

    <div class="switch-wrap">
        {{ form_widget(form.required, {'attr': {'class': 'modern-checkbox'}}) }}
        {{ form_label(form.required, 'Is this question required?', {'label_attr': {'class': 'form-label', 'style': 'cursor: pointer; margin: 0;'}}) }}
        {{ form_errors(form.required) }}
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            {{ button_label|default('Save Question') }}
        </button>
    </div>
{{ form_end(form) }}

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const btnAi = document.getElementById('btn-ai-suggest');
        const questionInput = document.querySelector('input[name*="[questionText]"], textarea[name*="[questionText]"], [id$="_questionText"]');
        const loading = document.getElementById('ai-loading');
        const errorDiv = document.getElementById('ai-error');
        const suggestionsContainer = document.getElementById('ai-suggestions-container');
        const btnMic = document.getElementById('btn-mic');

        // --- Web Speech API (Voice to text) ---
        if(btnMic && questionInput) {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            
            if (!SpeechRecognition) {
                btnMic.style.display = 'none'; // Hide if browser doesn't natively support it
            } else {
                const recognition = new SpeechRecognition();
                recognition.continuous = false;
                recognition.interimResults = false;
                // Defaults to the user's OS language
                recognition.lang = document.documentElement.lang || navigator.language || 'en-US';

                let isRecording = false;

                btnMic.addEventListener('click', () => {
                    if (isRecording) {
                        recognition.stop();
                    } else {
                        recognition.start();
                    }
                });

                recognition.onstart = function() {
                    isRecording = true;
                    btnMic.classList.add('recording');
                    btnMic.title = "Recording... Click to stop";
                };

                recognition.onresult = function(event) {
                    const transcript = event.results[0][0].transcript;
                    if (questionInput.value.length > 0) {
                        // Insert a space if there's already some text
                        questionInput.value += (questionInput.value.endsWith(' ') ? '' : ' ') + transcript;
                    } else {
                        questionInput.value = transcript;
                    }
                };

                recognition.onerror = function(event) {
                    console.error('Speech recognition error', event.error);
                };

                recognition.onend = function() {
                    isRecording = false;
                    btnMic.classList.remove('recording');
                    btnMic.title = "Click to speak your question";
                };
            }
        }

        if(btnAi && questionInput) {
            btnAi.addEventListener('click', async function() {
                const text = questionInput.value.trim();
                if(!text) {
                    errorDiv.textContent = '⚠ Please type a question snippet first.';
                    errorDiv.style.display = 'block';
                    return;
                }

                errorDiv.style.display = 'none';
                suggestionsContainer.style.display = 'none';
                loading.style.display = 'block';
                btnAi.disabled = true;
                btnAi.innerHTML = '✨ Generating...';

                try {
                    const response = await fetch('/api/ai-suggest', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ question: text })
                    });

                    const data = await response.json();

                    if(!response.ok) {
                        throw new Error(data.error || 'Failed to generate suggestions');
                    }

                    // Render suggestions
                    suggestionsContainer.innerHTML = '';
                    const labels = {
                        "simpler": "🟢 Simpler",
                        "reverse_meaning": "🔴 Reverse Meaning",
                        "more_emotional": "💜 More Emotional",
                        "more_abstract": "🔵 More Abstract",
                        "softer_tone": "🌸 Softer Tone",
                    };

                    Object.keys(data).forEach(key => {
                        if(labels[key] && data[key]) {
                            const btn = document.createElement('button');
                            btn.type = 'button';
                            btn.className = 'suggestion-chip';
                            btn.innerHTML = `<span class="label">${labels[key]}</span><span class="text">${data[key]}</span>`;
                            btn.addEventListener('click', () => {
                                questionInput.value = data[key];
                                // Optional: Smooth scroll back to input
                                questionInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            });
                            suggestionsContainer.appendChild(btn);
                        }
                    });

                    suggestionsContainer.style.display = 'flex';
                } catch(e) {
                    errorDiv.textContent = '❌ Error: ' + e.message;
                    errorDiv.style.display = 'block';
                } finally {
                    loading.style.display = 'none';
                    btnAi.disabled = false;
                    btnAi.innerHTML = '✨ Give me AI suggestion';
                }
            });
        }
    });
</script>
