{{ form_start(form, {'attr': {'class': 'auth-card', 'style': 'margin-top: 1rem;'}}) }}
    {{ form_errors(form) }}

    <div class="auth-field">
        {{ form_label(form.questionText, null, {'label_attr': {'class': 'auth-label'}}) }}
        {{ form_widget(form.questionText) }}
        {{ form_errors(form.questionText) }}
    </div>

    <div class="auth-field">
        {{ form_label(form.imagePath, null, {'label_attr': {'class': 'auth-label'}}) }}
        {{ form_widget(form.imagePath) }}
        {{ form_errors(form.imagePath) }}
    </div>

    <div class="auth-checkbox-wrap" style="margin-top: 1.5rem; margin-bottom: 1.5rem;">
        {{ form_widget(form.required) }}
        {{ form_label(form.required, null, {'label_attr': {'class': 'auth-checkbox-label'}}) }}
        {{ form_errors(form.required) }}
    </div>

    <button class="auth-submit" style="width: auto; padding: 0.75rem 1.5rem;">{{ button_label|default('Save') }}</button>
{{ form_end(form) }}
