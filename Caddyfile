{
    auto_https off
    admin off
    order php_server before file_server
}

http://0.0.0.0:{$PORT:8080} {
    root * /app/public
    log {
        output stdout
        format console
    }
    respond /health "ok" 200
    try_files {path} /index.php?{query}
    php_server
    file_server
    encode zstd gzip
}
